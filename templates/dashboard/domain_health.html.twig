{% extends 'dashboard/layout.html.twig' %}

{% block page_title %}Health — {{ domain.domainName }}{% endblock %}
{% block breadcrumbs %}
    <li><a href="{{ path('dashboard_domains') }}">Domains</a></li>
    <li><a href="{{ path('dashboard_domain_detail', { id: domain.domainId }) }}">{{ domain.domainName }}</a></li>
    <li>Health</li>
{% endblock %}

{% block page_heading %}
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
        <div>
            <h1 class="text-2xl font-bold">Domain Health</h1>
            <p class="text-sm text-base-content/60 mt-1">Health score and trend for {{ domain.domainName }}</p>
        </div>
        <div class="flex items-center gap-2">
            <a href="{{ path('dashboard_export_domain_pdf', { id: domain.domainId }) }}" class="btn btn-ghost btn-sm">
                Export PDF
            </a>
            {% if latest and latest.shareHash %}
                <a href="{{ path('public_domain_health', { hash: latest.shareHash }) }}" target="_blank" class="btn btn-ghost btn-sm">
                    Share
                </a>
            {% endif %}
        </div>
    </div>
{% endblock %}

{% block content %}
    <twig:DomainWorkspaceTabs :domain="domain" active="dns" />

    {% if ruaInstruction is defined and ruaInstruction is not null and not ruaInstruction.alreadyConfigured %}
        <div class="mb-6">
            <twig:DnsRecordInstruction
                recordType="TXT"
                host="_dmarc.{{ domain.domainName }}"
                whatText="Forward DMARC reports to Sendvery"
                whyText="DMARC reports are how mail providers tell you who's sending email as your domain. This TXT record points those reports at us so we can show them to you as charts and alerts."
                currentValue="{{ ruaInstruction.currentRecord }}"
                finalValue="{{ ruaInstruction.finalRecord }}"
                :alreadyConfigured="false"
            />
        </div>
    {% endif %}

    {# TASK-095: per-category DNS recommendations. Renders one card per
       category that has actionable guidance — SPF "missing" / "over the
       lookup limit", DKIM "no key found", DMARC "publish me" (in addition
       to the rua= add card above). When the recommender has a literal record
       to publish we use the existing DnsRecordInstruction card; otherwise
       a lighter DnsRecordHowTo text-only variant. #}
    {% if dnsRecommendations is defined and dnsRecommendations|length > 0 %}
        <div class="space-y-4 mb-6" data-testid="dns-record-recommendations">
            {% for rec in dnsRecommendations %}
                {# DMARC's recommendation is already covered by the ruaInstruction
                   card above — skip the duplicate render. #}
                {% if rec.category.value != 'dmarc' %}
                    {% if rec.recommendedValue is not null %}
                        <twig:DnsRecordInstruction
                            recordType="{{ rec.recordType }}"
                            host="{{ rec.recordHost }}"
                            whatText="{{ rec.whatText }}"
                            whyText="{{ rec.whyText }}"
                            finalValue="{{ rec.recommendedValue }}"
                            :alreadyConfigured="false"
                        />
                    {% else %}
                        <twig:DnsRecordHowTo
                            recordType="{{ rec.recordType }}"
                            host="{{ rec.recordHost }}"
                            whatText="{{ rec.whatText }}"
                            whyText="{{ rec.whyText }}"
                            kbSlug="{{ rec.category.value == 'dkim' ? 'what-is-dkim' : (rec.category.value == 'spf' ? 'spf-record-guide' : null) }}"
                        />
                    {% endif %}
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}

    {% if latest %}
        {# Current score #}
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
            <div id="health-score" class="card bg-base-100 shadow">
                <div class="card-body items-center text-center">
                    <div class="text-7xl font-bold {{ latest.gradeColor() }}">{{ latest.grade }}</div>
                    <div class="text-2xl font-semibold mt-2">{{ latest.score }}/100</div>
                    <p class="text-sm text-base-content/60 mt-1">Overall Health Score</p>
                </div>
            </div>

            <div class="col-span-2 card bg-base-100 shadow">
                <div class="card-body">
                    <h3 class="card-title text-lg mb-4">Category Scores</h3>
                    <div class="space-y-3">
                        {% set categories = [
                            { name: 'SPF',       score: latest.spfScore,       id: 'health-spf' },
                            { name: 'DKIM',      score: latest.dkimScore,      id: 'health-dkim' },
                            { name: 'DMARC',     score: latest.dmarcScore,     id: 'health-dmarc' },
                            { name: 'MX',        score: latest.mxScore,        id: 'health-mx' },
                            { name: 'Blacklist', score: latest.blacklistScore, id: 'health-blacklist' },
                        ] %}
                        {% for cat in categories %}
                            <div id="{{ cat.id }}">
                                <div class="flex justify-between text-sm mb-1">
                                    <span>{{ cat.name }}</span>
                                    <span class="font-medium">{{ cat.score }}%</span>
                                </div>
                                {% if cat.id == 'health-blacklist' %}
                                    <a href="{{ path('dashboard_blacklist_status', {id: domain.domainId}) }}" class="block">
                                {% endif %}
                                <progress class="progress {{ cat.score >= 80 ? 'progress-success' : (cat.score >= 50 ? 'progress-warning' : 'progress-error') }} w-full" value="{{ cat.score }}" max="100"></progress>
                                {% if cat.id == 'health-blacklist' %}
                                    </a>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        {# Trend chart #}
        {% if trendChartConfig %}
            <div id="health-trend" class="card bg-base-100 shadow mb-6">
                <div class="card-body">
                    <h3 class="card-title text-lg">Score Trend</h3>
                    <div {{ stimulus_controller('chart') }} {{ stimulus_target('chart', 'canvas') }} data-chart-config-value="{{ trendChartConfig|json_encode }}"></div>
                </div>
            </div>
        {% endif %}
    {% else %}
        <div class="card bg-base-100 shadow">
            <div class="card-body text-center py-12">
                <p class="text-base-content/60">No health snapshots yet.</p>
                <p class="text-sm text-base-content/50 mt-2">Health snapshots are generated automatically during the nightly DNS check.</p>
            </div>
        </div>
    {% endif %}
{% endblock %}
