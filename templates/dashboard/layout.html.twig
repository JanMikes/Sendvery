{% extends 'base.html.twig' %}

{% block title %}{% block page_title %}Dashboard{% endblock %} — Sendvery{% endblock %}

{% block body %}
<div class="min-h-screen flex" {{ stimulus_controller('sidebar') }}>
    {# Mobile overlay #}
    <div class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden"
         {{ stimulus_target('sidebar', 'overlay') }}
         {{ stimulus_action('sidebar', 'close') }}></div>

    {# Sidebar #}
    <aside class="fixed lg:sticky top-0 left-0 z-50 lg:z-auto w-64 h-screen bg-base-200 border-r border-base-300 flex flex-col transition-transform duration-200 -translate-x-full lg:translate-x-0"
           {{ stimulus_target('sidebar', 'sidebar') }}>
        {# Logo + Team #}
        <div class="p-4 border-b border-base-300">
            <a href="{{ path('dashboard_overview') }}" class="text-xl font-bold text-primary tracking-tight">
                Sendvery
            </a>
            <p class="text-xs text-base-content/50 mt-0.5">Email Health Dashboard</p>
        </div>

        {# Team switcher / chip — the always-visible "which team am I working with" affordance #}
        {% set _active_membership = active_membership() %}
        {% set _memberships = all_memberships() %}
        {% if _active_membership %}
            <div class="px-3 py-3 border-b border-base-300">
                <p class="text-[10px] uppercase tracking-wider text-base-content/40 mb-1.5">Team</p>
                {% if _memberships|length > 1 %}
                    <div class="dropdown dropdown-bottom w-full">
                        <label tabindex="0" class="btn btn-ghost btn-sm w-full justify-between font-normal normal-case">
                            <span class="truncate text-left">
                                <span class="font-medium block truncate">{{ _active_membership.team.name }}</span>
                                <span class="text-[10px] text-base-content/50 block">{{ _active_membership.team.plan | capitalize }} plan · {{ _active_membership.role.value | capitalize }}</span>
                            </span>
                            <svg class="w-4 h-4 flex-shrink-0 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"></path></svg>
                        </label>
                        <ul tabindex="0" class="dropdown-content menu menu-sm z-50 mt-1 w-60 rounded-box bg-base-100 border border-base-300 shadow-lg p-1">
                            <li class="menu-title">
                                <span class="text-[10px] uppercase tracking-wider">Switch team</span>
                            </li>
                            {% for option in _memberships %}
                                <li>
                                    <form method="post" action="{{ path('team_switch_active') }}" class="p-0">
                                        <input type="hidden" name="team_id" value="{{ option.team.id }}">
                                        <input type="hidden" name="return_to" value="{{ app.request.requestUri }}">
                                        <button type="submit" class="flex items-center justify-between w-full text-left {% if option.team.id == _active_membership.team.id %}bg-base-200{% endif %}">
                                            <span class="truncate">
                                                <span class="font-medium block truncate">{{ option.team.name }}</span>
                                                <span class="text-[10px] text-base-content/50 block">{{ option.team.plan | capitalize }} · {{ option.role.value | capitalize }}</span>
                                            </span>
                                            {% if option.team.id == _active_membership.team.id %}
                                                <svg class="w-4 h-4 text-primary flex-shrink-0 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                            {% endif %}
                                        </button>
                                    </form>
                                </li>
                            {% endfor %}
                            <div class="divider my-1"></div>
                            <li>
                                <a href="{{ path('team_settings') }}" class="text-xs text-base-content/70">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                    Manage team
                                </a>
                            </li>
                        </ul>
                    </div>
                {% else %}
                    <div class="px-1">
                        <p class="font-medium text-sm truncate">{{ _active_membership.team.name }}</p>
                        <p class="text-[10px] text-base-content/50">{{ _active_membership.team.plan | capitalize }} plan · {{ _active_membership.role.value | capitalize }}</p>
                    </div>
                {% endif %}
            </div>
        {% endif %}

        {# Navigation #}
        <nav class="flex-1 overflow-y-auto p-3 space-y-1">
            {% set current_route = app.request.attributes.get('_route') %}

            <a href="{{ path('dashboard_overview') }}"
               class="flex items-center gap-3 px-3 py-2 rounded-btn text-sm font-medium {{ current_route == 'dashboard_overview' ? 'bg-primary text-primary-content' : 'text-base-content/70 hover:bg-base-300 hover:text-base-content' }}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                Dashboard
            </a>

            <a href="{{ path('dashboard_domains') }}"
               class="flex items-center gap-3 px-3 py-2 rounded-btn text-sm font-medium {{ current_route starts with 'dashboard_domain' ? 'bg-primary text-primary-content' : 'text-base-content/70 hover:bg-base-300 hover:text-base-content' }}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
                Domains
            </a>

            <a href="{{ path('dashboard_reports') }}"
               class="flex items-center gap-3 px-3 py-2 rounded-btn text-sm font-medium {{ current_route starts with 'dashboard_report' ? 'bg-primary text-primary-content' : 'text-base-content/70 hover:bg-base-300 hover:text-base-content' }}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                Reports
            </a>

            <a href="{{ path('dashboard_quarantine') }}"
               class="flex items-center gap-3 px-3 py-2 rounded-btn text-sm font-medium {{ current_route starts with 'dashboard_quarantine' ? 'bg-primary text-primary-content' : 'text-base-content/70 hover:bg-base-300 hover:text-base-content' }}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8l1 12a2 2 0 002 2h8a2 2 0 002-2L19 8M10 12v4m4-4v4"></path></svg>
                Quarantine
                {% if quarantine_count > 0 %}<span class="badge badge-xs badge-warning ml-auto">{{ quarantine_count }}</span>{% endif %}
            </a>

            <a href="{{ path('dashboard_alerts') }}"
               class="flex items-center gap-3 px-3 py-2 rounded-btn text-sm font-medium {{ current_route starts with 'dashboard_alert' ? 'bg-primary text-primary-content' : 'text-base-content/70 hover:bg-base-300 hover:text-base-content' }}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                Alerts
            </a>

            <a href="{{ path('dashboard_dns_health') }}"
               class="flex items-center gap-3 px-3 py-2 rounded-btn text-sm font-medium {{ current_route == 'dashboard_dns_health' ? 'bg-primary text-primary-content' : 'text-base-content/70 hover:bg-base-300 hover:text-base-content' }}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                DNS Health
            </a>

            <a href="{{ path('dashboard_mailboxes') }}"
               class="flex items-center gap-3 px-3 py-2 rounded-btn text-sm font-medium {{ current_route starts with 'dashboard_mailbox' ? 'bg-primary text-primary-content' : 'text-base-content/70 hover:bg-base-300 hover:text-base-content' }}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                Mailboxes
            </a>

            <div class="divider my-2 text-xs text-base-content/30">Settings</div>

            <a href="{{ path('team_settings') }}"
               class="flex items-center gap-3 px-3 py-2 rounded-btn text-sm font-medium {{ current_route starts with 'team_' ? 'bg-primary text-primary-content' : 'text-base-content/70 hover:bg-base-300 hover:text-base-content' }}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                Team
            </a>

            <a href="{{ path('dashboard_preferences') }}"
               class="flex items-center gap-3 px-3 py-2 rounded-btn text-sm font-medium {{ current_route == 'dashboard_preferences' ? 'bg-primary text-primary-content' : 'text-base-content/70 hover:bg-base-300 hover:text-base-content' }}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                Settings
            </a>

            <a href="{{ path('dashboard_billing') }}"
               class="flex items-center gap-3 px-3 py-2 rounded-btn text-sm font-medium {{ current_route starts with 'dashboard_billing' ? 'bg-primary text-primary-content' : 'text-base-content/70 hover:bg-base-300 hover:text-base-content' }}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                Billing
            </a>
        </nav>

        {# Sidebar footer #}
        <div class="p-3 border-t border-base-300">
            <a href="{{ path('home') }}" class="flex items-center gap-3 px-3 py-2 rounded-btn text-sm text-base-content/50 hover:text-base-content hover:bg-base-300">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12"></path></svg>
                Back to website
            </a>
        </div>
    </aside>

    {# Main content #}
    <div class="flex-1 flex flex-col min-h-screen">
        {# Top bar #}
        <header class="sticky top-0 z-30 bg-base-100/80 backdrop-blur-md border-b border-base-200">
            <div class="flex items-center justify-between px-4 lg:px-6 h-14">
                <div class="flex items-center gap-3">
                    {# Mobile hamburger #}
                    <button class="btn btn-ghost btn-sm btn-square lg:hidden"
                            {{ stimulus_action('sidebar', 'toggle') }}
                            aria-label="Toggle sidebar">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                    </button>

                    {# Breadcrumbs #}
                    <div class="breadcrumbs text-sm">
                        <ul>
                            <li><a href="{{ path('dashboard_overview') }}">Dashboard</a></li>
                            {% block breadcrumbs %}{% endblock %}
                        </ul>
                    </div>
                </div>

                <div class="flex items-center gap-2">
                    {% block header_actions %}{% if app.user %}<twig:GlobalAddDropdown />{% endif %}{% endblock %}
                    {% if app.user %}
                        <span class="text-sm text-base-content/50 hidden sm:inline">{{ app.user.email }}</span>
                        <a href="{{ path('auth_logout') }}" class="btn btn-ghost btn-sm">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                            <span class="hidden sm:inline">Logout</span>
                        </a>
                    {% endif %}
                </div>
            </div>
        </header>

        {# Page content #}
        <main class="flex-1 p-4 lg:p-6">
            {% block content %}{% endblock %}
        </main>
    </div>

    {# Feedback widget #}
    {% include 'dashboard/_feedback_widget.html.twig' %}
</div>
{% endblock %}
