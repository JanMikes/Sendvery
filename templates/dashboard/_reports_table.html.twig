{% import 'components/_severity_glyph.html.twig' as severity %}
<turbo-frame id="reports-table">
    <div class="card bg-base-100 border border-base-200 shadow-sm">
        <div class="card-body p-4">
            <div class="overflow-x-auto">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            {# 32px-wide leading severity glyph (TASK-069). sr-only
                               header so the column is screen-reader-labelled but
                               visually anonymous — the glyph is the cue, the
                               Pass Rate column on the right is the precise label. #}
                            <th class="w-8"><span class="sr-only">Health</span></th>
                            <th>Domain</th>
                            <th>Reporter</th>
                            <th>Date Range</th>
                            <th class="text-right">Records</th>
                            <th class="text-right">Pass Rate</th>
                        </tr>
                    </thead>
                    <tbody>
                        {# Row-level navigation via stretched-link (a11y, middle-click, keyboard safe).
                           The <tr> is position:relative; the <a> is absolute inset-0 inside the first <td>.
                           If a future row adds a <button> or secondary <a>, give its containing <td>
                           (or the control itself) class="relative z-20" so it wins pointer events.
                           data-turbo-frame="_top" is required here because this table is wrapped in
                           <turbo-frame id="reports-table"> — without it, the link would try to swap
                           the report-detail page into this frame instead of loading as a full page.
                           Leading severity glyph + `border-l-{tone}` per TASK-069: a single failing
                           report jumps off the page instead of forcing the user to read every number. #}
                        {% for report in reports %}
                            {% set reportTone = severity.pass_rate_tone(report.passRate)|trim %}
                            <tr class="hover:bg-base-200/50 cursor-pointer relative border-l-4 border-l-{{ reportTone }}">
                                <td class="w-8">
                                    {{ severity.glyph(reportTone, 'sm') }}
                                </td>
                                <td class="font-medium">
                                    <a href="{{ path('dashboard_report_detail', { id: report.reportId }) }}"
                                       class="absolute inset-0 z-10"
                                       data-turbo-frame="_top"
                                       aria-label="View report from {{ report.reporterOrg }}"></a>
                                    {{ report.domainName }}
                                </td>
                                <td>{{ report.reporterOrg }}</td>
                                <td>{{ report.dateRangeBegin|date('M j') }} — {{ report.dateRangeEnd|date('M j, Y') }}</td>
                                <td class="text-right">{{ report.recordCount }}</td>
                                <td class="text-right">
                                    <span class="text-{{ reportTone }}">
                                        {{ report.passRate|number_format(1) }}%
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {# Pagination #}
            <div class="flex items-center justify-between mt-4">
                <div class="text-xs text-base-content/50">
                    Page {{ currentPage }}
                </div>
                <div class="join">
                    {% if currentPage > 1 %}
                        <a href="{{ path('dashboard_reports', filterParams|merge({ page: currentPage - 1 })) }}"
                           class="join-item btn btn-sm"
                           data-turbo-frame="reports-table">Previous</a>
                    {% endif %}
                    {% if hasNextPage %}
                        <a href="{{ path('dashboard_reports', filterParams|merge({ page: currentPage + 1 })) }}"
                           class="join-item btn btn-sm"
                           data-turbo-frame="reports-table">Next</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</turbo-frame>
