{% extends 'dashboard/layout.html.twig' %}

{% block page_title %}Overview{% endblock %}

{% block page_heading %}
    <div class="mb-6">
        <h1 class="text-2xl font-bold">Dashboard</h1>
        <p class="text-sm text-base-content/60 mt-1 max-w-2xl">Your team's email health at a glance — start with the next action below.</p>
    </div>
{% endblock %}

{% block content %}
    {% set isEmptyState = (nextAction.actionKey.value == 'add_domain') %}

    {# Health Summary Banner — single "are we healthy?" headline. #}
    {% set summaryTone = {
        success: {bar: 'bg-success', badge: 'bg-success/10 text-success', icon: 'check'},
        warning: {bar: 'bg-warning', badge: 'bg-warning/10 text-warning', icon: 'warn'},
        error:   {bar: 'bg-error', badge: 'bg-error/10 text-error', icon: 'warn'},
    }[healthSummary.severity] %}
    <div class="rounded-2xl border border-base-200 bg-base-100 overflow-hidden mb-4 shadow-sm">
        <div class="h-1 {{ summaryTone.bar }}"></div>
        <div class="p-4 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0 {{ summaryTone.badge }}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    {% if summaryTone.icon == 'check' %}
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                    {% else %}
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M5.07 19h13.86c1.54 0 2.5-1.67 1.73-2.5L13.73 4a2 2 0 00-3.46 0L3.34 16.5c-.77.83.19 2.5 1.73 2.5z"/>
                    {% endif %}
                </svg>
            </div>
            <div class="flex-1 min-w-0">
                <div class="text-base font-semibold text-base-content">{{ healthSummary.headline }}</div>
            </div>
            {% if healthSummary.domainsTotalCount > 0 %}
                <div class="flex flex-wrap items-center gap-3 text-xs text-base-content/60">
                    {% if healthSummary.domainsHealthyCount > 0 %}
                        <a href="{{ path('dashboard_domains', { status: 'healthy' }) }}" class="inline-flex items-center gap-1 hover:underline">
                            <span class="w-2 h-2 rounded-full bg-success"></span>
                            {{ healthSummary.domainsHealthyCount }} healthy
                        </a>
                    {% endif %}
                    {% if healthSummary.domainsAttentionCount > 0 %}
                        <a href="{{ path('dashboard_domains', { status: 'attention' }) }}" class="inline-flex items-center gap-1 hover:underline">
                            <span class="w-2 h-2 rounded-full bg-warning"></span>
                            {{ healthSummary.domainsAttentionCount }} need attention
                        </a>
                    {% endif %}
                    {% if healthSummary.domainsUnverifiedCount > 0 %}
                        <a href="{{ path('dashboard_domains', { status: 'unverified' }) }}" class="inline-flex items-center gap-1 hover:underline">
                            <span class="w-2 h-2 rounded-full bg-error"></span>
                            {{ healthSummary.domainsUnverifiedCount }} unverified
                        </a>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>

    {# Setup checklist — persistent, dismissible per-team. Re-surfaces on DMARC regression. #}
    {% if setupChecklist.isVisible %}
        <div class="card bg-base-100 border border-base-200 shadow-sm mb-6">
            <div class="card-body p-5">
                <div class="flex items-start justify-between gap-3 mb-4">
                    <div>
                        <div class="text-xs font-semibold uppercase tracking-wider text-base-content/50 mb-1">Setup checklist</div>
                        <h2 class="text-lg font-semibold text-base-content">Finish setting up Sendvery</h2>
                        <p class="text-sm text-base-content/60 mt-1">{{ setupChecklist.completedCount }} of {{ setupChecklist.totalCount }} steps complete</p>
                    </div>
                    <form method="post" action="{{ path('dashboard_setup_checklist_dismiss') }}" class="shrink-0">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('setup_checklist_dismiss') }}">
                        <button type="submit" class="btn btn-ghost btn-sm">Hide checklist</button>
                    </form>
                </div>
                <ul class="space-y-3">
                    {% for step in setupChecklist.steps %}
                        <li class="flex items-start gap-3">
                            {% if step.isComplete %}
                                <span class="w-6 h-6 rounded-full bg-success/15 text-success flex items-center justify-center shrink-0 mt-0.5" aria-label="Complete">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                                    </svg>
                                </span>
                                <div class="flex-1 min-w-0 opacity-60">
                                    <div class="font-medium text-sm line-through">{{ step.title }}</div>
                                </div>
                            {% else %}
                                <span class="w-6 h-6 rounded-full border-2 border-base-content/30 shrink-0 mt-0.5" aria-label="Incomplete"></span>
                                <div class="flex-1 min-w-0">
                                    <div class="font-medium text-sm text-base-content">{{ step.title }}</div>
                                    <p class="text-sm text-base-content/60 mt-0.5">{{ step.description }}</p>
                                    <a href="{{ path(step.actionRoute, step.actionRouteParams) }}" class="btn btn-sm btn-outline btn-primary mt-2">{{ step.actionLabel }} &rarr;</a>
                                </div>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    {% endif %}

    {# Next Action card — single highest-value step picked by NextActionResolver. #}
    {% set actionTone = {
        success: {border: 'border-success/30', badge: 'bg-success/10 text-success', btn: 'btn-success'},
        warning: {border: 'border-warning/30', badge: 'bg-warning/10 text-warning', btn: 'btn-warning'},
        error:   {border: 'border-error/30', badge: 'bg-error/10 text-error', btn: 'btn-error'},
        info:    {border: 'border-info/30', badge: 'bg-info/10 text-info', btn: 'btn-info btn-outline'},
    }[nextAction.severity] %}
    <div class="card bg-base-100 border {{ actionTone.border }} shadow-sm mb-6">
        <div class="card-body p-5 flex flex-row items-start gap-4">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0 {{ actionTone.badge }}">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    {% if nextAction.actionKey.value == 'add_domain' %}
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                    {% elseif nextAction.actionKey.value == 'verify_dns' %}
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                    {% elseif nextAction.actionKey.value == 'wait_for_reports' %}
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    {% elseif nextAction.actionKey.value == 'review_alerts' %}
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                    {% elseif nextAction.actionKey.value == 'connect_mailbox' %}
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    {% elseif nextAction.actionKey.value == 'publish_rua_record' %}
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                    {% else %}
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    {% endif %}
                </svg>
            </div>
            <div class="flex-1 min-w-0">
                <div class="text-xs font-semibold uppercase tracking-wider text-base-content/50 mb-1">Next step</div>
                <h2 class="text-lg font-semibold text-base-content mb-1">{{ nextAction.title }}</h2>
                <p class="text-sm text-base-content/70 mb-3">{{ nextAction.description }}</p>
                <a href="{{ path(nextAction.ctaRoute, nextAction.ctaRouteParams) }}" class="btn btn-sm {{ actionTone.btn }}">
                    {{ nextAction.ctaLabel }}
                </a>
                {% if nextAction.secondaryCtaRoute is not null %}
                    <div class="mt-3 flex items-center gap-3 text-sm">
                        <a href="{{ path(nextAction.secondaryCtaRoute) }}" class="link link-hover text-base-content/70">
                            {{ nextAction.secondaryCtaLabel }}
                        </a>
                        <form method="post" action="{{ path('dashboard_ingestion_recommendation_dismiss') }}" class="inline">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('ingestion_recommendation_dismiss') }}">
                            <button type="submit" class="link link-hover text-base-content/50 text-xs">Dismiss</button>
                        </form>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    {% if not isEmptyState %}
    {% if verificationStatus is not null and verificationSeverity is not null and verificationSeverity.value != 'ok' %}
        {% set severityValue = verificationSeverity.value %}
        {% set tone = {
            critical: {bg: 'bg-error/5 border-error/30', dot: 'bg-error/15 text-error', btn: 'btn-error'},
            warning:  {bg: 'bg-warning/5 border-warning/30', dot: 'bg-warning/15 text-warning', btn: 'btn-warning'},
            info:     {bg: 'bg-info/5 border-info/30', dot: 'bg-info/15 text-info', btn: 'btn-info btn-outline'},
        }[severityValue] %}
        <div class="rounded-2xl border p-5 mb-6 {{ tone.bg }}">
            <div class="flex items-start gap-3">
                <div class="w-9 h-9 rounded-full flex items-center justify-center shrink-0 {{ tone.dot }}">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        {% if severityValue == 'info' %}
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        {% else %}
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M5.07 19h13.86c1.54 0 2.5-1.67 1.73-2.5L13.73 4a2 2 0 00-3.46 0L3.34 16.5c-.77.83.19 2.5 1.73 2.5z"/>
                        {% endif %}
                    </svg>
                </div>
                <div class="flex-1">
                    {% if verificationStatus.dmarcVerifiedAt is null %}
                        {% if quarantineCount > 0 %}
                            <div class="font-semibold text-base-content mb-1">
                                {{ quarantineCount }} DMARC report{{ quarantineCount > 1 ? 's' : '' }} already waiting for {{ verificationStatus.domainName }}
                            </div>
                            <p class="text-sm text-base-content/70">
                                Email receivers are already sending reports to <span class="font-mono">{{ reportAddress }}</span> — they're parked safely until you finish DNS verification. Publish your DMARC TXT record (and re-check below) to unlock them.
                            </p>
                        {% else %}
                            <div class="font-semibold text-base-content mb-1">DMARC record not detected for {{ verificationStatus.domainName }}</div>
                            <p class="text-sm text-base-content/70">Publish a DMARC TXT record so reports can be delivered. We re-check every day; you can also re-check now.</p>
                        {% endif %}
                    {% elseif severityValue == 'info' %}
                        <div class="font-semibold text-base-content mb-1">Confirming DMARC record for {{ verificationStatus.domainName }}</div>
                        <p class="text-sm text-base-content/70">The latest check didn't see your DMARC record — most likely DNS is still propagating, or a resolver hiccup. We'll keep checking; nothing to worry about yet.</p>
                    {% elseif verificationStatus.consecutiveDmarcFailures > 0 %}
                        <div class="font-semibold text-base-content mb-1">DMARC record went missing for {{ verificationStatus.domainName }}</div>
                        <p class="text-sm text-base-content/70">We saw it before, but the last {{ verificationStatus.consecutiveDmarcFailures }} checks couldn't find it. Reports will stop arriving until it's republished.</p>
                    {% else %}
                        <div class="font-semibold text-base-content mb-1">No DMARC reports yet for {{ verificationStatus.domainName }}</div>
                        <p class="text-sm text-base-content/70">DMARC is published but no reports have arrived after 48 hours. Verify that <code class="kbd kbd-xs">rua</code> points at <span class="font-mono">{{ reportAddress }}</span>.</p>
                    {% endif %}
                </div>
                <form method="post" action="{{ path('dashboard_domain_reverify', {id: verificationStatus.domainId}) }}" class="shrink-0">
                    <button type="submit" class="btn btn-sm {{ tone.btn }}">Re-check now</button>
                </form>
            </div>
        </div>
    {% endif %}

    {# Stat cards — grow to 6 columns when the optional Reports-this-month
       card is visible (team on a finite-limit plan with >=50% usage). #}
    <div class="grid grid-cols-1 sm:grid-cols-2 {{ showReportUsageCard ? 'lg:grid-cols-6' : 'lg:grid-cols-5' }} gap-4 mb-6">
        <a href="{{ path('dashboard_domains') }}" class="block">
            <twig:StatCard
                title="Monitored Domains"
                value="{{ stats.totalDomains }}"
                variant="default"
                icon='<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>'
            />
        </a>
        <a href="{{ path('dashboard_reports') }}" class="block">
            <twig:StatCard
                title="Reports (30 days)"
                value="{{ stats.totalReportsLast30Days }}"
                variant="default"
                icon='<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>'
            />
        </a>
        {# pass_rate=low — actionable subset, live from ReportsFilter (TASK-016). #}
        <a href="{{ path('dashboard_reports', { pass_rate: 'low' }) }}" class="block">
            <twig:StatCard
                title="DMARC Pass Rate"
                value="{{ stats.overallPassRate|number_format(1) }}%"
                variant="{{ stats.overallPassRate >= 90 ? 'success' : (stats.overallPassRate >= 70 ? 'warning' : 'error') }}"
                icon='<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>'
            />
        </a>
        {# Total Messages is intentionally unlinked — sum of dmarc_record.count rows aggregated across reports; no per-message drill-down view exists. Revisit if one's added. #}
        <twig:StatCard
            title="Total Messages"
            value="{{ stats.totalMessages|number_format(0, '.', ',') }}"
            variant="default"
            icon='<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>'
        />
        <a href="{{ path('dashboard_alerts') }}" class="block">
            <twig:StatCard
                title="Unread Alerts"
                value="{{ unreadAlertCount }}"
                variant="{{ unreadAlertCount > 0 ? 'warning' : 'default' }}"
                icon='<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>'
            />
        </a>
        {% if showReportUsageCard %}
            <a href="{{ path('dashboard_billing') }}" class="block">
                <twig:StatCard
                    title="Reports this month"
                    value="{{ overviewReportUsage.currentCount|number_format(0, '.', ',') }} / {{ overviewReportUsage.limit|number_format(0, '.', ',') }} ({{ overviewReportUsage.percentageUsed|number_format(0) }}%)"
                    variant="{{ overviewReportUsage.percentageUsed >= 90 ? 'error' : (overviewReportUsage.percentageUsed >= 70 ? 'warning' : 'default') }}"
                    icon='<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>'
                />
            </a>
        {% endif %}
    </div>

    {# Trend chart #}
    <div class="mb-6">
        <twig:ChartCard
            title="DMARC Pass/Fail Trend"
            description="Last 30 days"
            :config="trendChartConfig"
        />
    </div>

    {# Recent critical alerts #}
    {% if recentAlerts is not empty %}
        <div class="card bg-base-100 border border-base-200 shadow-sm mb-6">
            <div class="card-body p-4">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-sm font-semibold">Recent Critical Alerts</h3>
                    <a href="{{ path('dashboard_alerts') }}" class="text-xs text-primary hover:underline">View all</a>
                </div>
                <div class="space-y-2">
                    {% for alert in recentAlerts %}
                        <a href="{{ path('dashboard_alert_detail', { id: alert.alertId }) }}"
                           class="flex items-center gap-3 p-2 rounded-btn hover:bg-base-200/50 transition-colors">
                            <div class="w-6 h-6 rounded-full bg-error/10 flex items-center justify-center flex-shrink-0">
                                <svg class="w-3 h-3 text-error" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"></path></svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium truncate">{{ alert.title }}</p>
                                <p class="text-xs text-base-content/50">{{ alert.createdAt|date('M j, H:i') }}</p>
                            </div>
                            {% if not alert.isRead %}
                                <span class="badge badge-xs badge-primary">New</span>
                            {% endif %}
                        </a>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {# Recent reports — TASK-040: in-card date-range dropdown + failing-only chip. #}
        <div class="card bg-base-100 border border-base-200 shadow-sm">
            <div class="card-body p-4">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-sm font-semibold">Recent Reports</h3>
                    <div class="flex items-center gap-3">
                        {% set rangeLabels = { '7d': 'Last 7 days', '30d': 'Last 30 days', '90d': 'Last 90 days' } %}
                        <details class="dropdown dropdown-end">
                            <summary class="btn btn-ghost btn-xs gap-1" aria-label="Change date range">
                                {{ rangeLabels[recentReportsRange] }}
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                            </summary>
                            <ul class="dropdown-content menu bg-base-100 rounded-box border border-base-200 shadow-lg z-50 w-48 p-1 mt-1">
                                {% for value, label in rangeLabels %}
                                    {% set rangeParams = { recent_reports_range: value } %}
                                    {% if recentReportsFailing %}{% set rangeParams = rangeParams|merge({ recent_reports_failing: 1 }) %}{% endif %}
                                    {% if domainHealthSort.value != 'worst' %}{% set rangeParams = rangeParams|merge({ domain_health_sort: domainHealthSort.value }) %}{% endif %}
                                    <li>
                                        <a href="{{ path('dashboard_overview', rangeParams) }}"
                                           class="{{ value == recentReportsRange ? 'menu-active' : '' }}">{{ label }}</a>
                                    </li>
                                {% endfor %}
                            </ul>
                        </details>
                        <a href="{{ path('dashboard_reports') }}" class="text-xs text-primary hover:underline">View all</a>
                    </div>
                </div>

                {% if recentReports is empty %}
                    <p class="text-sm text-base-content/50 py-4 text-center">No reports in this window.</p>
                {% else %}
                    <div class="overflow-x-auto">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Domain</th>
                                    <th>Reporter</th>
                                    <th>Date</th>
                                    <th class="text-right">Pass Rate</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for report in recentReports %}
                                    <tr class="hover:bg-base-200/50 cursor-pointer relative">
                                        <td class="font-medium">
                                            <a href="{{ path('dashboard_report_detail', { id: report.reportId }) }}"
                                               class="absolute inset-0 z-10"
                                               aria-label="View report from {{ report.reporterOrg }} for {{ report.domainName }}"></a>
                                            {{ report.domainName }}
                                        </td>
                                        <td>{{ report.reporterOrg }}</td>
                                        <td>{{ report.dateRangeEnd|date('M j') }}</td>
                                        <td class="text-right">
                                            <span class="{{ report.passRate >= 90 ? 'text-success' : (report.passRate >= 70 ? 'text-warning' : 'text-error') }}">
                                                {{ report.passRate|number_format(1) }}%
                                            </span>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}

                {# Failing-only chip — sits below the table so it's an *escape* from
                   the broad view, not a filter someone scans past on the way in. #}
                <div class="mt-3 pt-3 border-t border-base-200">
                    {% set failingParams = { recent_reports_range: recentReportsRange } %}
                    {% if not recentReportsFailing %}{% set failingParams = failingParams|merge({ recent_reports_failing: 1 }) %}{% endif %}
                    {% if domainHealthSort.value != 'worst' %}{% set failingParams = failingParams|merge({ domain_health_sort: domainHealthSort.value }) %}{% endif %}
                    <a href="{{ path('dashboard_overview', failingParams) }}"
                       class="btn btn-xs gap-1 {{ recentReportsFailing ? 'btn-warning' : 'btn-ghost' }}">
                        {% if recentReportsFailing %}
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                            Showing failing only — clear
                        {% else %}
                            Show only failing (&lt; 70% pass)
                        {% endif %}
                    </a>
                </div>
            </div>
        </div>

        {# Domain health — TASK-040: in-card sort toggle + per-row 30-day sparkline. #}
        <div class="card bg-base-100 border border-base-200 shadow-sm">
            <div class="card-body p-4">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-sm font-semibold">Domain Health</h3>
                    <div class="flex items-center gap-3">
                        {% set sortLabels = { 'worst': 'Worst first', 'best': 'Best first', 'most': 'Most reports' } %}
                        <details class="dropdown dropdown-end">
                            <summary class="btn btn-ghost btn-xs gap-1" aria-label="Change sort order">
                                {{ sortLabels[domainHealthSort.value] }}
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                            </summary>
                            <ul class="dropdown-content menu bg-base-100 rounded-box border border-base-200 shadow-lg z-50 w-48 p-1 mt-1">
                                {% for value, label in sortLabels %}
                                    {% set sortParams = {} %}
                                    {% if value != 'worst' %}{% set sortParams = sortParams|merge({ domain_health_sort: value }) %}{% endif %}
                                    {% if recentReportsRange != '7d' %}{% set sortParams = sortParams|merge({ recent_reports_range: recentReportsRange }) %}{% endif %}
                                    {% if recentReportsFailing %}{% set sortParams = sortParams|merge({ recent_reports_failing: 1 }) %}{% endif %}
                                    <li>
                                        <a href="{{ path('dashboard_overview', sortParams) }}"
                                           class="{{ value == domainHealthSort.value ? 'menu-active' : '' }}">{{ label }}</a>
                                    </li>
                                {% endfor %}
                            </ul>
                        </details>
                        <a href="{{ path('dashboard_domains') }}" class="text-xs text-primary hover:underline">View all</a>
                    </div>
                </div>

                {% if domains is empty %}
                    <twig:EmptyState
                        title="No domains"
                        message="Add your first domain to start monitoring DMARC reports."
                        actionUrl="{{ path('dashboard_domain_add') }}"
                        actionLabel="Add domain"
                    />
                {% else %}
                    <div class="space-y-3">
                        {% for domain in domains[:5] %}
                            {% set passRateTone = domain.passRate >= 90 ? 'text-success' : (domain.passRate >= 70 ? 'text-warning' : 'text-error') %}
                            <a href="{{ path('dashboard_domain_detail', { id: domain.domainId }) }}"
                               class="flex items-center justify-between p-3 rounded-btn hover:bg-base-200/50 transition-colors gap-3">
                                <div class="min-w-0 flex-1">
                                    <span class="font-medium text-sm">{{ domain.domainName }}</span>
                                    <span class="text-xs text-base-content/50 ml-2">{{ domain.totalReports }} reports</span>
                                </div>
                                <div class="flex items-center gap-3 shrink-0">
                                    <span class="{{ passRateTone }}" aria-label="30-day pass-rate trend">
                                        <twig:DomainPassRateSparkline :points="domainPassRateTrends[domain.domainId]|default([])"/>
                                    </span>
                                    <span class="text-sm font-semibold {{ passRateTone }}">
                                        {{ domain.passRate|number_format(1) }}%
                                    </span>
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
    {% endif %}
{% endblock %}
