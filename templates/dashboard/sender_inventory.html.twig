{% extends 'dashboard/layout.html.twig' %}

{% block page_title %}Senders — {{ domain.domainName }}{% endblock %}
{% block breadcrumbs %}
    <li><a href="{{ path('dashboard_domains') }}">Domains</a></li>
    <li><a href="{{ path('dashboard_domain_detail', { id: domain.domainId }) }}">{{ domain.domainName }}</a></li>
    <li>Senders</li>
{% endblock %}

{% block page_heading %}
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
        <div>
            <h1 class="text-2xl font-bold">Sender Inventory</h1>
            <p class="text-sm text-base-content/60 mt-1">All services and IPs sending email as {{ domain.domainName }}</p>
        </div>
    </div>
{% endblock %}

{% block content %}
    <twig:DomainWorkspaceTabs :domain="domain" active="senders" :tabCounts="tabCounts" />

    {# TASK-092 "X senders need a decision" stat row — only renders when at
       least one row has a recommend_authorize or recommend_revoke verdict.
       Links to ?recommendation=needs_decision to narrow the table. #}
    {% if needsDecisionCount is defined and needsDecisionCount > 0 %}
        <a href="{{ path('dashboard_sender_inventory', { domainId: domain.domainId, recommendation: 'needs_decision' }) }}"
           class="card border border-warning/30 bg-warning/5 shadow-sm mb-4 block hover:bg-warning/10 transition-colors"
           data-testid="sender-needs-decision-stat">
            <div class="card-body p-4 flex flex-row items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-warning/10 flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-warning" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="font-semibold text-sm sm:text-base">
                        {{ needsDecisionCount }} sender{{ needsDecisionCount == 1 ? '' : 's' }} need{{ needsDecisionCount == 1 ? 's' : '' }} a decision
                    </div>
                    <div class="text-xs sm:text-sm text-base-content/60">
                        Each one has crossed the threshold for an authorize or revoke recommendation. Click to filter the table.
                    </div>
                </div>
                <svg class="w-5 h-5 text-base-content/40 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </div>
        </a>
    {% endif %}

    {# Filter tabs #}
    <div class="tabs tabs-bordered mb-6">
        <a href="{{ path('dashboard_sender_inventory', { domainId: domain.domainId }) }}"
           class="tab {{ filter == '' or filter is null ? 'tab-active' : '' }}">All</a>
        <a href="{{ path('dashboard_sender_inventory', { domainId: domain.domainId, filter: 'authorized' }) }}"
           class="tab {{ filter == 'authorized' ? 'tab-active' : '' }}">Authorized</a>
        <a href="{{ path('dashboard_sender_inventory', { domainId: domain.domainId, filter: 'unauthorized' }) }}"
           class="tab {{ filter == 'unauthorized' ? 'tab-active' : '' }}">Unauthorized</a>
        {% if recommendationFilter is defined and recommendationFilter == 'needs_decision' %}
            <span class="tab tab-active flex items-center gap-1" data-testid="sender-needs-decision-active-tab">
                Needs decision
                <a href="{{ path('dashboard_sender_inventory', { domainId: domain.domainId }) }}" class="text-base-content/60 hover:text-base-content" aria-label="Clear filter">×</a>
            </span>
        {% endif %}
    </div>

    {% if senders is empty %}
        <div class="card bg-base-100 shadow">
            <div class="card-body text-center py-12">
                <p class="text-base-content/60">No senders discovered yet. Senders will appear here after DMARC reports are processed.</p>
            </div>
        </div>
    {% else %}
        {# Bulk-action form wrapping the table. The Stimulus controller toggles
           the toolbar visibility based on per-row checkbox state. Per-row
           Authorize/Revoke buttons use the HTML5 form= attribute to target
           hidden forms rendered AFTER this form (HTML disallows nested forms). #}
        <form id="bulk-sender-form"
              method="post"
              action="{{ path('dashboard_sender_bulk', { domainId: domain.domainId }) }}"
              {{ stimulus_controller('sender-selection') }}>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('bulk_sender_action') }}">

            {# Sticky bulk toolbar — hidden by default, revealed when ≥1 row checked. #}
            <div data-sender-selection-target="toolbar"
                 class="hidden sticky top-0 z-20 flex flex-wrap items-center gap-2 bg-base-100 border border-base-200 rounded-box shadow-sm px-3 py-2 mb-3">
                <span class="text-sm font-medium" data-sender-selection-target="count">0 selected</span>
                <div class="divider divider-horizontal mx-0"></div>
                <button type="submit" name="action" value="authorize" class="btn btn-sm btn-primary">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Authorize selected
                </button>
                <button type="submit" name="action" value="mark_unknown" class="btn btn-sm btn-ghost">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728L5.636 5.636m12.728 12.728L18.364 5.636M5.636 18.364l12.728-12.728"></path></svg>
                    Mark unknown selected
                </button>
                <button type="button" class="btn btn-sm btn-ghost ml-auto" data-action="sender-selection#clearAll">Clear</button>
            </div>

            <div class="card bg-base-100 shadow overflow-x-auto">
                <table class="table table-zebra">
                    <thead>
                        <tr>
                            <th class="w-8">
                                <span class="sr-only">Select</span>
                            </th>
                            <th>IP Address</th>
                            <th>Hostname</th>
                            <th>Organization</th>
                            <th>Messages</th>
                            <th>Pass Rate</th>
                            <th>First Seen</th>
                            <th>Last Seen</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for sender in senders %}
                            <tr id="sender-{{ sender.id }}">
                                <td>
                                    <input type="checkbox"
                                           name="senderIds[]"
                                           value="{{ sender.id }}"
                                           class="checkbox checkbox-sm"
                                           data-action="change->sender-selection#updateCount"
                                           aria-label="Select sender {{ sender.sourceIp }}">
                                </td>
                                <td class="font-mono text-sm">{{ sender.sourceIp }}</td>
                                <td class="text-sm">{{ sender.hostname ?? '-' }}</td>
                                <td>
                                    {% if sender.organization %}
                                        <span class="badge badge-sm badge-ghost">{{ sender.organization }}</span>
                                    {% else %}
                                        <span class="text-base-content/40">Unknown</span>
                                    {% endif %}
                                </td>
                                <td>{{ sender.totalMessages|number_format(0, '.', ',') }}</td>
                                <td>
                                    <span class="{{ sender.passRate >= 90 ? 'text-success' : (sender.passRate >= 70 ? 'text-warning' : 'text-error') }}">
                                        {{ sender.passRate|number_format(1) }}%
                                    </span>
                                </td>
                                <td class="text-sm text-base-content/60">{{ sender.firstSeenAt|date('M j, Y') }}</td>
                                <td class="text-sm text-base-content/60">{{ sender.lastSeenAt|date('M j, Y') }}</td>
                                <td>
                                    {% if sender.isAuthorized %}
                                        <span class="badge badge-sm badge-success">Authorized</span>
                                    {% else %}
                                        <span class="badge badge-sm badge-warning">Unknown</span>
                                    {% endif %}
                                    {% if sender.updatedAt %}
                                        <div class="text-xs text-base-content/50 mt-1">
                                            Last changed by {{ sender.updatedByUserEmail ?? 'system' }} on {{ sender.updatedAt|date('M j, Y') }}
                                        </div>
                                    {% endif %}
                                    {% if sender.notes %}
                                        <div class="text-xs text-base-content/70 mt-1 italic max-w-xs">
                                            <span class="font-semibold not-italic">Note:</span> {{ sender.notes|length > 120 ? sender.notes|slice(0, 120) ~ '…' : sender.notes }}
                                        </div>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="flex items-center gap-1">
                                        {% if sender.isAuthorized %}
                                            <button type="submit"
                                                    form="revoke-form-{{ sender.id }}"
                                                    class="btn btn-ghost btn-xs">Revoke</button>
                                        {% else %}
                                            <button type="submit"
                                                    form="authorize-form-{{ sender.id }}"
                                                    class="btn btn-primary btn-xs">Authorize</button>
                                        {% endif %}
                                        <button type="button"
                                                class="btn btn-ghost btn-xs"
                                                onclick="document.getElementById('note-dialog-{{ sender.id }}').showModal()"
                                                aria-label="Edit note">
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                            Note
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            {# TASK-092 inline recommendation callout. The
                               SenderActionCallout component renders nothing for
                               monitor/none — this guard keeps the empty extra
                               <tr> out of the DOM when the row is healthy. #}
                            {% if advisorBySenderId is defined and advisorBySenderId[sender.id] is defined and advisorBySenderId[sender.id].severity.value in ['recommend_authorize', 'recommend_revoke'] %}
                                <tr class="bg-transparent" data-testid="sender-callout-row-{{ sender.id }}">
                                    <td colspan="10" class="p-0 pb-3">
                                        <twig:SenderActionCallout :advice="advisorBySenderId[sender.id]" domainId="{{ domain.domainId }}" />
                                    </td>
                                </tr>
                            {% endif %}
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </form>

        {# Per-row hidden forms + note dialogs rendered OUTSIDE the bulk form
           to keep the HTML well-formed (no nested <form> tags). The visible
           buttons inside the table reference these via form="…" attribute. #}
        {% for sender in senders %}
            <form id="authorize-form-{{ sender.id }}"
                  method="post"
                  action="{{ path('dashboard_sender_authorize', { domainId: domain.domainId, senderId: sender.id }) }}"
                  class="hidden"
                  {{ stimulus_controller('sender-authorize-confirm') }}
                  data-action="submit->sender-authorize-confirm#confirmIfNeeded">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('sender_action') }}">
            </form>
            <form id="revoke-form-{{ sender.id }}"
                  method="post"
                  action="{{ path('dashboard_sender_revoke', { domainId: domain.domainId, senderId: sender.id }) }}"
                  class="hidden">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('sender_action') }}">
            </form>

            <dialog id="note-dialog-{{ sender.id }}" class="modal">
                <div class="modal-box">
                    <h3 class="font-bold text-lg">Note for {{ sender.sourceIp }}</h3>
                    <p class="text-sm text-base-content/60 mb-3">
                        Useful context — who runs this IP, when DKIM was set up, why it's authorized, etc.
                    </p>
                    <form method="post"
                          action="{{ path('dashboard_sender_note', { domainId: domain.domainId, senderId: sender.id }) }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('sender_note') }}">
                        <textarea name="note"
                                  class="textarea textarea-bordered w-full"
                                  rows="5"
                                  maxlength="10000"
                                  placeholder="e.g. Mailchimp marketing IP — Jane set up DKIM on 2026-04-12.">{{ sender.notes }}</textarea>
                        <div class="modal-action">
                            <button type="button" class="btn btn-ghost" onclick="document.getElementById('note-dialog-{{ sender.id }}').close()">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save note</button>
                        </div>
                    </form>
                </div>
                <form method="dialog" class="modal-backdrop">
                    <button>close</button>
                </form>
            </dialog>
        {% endfor %}
    {% endif %}
{% endblock %}
