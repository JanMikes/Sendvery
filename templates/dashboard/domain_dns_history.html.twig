{% extends 'dashboard/layout.html.twig' %}

{% import 'components/_dns_record_diff.html.twig' as record_diff %}

{% block page_title %}DNS History — {{ domain.domainName }}{% endblock %}

{% block breadcrumbs %}
    <li><a href="{{ path('dashboard_domains') }}">Domains</a></li>
    <li><a href="{{ path('dashboard_domain_detail', { id: domain.domainId }) }}">{{ domain.domainName }}</a></li>
    <li>DNS History</li>
{% endblock %}

{% block page_heading %}
    <div class="mb-6">
        <h1 class="text-2xl font-bold">DNS History</h1>
        <p class="text-sm text-base-content/60 mt-1 max-w-2xl">
            Every DNS check we've run for {{ domain.domainName }}. We re-check SPF, DKIM, DMARC and MX once a day — and any time you click "Re-check now". Rows highlighted in yellow show a change from the previous check.
        </p>
    </div>
{% endblock %}

{% block content %}
    <twig:DomainWorkspaceTabs :domain="domain" active="history" :tabCounts="tabCounts" />

    {% if ruaInstruction is defined and ruaInstruction is not null and not ruaInstruction.alreadyConfigured %}
        <div class="mb-6">
            <twig:DnsRecordInstruction
                recordType="TXT"
                host="_dmarc.{{ domain.domainName }}"
                whatText="Send DMARC reports to Sendvery"
                whyText="Without this, mail providers (Gmail, Outlook…) send DMARC reports somewhere else — or nowhere — and we can't show you who's sending mail as your domain."
                currentValue="{{ ruaInstruction.currentRecord }}"
                finalValue="{{ ruaInstruction.finalRecord }}"
                :alreadyConfigured="false"
            />
        </div>
    {% endif %}

    {% if hasAnyHistory %}
        {# Filter chip groups. Each chip carries the other active filters
           forward so the user never silently loses scope by clicking. #}
        {% set baseParams = { id: domain.domainId } %}
        {% set typeParams = baseParams|merge({ range: rangeDays, changes_only: changesOnly ? 1 : null }) %}
        {% set rangeParams = baseParams|merge({ type: activeType ? activeType.value : null, changes_only: changesOnly ? 1 : null }) %}
        {% set changesParams = baseParams|merge({ type: activeType ? activeType.value : null, range: rangeDays }) %}

        <div class="card bg-base-100 border border-base-200 shadow-sm mb-6">
            <div class="card-body p-4 gap-4">
                <div>
                    <p class="text-xs uppercase tracking-wide text-base-content/50 mb-2">Record type</p>
                    <div class="flex flex-wrap gap-2">
                        <a href="{{ path('dashboard_domain_dns_history', typeParams) }}"
                           data-turbo-action="advance"
                           class="btn btn-sm {{ activeType is null ? 'btn-primary' : 'btn-ghost' }}">
                            All
                        </a>
                        <a href="{{ path('dashboard_domain_dns_history', typeParams|merge({ type: 'spf' })) }}"
                           data-turbo-action="advance"
                           class="btn btn-sm {{ activeType is not null and activeType.value == 'spf' ? 'btn-primary' : 'btn-ghost' }}">
                            SPF
                        </a>
                        <a href="{{ path('dashboard_domain_dns_history', typeParams|merge({ type: 'dkim' })) }}"
                           data-turbo-action="advance"
                           class="btn btn-sm {{ activeType is not null and activeType.value == 'dkim' ? 'btn-primary' : 'btn-ghost' }}">
                            DKIM
                        </a>
                        <a href="{{ path('dashboard_domain_dns_history', typeParams|merge({ type: 'dmarc' })) }}"
                           data-turbo-action="advance"
                           class="btn btn-sm {{ activeType is not null and activeType.value == 'dmarc' ? 'btn-primary' : 'btn-ghost' }}">
                            DMARC
                        </a>
                        <a href="{{ path('dashboard_domain_dns_history', typeParams|merge({ type: 'mx' })) }}"
                           data-turbo-action="advance"
                           class="btn btn-sm {{ activeType is not null and activeType.value == 'mx' ? 'btn-primary' : 'btn-ghost' }}">
                            MX
                        </a>
                    </div>
                </div>

                <div>
                    <p class="text-xs uppercase tracking-wide text-base-content/50 mb-2">Date range</p>
                    <div class="flex flex-wrap gap-2">
                        <a href="{{ path('dashboard_domain_dns_history', rangeParams|merge({ range: 7 })) }}"
                           data-turbo-action="advance"
                           class="btn btn-sm {{ rangeDays == 7 ? 'btn-primary' : 'btn-ghost' }}">
                            Last 7 days
                        </a>
                        <a href="{{ path('dashboard_domain_dns_history', rangeParams|merge({ range: 30 })) }}"
                           data-turbo-action="advance"
                           class="btn btn-sm {{ rangeDays == 30 ? 'btn-primary' : 'btn-ghost' }}">
                            Last 30 days
                        </a>
                        <a href="{{ path('dashboard_domain_dns_history', rangeParams|merge({ range: 90 })) }}"
                           data-turbo-action="advance"
                           class="btn btn-sm {{ rangeDays == 90 ? 'btn-primary' : 'btn-ghost' }}">
                            Last 90 days
                        </a>
                        <a href="{{ path('dashboard_domain_dns_history', rangeParams|merge({ range: 0 })) }}"
                           data-turbo-action="advance"
                           class="btn btn-sm {{ rangeDays == 0 ? 'btn-primary' : 'btn-ghost' }}">
                            All time
                        </a>
                    </div>
                </div>

                <div>
                    <p class="text-xs uppercase tracking-wide text-base-content/50 mb-2">Quick filter</p>
                    <a href="{{ path('dashboard_domain_dns_history', changesParams|merge({ changes_only: changesOnly ? null : 1 })) }}"
                       data-turbo-action="advance"
                       class="btn btn-sm {{ changesOnly ? 'btn-warning' : 'btn-ghost' }}">
                        Show only changes ({{ changesOnlyCount }})
                    </a>
                </div>
            </div>
        </div>

        {% if groupedHistory is empty %}
            <div class="card bg-base-100 border border-base-200 shadow-sm">
                <div class="card-body items-center text-center py-10">
                    <h3 class="text-lg font-semibold mb-1">No DNS checks match the current filter</h3>
                    <p class="text-sm text-base-content/60 mb-4 max-w-md">
                        Try widening the date range, switching record types, or turning off the changes-only filter.
                    </p>
                    <a href="{{ path('dashboard_domain_dns_history', { id: domain.domainId }) }}"
                       data-turbo-action="advance"
                       class="btn btn-primary btn-sm">
                        Clear filters
                    </a>
                </div>
            </div>
        {% else %}
            <div class="space-y-3">
                {% for date, group in groupedHistory %}
                    <details class="card bg-base-100 border border-base-200 shadow-sm" {{ date in openDays ? 'open' : '' }}>
                        <summary class="flex items-center justify-between gap-2 flex-wrap cursor-pointer py-3 px-4 hover:bg-base-200 list-none">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span class="font-semibold">{{ date|date('l, F j, Y') }}</span>
                                <span class="text-sm text-base-content/60">{{ group.checks|length }} check{{ group.checks|length == 1 ? '' : 's' }}</span>
                                {% if group.changeCount > 0 %}
                                    <span class="badge badge-sm badge-warning">{{ group.changeCount }} change{{ group.changeCount == 1 ? '' : 's' }}</span>
                                {% endif %}
                            </div>
                        </summary>

                        <div class="px-4 pb-4 space-y-3">
                            {% for check in group.checks %}
                                {# A row is "really" changed only if a prior observation existed.
                                   The very first row per (domain, record_type) is a baseline, not a change.
                                   isRealChange() is the single source of truth (DnsCheckHistoryResult). #}
                                {% set isRealChange = check.isRealChange %}
                                <div class="border border-base-200 rounded-box p-3 {{ isRealChange ? 'bg-warning/5 border-l-4 border-l-warning' : 'bg-base-100' }}">
                                    <div class="flex items-center justify-between mb-2 flex-wrap gap-2">
                                        <div class="flex items-center gap-2 flex-wrap">
                                            {# TASK-126: record-type labels use a single non-semantic tone with a
                                               protocol icon prefix, so they don't compete with the validity badge. #}
                                            <span class="badge badge-sm badge-neutral badge-outline gap-1">
                                                {% if check.type == 'spf' %}
                                                    {# shield #}
                                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2l8 4v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6l8-4z" /></svg>
                                                {% elseif check.type == 'dkim' %}
                                                    {# key #}
                                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a4 4 0 11-3.84 5H7l-2 2v3h3v-2h2v-2h2.16A4 4 0 0115 7z" /></svg>
                                                {% elseif check.type == 'dmarc' %}
                                                    {# clipboard-check #}
                                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5h6a1 1 0 011 1v1H8V6a1 1 0 011-1z" /><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h10v12a1 1 0 01-1 1H8a1 1 0 01-1-1V7z" /><path stroke-linecap="round" stroke-linejoin="round" d="M9.5 13l2 2 3.5-4" /></svg>
                                                {% else %}
                                                    {# envelope (MX) #}
                                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16v12H4z" /><path stroke-linecap="round" stroke-linejoin="round" d="M4 6l8 7 8-7" /></svg>
                                                {% endif %}
                                                {{ check.type|upper }}
                                            </span>
                                            {% if check.isValid %}
                                                <span class="badge badge-sm badge-success badge-outline">Valid</span>
                                            {% else %}
                                                <span class="badge badge-sm badge-error badge-outline">Invalid</span>
                                            {% endif %}
                                            {# TASK-125: first observation per protocol is a baseline, not a change.
                                               INITIAL CHECK reads as informational (info tone), not as a warning. #}
                                            {% if check.isInitialCheck %}
                                                <span class="badge badge-sm badge-info badge-outline">Initial check</span>
                                            {% elseif check.hasChanged %}
                                                <span class="badge badge-sm badge-warning">Changed</span>
                                            {% endif %}
                                        </div>
                                        <span class="text-xs text-base-content/50">{{ check.checkedAt|date('H:i') }}</span>
                                    </div>

                                    {% if isRealChange and diffsById[check.id] is defined %}
                                        {# TASK-127: render inline token-level diff for CHANGED rows
                                           so the user reads "what flipped" at a glance instead of
                                           eyeballing two opaque before/after blobs. #}
                                        <div class="bg-base-200 rounded-btn px-3 py-2 mb-2">
                                            {{ record_diff.render(diffsById[check.id]) }}
                                        </div>
                                        {{ record_diff.expander(diffsById[check.id]) }}
                                    {% elseif check.rawRecord %}
                                        <div class="bg-base-200 rounded-btn px-3 py-2 mb-2">
                                            <code class="text-xs break-all">{{ check.rawRecord }}</code>
                                        </div>
                                    {% else %}
                                        <p class="text-sm text-base-content/50 italic mb-2">No record found</p>
                                    {% endif %}

                                    {% if check.issues is not empty %}
                                        <div class="mt-2 space-y-1">
                                            {% for issue in check.issues %}
                                                <div class="text-xs flex items-center gap-1">
                                                    {% if issue.severity == 'critical' %}
                                                        <span class="text-error">&#x2716;</span>
                                                    {% elseif issue.severity == 'warning' %}
                                                        <span class="text-warning">&#x26A0;</span>
                                                    {% else %}
                                                        <span class="text-info">&#x2139;</span>
                                                    {% endif %}
                                                    <span class="text-base-content/70">{{ issue.message }}</span>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    </details>
                {% endfor %}
            </div>
        {% endif %}
    {% else %}
        <twig:EmptyState
            title="No DNS checks yet"
            message="DNS checks run automatically once a day. Trigger one now to see results immediately."
        />
        <div class="flex justify-center -mt-4">
            <form method="post" action="{{ path('dashboard_domain_reverify', { id: domain.domainId }) }}">
                <button type="submit" class="btn btn-primary btn-sm">Re-check now</button>
            </form>
        </div>
    {% endif %}
{% endblock %}
