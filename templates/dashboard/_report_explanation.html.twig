<turbo-frame id="report-explanation">
    <div class="card bg-base-100 border border-base-200 shadow-sm mb-6">
        <div class="card-body p-4">
            <h3 class="text-sm font-semibold mb-2">AI explanation</h3>
            {% if explanation is defined %}
                <div class="text-sm whitespace-pre-line">{{ explanation }}</div>
                <p class="text-xs text-base-content/50 mt-3">Generated by Claude · {{ remaining }} of {{ limit }} AI explanations left this month.</p>
            {% elseif upgradePlan is defined %}
                <p class="text-sm">AI Insights isn't on your current plan.</p>
                <a href="{{ path('dashboard_billing_upgrade', { plan: upgradePlan }) }}" class="btn btn-primary btn-sm mt-2">Upgrade to add AI Insights</a>
            {% elseif quotaLimit is defined %}
                <p class="text-sm text-warning">You've used {{ quotaUsed }} of {{ quotaLimit }} AI explanations this month. Your quota resets on the 1st.</p>
            {% elseif unavailable is defined %}
                <p class="text-sm text-base-content/60">We couldn't analyze this report right now. Please try again in a moment.</p>
            {% endif %}
        </div>
    </div>
</turbo-frame>
