{% extends 'dashboard/layout.html.twig' %}

{% block page_title %}Add Domain{% endblock %}
{% block breadcrumbs %}
    <li><a href="{{ path('dashboard_domains') }}">Domains</a></li>
    <li>Add</li>
{% endblock %}

{% block content %}
    <div class="max-w-lg mx-auto">
        <div class="card bg-base-100 border border-base-200 shadow-sm">
            <div class="card-body p-6">
                <h2 class="text-lg font-semibold mb-2">Add a domain</h2>
                <div class="flex items-center gap-2 text-sm bg-base-200/60 rounded-lg px-3 py-2 mb-3">
                    <svg class="w-4 h-4 flex-shrink-0 text-base-content/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
                    <span class="text-base-content/70">
                        Adding to <span class="font-medium text-base-content">{{ targetTeam.name }}</span>
                    </span>
                </div>
                <p class="text-sm text-base-content/50 mb-6">
                    Enter the domain name you want to monitor for DMARC reports.
                </p>

                {% if errors is not empty %}
                    <div class="alert alert-error mb-4">
                        <ul class="text-sm">
                            {% for error in errors %}
                                <li>{{ error }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                {% if not canAddDomain %}
                    <div class="alert alert-warning mb-4">
                        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"></path></svg>
                        <div>
                            <p class="text-sm font-medium">Domain limit reached ({{ domainCount }}/{{ maxDomains }})</p>
                            <p class="text-sm mt-1">
                                {% if currentPlan.value == 'free' %}
                                    Personal plan ($5.99/mo, up to 5 domains) is in private beta — request access below.
                                {% elseif currentPlan.value == 'personal' %}
                                    Pro plan ($23.99/mo, up to 20 domains) is in private beta — request access below.
                                {% elseif currentPlan.value == 'pro' %}
                                    Business plan ($59.99/mo, up to 50 domains) is in private beta — request access below.
                                {% endif %}
                            </p>
                            {% set nextPlan = currentPlan.value == 'free' ? 'personal' : (currentPlan.value == 'personal' ? 'pro' : 'business') %}
                            <a href="{{ path('request_beta_access', {plan: nextPlan, source: 'dashboard-domain-add'}) }}" class="btn btn-sm btn-primary mt-2">Request beta access</a>
                        </div>
                    </div>
                {% endif %}

                <form method="POST" action="{{ path('dashboard_domain_add') }}">
                    <div class="form-control mb-4">
                        <label class="label" for="domain_name">
                            <span class="label-text">Domain name</span>
                        </label>
                        <input
                            type="text"
                            id="domain_name"
                            name="domain_name"
                            value="{{ data.domainName }}"
                            placeholder="example.com"
                            class="input input-bordered w-full"
                            required
                            autofocus
                            {% if not canAddDomain %}disabled{% endif %}
                        >
                    </div>

                    <div class="flex items-center justify-end gap-3">
                        <a href="{{ path('dashboard_domains') }}" class="btn btn-ghost btn-sm">Cancel</a>
                        <button type="submit" class="btn btn-primary btn-sm" {% if not canAddDomain %}disabled{% endif %}>Add domain</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
