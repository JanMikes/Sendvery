{% extends 'dashboard/layout.html.twig' %}

{% block page_title %}Reports{% endblock %}
{% block breadcrumbs %}<li>Reports</li>{% endblock %}

{% block page_heading %}
    <div class="mb-6">
        <h1 class="text-2xl font-bold">DMARC Reports</h1>
        <p class="text-sm text-base-content/60 mt-1 max-w-2xl">Every parsed DMARC report across your domains. Filter by date, domain, reporter, or pass-rate to find what you need.</p>
    </div>
{% endblock %}

{% block content %}
    {# TASK-093 — pass-rate regression / improvement banner. Renders nothing
       when the advisor returns Stable, so the table-only frame refresh path
       (no regressionResult variable) stays unchanged. #}
    {% if regressionResult is defined %}
        <twig:PassRateRegressionBanner :regression="regressionResult" />
    {% endif %}

    <twig:ReportsFilterBar
        filter="{{ filter }}"
        domains="{{ domains }}"
        reporterOptions="{{ reporterOptions }}"
        formAction="dashboard_reports"
    />

    {% if reports is empty and currentPage == 1 %}
        {% if filter.hasActiveFilters() %}
            <div class="card bg-base-100 border border-base-200 shadow-sm">
                <div class="card-body p-8 text-center text-base-content/60">
                    No reports match the current filters.
                </div>
            </div>
        {% else %}
            <twig:EmptyState
                title="No reports yet"
                message="DMARC reports will appear here once your mailbox connection starts receiving them."
            />
        {% endif %}
    {% else %}
        <turbo-frame id="reports-table">
            {% include 'dashboard/_reports_table.html.twig' %}
        </turbo-frame>
    {% endif %}
{% endblock %}
