{% extends 'dashboard/layout.html.twig' %}

{% block page_title %}Report ingestion{% endblock %}
{% block breadcrumbs %}<li>Report ingestion</li>{% endblock %}

{% block page_heading %}
    <div class="mb-6">
        <h1 class="text-2xl font-bold">Report ingestion</h1>
        <p class="text-sm text-base-content/60 mt-1 max-w-2xl">
            Where DMARC reports arrive from email providers.
        </p>
    </div>
{% endblock %}

{% block content %}
    {# Flash messages #}
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'error' ? 'error' : 'success' }} mb-4">
                <span>{{ message }}</span>
            </div>
        {% endfor %}
    {% endfor %}

    <twig:IngestionRoutesCallout
        reportAddress="{{ reportAddress }}"
        dnsCtaUrl="{{ dnsCtaUrl }}"
    />

    {% if matrix|length > 0 %}
        <section class="mb-8" data-testid="ingestion-matrix">
            <h2 class="text-lg font-semibold mb-3">Per-domain ingestion</h2>
            <div class="card bg-base-100 border border-base-200 shadow-sm">
                <div class="card-body p-4">
                    <div class="overflow-x-auto">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Domain</th>
                                    <th>Active ingestion path</th>
                                    <th>Last report received</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for row in matrix %}
                                    <tr {% if row.isMisconfigured %}data-testid="mixed-warning"{% endif %}>
                                        <td class="font-medium">{{ row.domainName }}</td>
                                        <td>
                                            {# TASK-100: scenario-aware badges take precedence over the
                                               raw IngestionPath because the scenario answers "what does
                                               DMARC actually route?" — a strictly better signal than the
                                               envelope-history-only path classifier. Mixed always wins
                                               so the duplicate-ingestion warning still surfaces. #}
                                            {% if row.path.value == 'mixed' %}
                                                <span class="badge badge-warning">Both — please pick one</span>
                                                <div class="text-xs text-warning mt-1">
                                                    Duplicate ingestion — choose DNS or mailbox per domain.
                                                </div>
                                            {% elseif row.ruaScenario and row.ruaScenario.scenario.value == 'points_at_sendvery' %}
                                                <span class="badge badge-success">Ingesting via DNS (Sendvery)</span>
                                                <div class="text-xs text-base-content/60 mt-1">
                                                    RUA points at <span class="font-mono">{{ reportAddress }}</span>
                                                </div>
                                            {% elseif row.ruaScenario and row.ruaScenario.scenario.value == 'points_at_external' %}
                                                <span class="badge badge-warning">Configured for external inbox</span>
                                                <div class="text-xs text-base-content/70 mt-1">
                                                    RUA points at <span class="font-mono">{{ row.ruaScenario.ruaEmail }}</span>
                                                </div>
                                            {% elseif row.ruaScenario and row.ruaScenario.scenario.value == 'no_record' %}
                                                <span class="badge badge-error">DMARC missing</span>
                                                <div class="text-xs text-error mt-1">
                                                    No <code>_dmarc</code> TXT record found
                                                </div>
                                            {% elseif row.path.value == 'dns' %}
                                                <span class="badge badge-primary">DNS (central inbox)</span>
                                                <div class="text-xs text-base-content/60 mt-1">
                                                    via <span class="font-mono">{{ reportAddress }}</span>
                                                </div>
                                            {% elseif row.path.value == 'mailbox' %}
                                                <span class="badge badge-ghost">Mailbox</span>
                                                {% if row.mailboxHost %}
                                                    <div class="text-xs text-base-content/60 mt-1">
                                                        via
                                                        {% if row.mailboxId %}
                                                            <a href="{{ path('dashboard_mailbox_detail', {id: row.mailboxId}) }}"
                                                               class="link link-hover font-mono">{{ row.mailboxHost }}:{{ row.mailboxPort }}</a>
                                                        {% else %}
                                                            <span class="font-mono">{{ row.mailboxHost }}:{{ row.mailboxPort }}</span>
                                                        {% endif %}
                                                    </div>
                                                {% endif %}
                                            {% else %}
                                                <span class="badge badge-ghost">No reports yet</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-sm text-base-content/70">
                                            {{ row.lastReportAt ? row.lastReportAt|date('M j, H:i') : '—' }}
                                        </td>
                                        <td>
                                            {# Scenario-driven action column. Mixed still wins. Then
                                               scenario-aware copy for the three RUA cases; finally
                                               fall through to the legacy path-based branches. #}
                                            {% if row.path.value == 'mixed' %}
                                                <a href="{{ path('dashboard_domain_health', {id: row.domainId}) }}#health-dmarc"
                                                   class="btn btn-warning btn-xs">Decide</a>
                                            {% elseif row.ruaScenario and row.ruaScenario.scenario.value == 'no_record' %}
                                                <a href="{{ path('dashboard_domain_health', {id: row.domainId}) }}#health-dmarc"
                                                   class="btn btn-ghost btn-xs">Publish RUA</a>
                                            {% elseif row.ruaScenario and row.ruaScenario.scenario.value == 'points_at_sendvery' %}
                                                <span class="text-base-content/40">—</span>
                                            {% elseif row.ruaScenario and row.ruaScenario.scenario.value == 'points_at_external' %}
                                                <div class="flex flex-col gap-1">
                                                    <a href="{{ path('dashboard_mailbox_add') }}"
                                                       class="btn btn-primary btn-xs">Connect this inbox</a>
                                                    <a class="link link-hover text-xs"
                                                       href="{{ path('dashboard_domain_health', {id: row.domainId}) }}#health-dmarc">Or repoint to Sendvery</a>
                                                </div>
                                            {% elseif row.path.value == 'none' %}
                                                <a href="{{ path('dashboard_domain_health', {id: row.domainId}) }}#health-dmarc"
                                                   class="btn btn-ghost btn-xs">Publish RUA</a>
                                            {% else %}
                                                <span class="text-base-content/40">—</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </section>
    {% endif %}

    {% if mailboxes|length > 0 %}
        <section data-testid="connected-mailboxes">
            <h2 class="text-lg font-semibold mb-3">Connected mailboxes</h2>
            <div class="card bg-base-100 border border-base-200 shadow-sm">
                <div class="card-body p-4">
                    <div class="overflow-x-auto">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Host</th>
                                    <th>Type</th>
                                    <th>Status</th>
                                    <th>Last Polled</th>
                                    <th>Activity (30d)</th>
                                    <th>Last Error</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {# Stretched-link row navigation per TASK-018 (TASK-035).
                                   The "Re-test" form gets `relative z-20` so submitting
                                   the button doesn't fall through to the row anchor. #}
                                {% for mailbox in mailboxes %}
                                    {% set summary = activity[mailbox.id.toString()] %}
                                    <tr class="hover:bg-base-200/50 relative">
                                        <td class="font-medium">
                                            <a href="{{ path('dashboard_mailbox_detail', { id: mailbox.id }) }}"
                                               class="absolute inset-0 z-10"
                                               aria-label="Open mailbox detail for {{ mailbox.host }}"></a>
                                            {{ mailbox.host }}:{{ mailbox.port }}
                                        </td>
                                        <td>{{ mailbox.type.value }}</td>
                                        <td>
                                            {% if mailbox.isActive and mailbox.lastError is null %}
                                                <twig:StatusBadge status="active" label="Active" />
                                            {% elseif mailbox.lastError %}
                                                <twig:StatusBadge status="error" label="Error" />
                                            {% else %}
                                                <twig:StatusBadge status="inactive" label="Inactive" />
                                            {% endif %}
                                        </td>
                                        <td>{{ mailbox.lastPolledAt ? mailbox.lastPolledAt|date('M j, H:i') : '—' }}</td>
                                        <td class="text-xs text-base-content/60 whitespace-nowrap">
                                            {{ summary.envelopes30d }} envelopes / {{ summary.reports30d }} reports / {{ summary.quarantined30d }} quarantined
                                        </td>
                                        <td class="text-xs text-error max-w-xs truncate">{{ mailbox.lastError ?? '—' }}</td>
                                        <td>
                                            <form method="post" action="{{ path('dashboard_mailbox_retest', { id: mailbox.id }) }}" class="relative z-20">
                                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('mailbox_retest') }}">
                                                <button type="submit" class="btn btn-ghost btn-xs">Re-test</button>
                                            </form>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </section>
    {% endif %}
{% endblock %}
