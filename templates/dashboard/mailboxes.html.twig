{% extends 'dashboard/layout.html.twig' %}

{% block page_title %}Mailboxes{% endblock %}
{% block breadcrumbs %}<li>Mailboxes</li>{% endblock %}

{% block content %}
    {# Flash messages #}
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'error' ? 'error' : 'success' }} mb-4">
                <span>{{ message }}</span>
            </div>
        {% endfor %}
    {% endfor %}

    {% if mailboxes is empty %}
        <twig:EmptyState
            title="No mailboxes connected"
            message="Connect a mailbox to automatically receive and parse DMARC reports."
            actionUrl="{{ path('dashboard_mailbox_add') }}"
            actionLabel="Connect a mailbox"
        />
    {% else %}
        <div class="card bg-base-100 border border-base-200 shadow-sm">
            <div class="card-body p-4">
                <div class="overflow-x-auto">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Host</th>
                                <th>Type</th>
                                <th>Status</th>
                                <th>Last Polled</th>
                                <th>Activity (30d)</th>
                                <th>Last Error</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {# Stretched-link row navigation per TASK-018 (TASK-035).
                               The "Re-test" form gets `relative z-20` so submitting
                               the button doesn't fall through to the row anchor. #}
                            {% for mailbox in mailboxes %}
                                {% set summary = activity[mailbox.id.toString()] %}
                                <tr class="hover:bg-base-200/50 relative">
                                    <td class="font-medium">
                                        <a href="{{ path('dashboard_mailbox_detail', { id: mailbox.id }) }}"
                                           class="absolute inset-0 z-10"
                                           aria-label="Open mailbox detail for {{ mailbox.host }}"></a>
                                        {{ mailbox.host }}:{{ mailbox.port }}
                                    </td>
                                    <td>{{ mailbox.type.value }}</td>
                                    <td>
                                        {% if mailbox.isActive and mailbox.lastError is null %}
                                            <twig:StatusBadge status="active" label="Active" />
                                        {% elseif mailbox.lastError %}
                                            <twig:StatusBadge status="error" label="Error" />
                                        {% else %}
                                            <twig:StatusBadge status="inactive" label="Inactive" />
                                        {% endif %}
                                    </td>
                                    <td>{{ mailbox.lastPolledAt ? mailbox.lastPolledAt|date('M j, H:i') : '—' }}</td>
                                    <td class="text-xs text-base-content/60 whitespace-nowrap">
                                        {{ summary.envelopes30d }} envelopes / {{ summary.reports30d }} reports / {{ summary.quarantined30d }} quarantined
                                    </td>
                                    <td class="text-xs text-error max-w-xs truncate">{{ mailbox.lastError ?? '—' }}</td>
                                    <td>
                                        <form method="post" action="{{ path('dashboard_mailbox_retest', { id: mailbox.id }) }}" class="relative z-20">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('mailbox_retest') }}">
                                            <button type="submit" class="btn btn-ghost btn-xs">Re-test</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
