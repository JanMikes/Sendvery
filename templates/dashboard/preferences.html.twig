{% extends 'dashboard/layout.html.twig' %}

{% block page_title %}Preferences{% endblock %}

{% block breadcrumbs %}
    <li>Settings</li>
    <li>Preferences</li>
{% endblock %}

{% block content %}
<div class="max-w-2xl">
    <h1 class="text-2xl font-bold mb-6">Email Preferences</h1>

    {% if success is defined and success %}
        <div class="alert alert-success mb-6">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span>{{ success }}</span>
        </div>
    {% endif %}

    <div class="card bg-base-100 shadow-sm">
        <div class="card-body">
            <form method="POST" action="{{ path('dashboard_preferences') }}">
                <div class="form-control mb-4">
                    <label class="label cursor-pointer justify-start gap-4">
                        <input type="checkbox" name="email_digest_enabled" value="1" class="toggle toggle-primary" {{ user.emailDigestEnabled ? 'checked' : '' }}>
                        <div>
                            <span class="label-text font-medium">Weekly Digest Email</span>
                            <p class="text-xs text-base-content/50 mt-0.5">Receive a weekly summary of your DMARC reports, alerts, and DNS changes every Monday.</p>
                        </div>
                    </label>
                </div>

                <div class="form-control mb-6">
                    <label class="label cursor-pointer justify-start gap-4">
                        <input type="checkbox" name="email_alerts_enabled" value="1" class="toggle toggle-primary" {{ user.emailAlertsEnabled ? 'checked' : '' }}>
                        <div>
                            <span class="label-text font-medium">Alert Notifications</span>
                            <p class="text-xs text-base-content/50 mt-0.5">Receive email notifications for critical alerts like DNS changes or failure spikes.</p>
                        </div>
                    </label>
                </div>

                <button type="submit" class="btn btn-primary">Save Preferences</button>
            </form>
        </div>
    </div>

    {# Muted alert types — surfaced here (rather than per-team-settings) so a
       single user with multiple teams sees every active mute in one place. #}
    <h2 class="text-xl font-bold mt-10 mb-3">Muted Alert Types</h2>
    <p class="text-sm text-base-content/60 mb-4">
        Future alerts of these (domain, type) pairs are silently dropped. Past alerts already in your list are unaffected.
    </p>

    <div class="card bg-base-100 shadow-sm">
        <div class="card-body">
            {% if mutedAlerts is empty %}
                <p class="text-sm text-base-content/50">No muted alert types. Use the "Mute this type" button on an alert's detail page to silence future occurrences for a domain.</p>
            {% else %}
                <div class="overflow-x-auto">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Domain</th>
                                <th>Alert type</th>
                                <th>Muted</th>
                                <th class="text-right"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for muted in mutedAlerts %}
                                <tr>
                                    <td class="font-medium">{{ muted.domainName }}</td>
                                    <td>{{ muted.alertType|replace({'_': ' '})|capitalize }}</td>
                                    <td class="text-base-content/60 text-xs">{{ muted.mutedAt|date('M j, Y') }}</td>
                                    <td class="text-right">
                                        <form method="post" action="{{ path('dashboard_alert_unmute', { id: muted.mutedAlertId }) }}">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('unmute_alert') }}">
                                            <button type="submit" class="btn btn-xs btn-ghost">Unmute</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
