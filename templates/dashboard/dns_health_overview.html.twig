{% extends 'dashboard/layout.html.twig' %}

{% block page_title %}DNS Health{% endblock %}
{% block breadcrumbs %}<li>DNS Health</li>{% endblock %}

{% block header_actions %}
    <a href="{{ path('dashboard_domain_add') }}" class="btn btn-primary btn-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Add domain
    </a>
{% endblock %}

{% block content %}
    {% if domains is empty %}
        <twig:EmptyState
            title="No domains yet"
            message="Add your first domain to start monitoring its DNS health."
            actionUrl="{{ path('dashboard_domain_add') }}"
            actionLabel="Add your first domain"
        />
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
            {% for domain in domains %}
                <div class="card bg-base-100 shadow">
                    <div class="card-body">
                        <div class="flex items-center justify-between">
                            <h3 class="card-title text-lg">{{ domain.domainName }}</h3>
                            {% if domain.hasSnapshot() %}
                                <span class="badge {{ domain.snapshotGradeColor() }} font-bold">{{ domain.latestSnapshotGrade }}</span>
                            {% endif %}
                        </div>
                        <div class="flex flex-wrap gap-2 mt-2">
                            <span class="badge {{ domain.isSpfVerified() ? 'badge-success' : 'badge-error' }}">SPF</span>
                            <span class="badge {{ domain.isDkimVerified() ? 'badge-success' : 'badge-error' }}">DKIM</span>
                            <span class="badge {{ domain.isDmarcVerified() ? 'badge-success' : 'badge-error' }}">DMARC</span>
                            {% if domain.latestMxScore is null %}
                                <span class="badge badge-ghost">MX</span>
                            {% elseif domain.latestMxScore >= 80 %}
                                <span class="badge badge-success">MX</span>
                            {% elseif domain.latestMxScore >= 50 %}
                                <span class="badge badge-warning">MX</span>
                            {% else %}
                                <span class="badge badge-error">MX</span>
                            {% endif %}
                        </div>
                        <div class="card-actions justify-end mt-4">
                            {% if not domain.hasSnapshot() %}
                                <span class="text-sm text-base-content/50">No health data yet</span>
                            {% endif %}
                            <a href="{{ path('dashboard_domain_health', {id: domain.domainId}) }}" class="btn btn-ghost btn-sm">View details</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
