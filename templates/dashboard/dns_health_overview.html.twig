{% extends 'dashboard/layout.html.twig' %}

{% block page_title %}DNS Health{% endblock %}
{% block breadcrumbs %}<li>DNS Health</li>{% endblock %}

{% block page_heading %}
    <div class="mb-6">
        <h1 class="text-2xl font-bold">DNS Health</h1>
        <p class="text-sm text-base-content/60 mt-1 max-w-2xl">SPF, DKIM, DMARC and MX records for every monitored domain in one view.</p>
    </div>
{% endblock %}

{% block content %}
    {% if totalCount == 0 %}
        <twig:EmptyState
            title="No domains yet"
            message="Add your first domain to start monitoring its DNS health."
            actionUrl="{{ path('dashboard_domain_add') }}"
            actionLabel="Add your first domain"
        />
    {% else %}
        {# TASK-083: 4-card summary row + filter chips. Counts are always
           the unfiltered totals so the chips link to a known target; the
           grid below shows whichever subset the active filter matches. #}
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
            <twig:StatCard title="Domains monitored" value="{{ totalCount }}" />
            <a href="{{ path('dashboard_dns_health', { status: 'healthy' }) }}" class="block">
                <twig:StatCard title="Fully healthy" value="{{ healthyCount }}" variant="{{ healthyCount > 0 ? 'success' : 'default' }}" />
            </a>
            <a href="{{ path('dashboard_dns_health', { status: 'attention' }) }}" class="block">
                <twig:StatCard title="Need attention" value="{{ attentionCount }}" variant="{{ attentionCount > 0 ? 'warning' : 'default' }}" />
            </a>
            <a href="{{ path('dashboard_dns_health', { status: 'unchecked' }) }}" class="block">
                <twig:StatCard title="Awaiting first check" value="{{ awaitingCount }}" variant="default" />
            </a>
        </div>

        <div class="flex flex-wrap gap-2 mb-4" data-testid="dns-health-filter-chips">
            <a href="{{ path('dashboard_dns_health') }}" class="btn btn-sm {{ activeFilter == '' ? 'btn-primary' : 'btn-ghost' }}">All ({{ totalCount }})</a>
            <a href="{{ path('dashboard_dns_health', { status: 'healthy' }) }}" class="btn btn-sm {{ activeFilter == 'healthy' ? 'btn-success' : 'btn-ghost' }}">Fully healthy ({{ healthyCount }})</a>
            <a href="{{ path('dashboard_dns_health', { status: 'attention' }) }}" class="btn btn-sm {{ activeFilter == 'attention' ? 'btn-warning' : 'btn-ghost' }}">Need attention ({{ attentionCount }})</a>
            <a href="{{ path('dashboard_dns_health', { status: 'unchecked' }) }}" class="btn btn-sm {{ activeFilter == 'unchecked' ? 'btn-info' : 'btn-ghost' }}">Awaiting first check ({{ awaitingCount }})</a>
        </div>

        {% if domains is empty %}
            <div class="card bg-base-100 border border-base-200 shadow-sm">
                <div class="card-body text-center py-10">
                    <p class="text-base-content/60">No domains match the current filter.</p>
                    <a href="{{ path('dashboard_dns_health') }}" class="btn btn-ghost btn-sm mt-3 w-fit mx-auto">Clear filter</a>
                </div>
            </div>
        {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
            {% for domain in domains %}
                {% set detailUrl = path('dashboard_domain_health', {id: domain.domainId}) %}
                <div class="card bg-base-100 shadow border border-base-200 hover:shadow-md hover:border-primary/30 transition-all relative">
                    <a href="{{ detailUrl }}" class="absolute inset-0" aria-label="Open DNS health for {{ domain.domainName }}"></a>
                    <div class="card-body">
                        <div class="flex items-center justify-between">
                            <h3 class="card-title text-lg">{{ domain.domainName }}</h3>
                            {% if domain.hasSnapshot() %}
                                <a href="{{ detailUrl }}#health-score"
                                   class="badge {{ domain.snapshotGradeColor() }} font-bold relative z-10 hover:opacity-80"
                                   aria-label="Overall DNS health score for {{ domain.domainName }}">{{ domain.latestSnapshotGrade }}</a>
                            {% endif %}
                        </div>
                        <div class="flex flex-wrap gap-2 mt-2">
                            <a href="{{ detailUrl }}#health-spf"
                               class="badge {{ domain.isSpfVerified() ? 'badge-success' : 'badge-error' }} relative z-10 hover:opacity-80">SPF</a>
                            <a href="{{ detailUrl }}#health-dkim"
                               class="badge {{ domain.isDkimVerified() ? 'badge-success' : 'badge-error' }} relative z-10 hover:opacity-80">DKIM</a>
                            <a href="{{ detailUrl }}#health-dmarc"
                               class="badge {{ domain.isDmarcVerified() ? 'badge-success' : 'badge-error' }} relative z-10 hover:opacity-80">DMARC</a>
                            {% if domain.latestMxScore is null %}
                                <a href="{{ detailUrl }}#health-mx" class="badge badge-ghost relative z-10 hover:opacity-80">MX</a>
                            {% elseif domain.latestMxScore >= 80 %}
                                <a href="{{ detailUrl }}#health-mx" class="badge badge-success relative z-10 hover:opacity-80">MX</a>
                            {% elseif domain.latestMxScore >= 50 %}
                                <a href="{{ detailUrl }}#health-mx" class="badge badge-warning relative z-10 hover:opacity-80">MX</a>
                            {% else %}
                                <a href="{{ detailUrl }}#health-mx" class="badge badge-error relative z-10 hover:opacity-80">MX</a>
                            {% endif %}
                        </div>
                        {% if not domain.hasSnapshot() %}
                            <div class="mt-4 text-sm text-base-content/50">No health data yet</div>
                        {% endif %}
                        <div class="card-actions justify-end mt-4">
                            <a href="{{ path('dashboard_domain_dns_history', {id: domain.domainId}) }}"
                               class="btn btn-ghost btn-sm relative z-10">DNS history</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        {% endif %}
    {% endif %}
{% endblock %}
