{% extends 'dashboard/layout.html.twig' %}

{% block page_title %}Billing{% endblock %}
{% block breadcrumbs %}
    <li><a href="{{ path('dashboard_preferences') }}">Settings</a></li>
    <li>Billing</li>
{% endblock %}

{% block content %}
    <div class="max-w-3xl mx-auto space-y-6">
        {# Current plan #}
        <div class="card bg-base-100 border border-base-200 shadow-sm">
            <div class="card-body p-6">
                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-lg font-semibold">Current Plan</h2>
                    <span class="badge badge-primary badge-lg">{{ billing.plan.value|capitalize }}</span>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-sm text-base-content/50">Domains</p>
                        <p class="text-lg font-medium">{{ billing.domainCount }} / {{ maxDomains }}</p>
                        <div class="w-full bg-base-200 rounded-full h-2 mt-1">
                            <div class="bg-primary rounded-full h-2" style="width: {{ maxDomains > 0 ? ((billing.domainCount / maxDomains) * 100)|round : 0 }}%"></div>
                        </div>
                    </div>
                    <div>
                        <p class="text-sm text-base-content/50">Team Members</p>
                        <p class="text-lg font-medium">{{ billing.memberCount }} / {{ maxMembers }}</p>
                        <div class="w-full bg-base-200 rounded-full h-2 mt-1">
                            <div class="bg-primary rounded-full h-2" style="width: {{ maxMembers > 0 ? ((billing.memberCount / maxMembers) * 100)|round : 0 }}%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Paid plans in private beta #}
        {% if billing.plan.value != 'team' %}
            <div class="card bg-base-100 border border-base-200 shadow-sm">
                <div class="card-body p-6">
                    <div class="flex items-start gap-3 mb-4">
                        <div class="w-10 h-10 rounded-lg bg-warning/10 flex items-center justify-center flex-shrink-0">
                            <svg class="w-5 h-5 text-warning" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                        <div>
                            <h2 class="text-lg font-semibold">Paid plans are in private beta</h2>
                            <p class="text-sm text-base-content/60 mt-1">
                                Sendvery hosted is onboarding small batches. Request access and we'll get back to you with next steps.
                            </p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-{{ billing.plan.value == 'free' ? '2' : '1' }} gap-4">
                        {% if billing.plan.value == 'free' %}
                            <div class="border border-primary rounded-xl p-5">
                                <div class="flex items-center justify-between mb-2">
                                    <h3 class="font-semibold">Personal</h3>
                                    <span class="badge badge-primary badge-sm">Most popular</span>
                                </div>
                                <p class="text-2xl font-bold">$5.99<span class="text-sm font-normal text-base-content/50">/mo</span></p>
                                <p class="text-xs text-base-content/50">VAT included where applicable</p>
                                <ul class="mt-3 space-y-1 text-sm text-base-content/70">
                                    <li>Up to 5 domains</li>
                                    <li>Real-time alerts</li>
                                    <li>Blacklist monitoring</li>
                                    <li>1-year data retention</li>
                                </ul>
                                <a href="{{ path('request_beta_access', {plan: 'personal', source: 'dashboard-billing'}) }}" class="btn btn-primary btn-sm w-full mt-4">Request beta access</a>
                            </div>
                        {% endif %}

                        <div class="border border-base-300 rounded-xl p-5">
                            <h3 class="font-semibold mb-2">Team</h3>
                            <p class="text-2xl font-bold">$49.99<span class="text-sm font-normal text-base-content/50">/mo</span></p>
                            <p class="text-xs text-base-content/50">VAT included where applicable</p>
                            <ul class="mt-3 space-y-1 text-sm text-base-content/70">
                                <li>Up to 50 domains</li>
                                <li>10 team members</li>
                                <li>AI Insights included</li>
                                <li>API access</li>
                                <li>Unlimited retention</li>
                            </ul>
                            <a href="{{ path('request_beta_access', {plan: 'team', source: 'dashboard-billing'}) }}" class="btn btn-outline btn-sm w-full mt-4">Request beta access</a>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
