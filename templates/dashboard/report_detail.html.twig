{% extends 'dashboard/layout.html.twig' %}

{% block page_title %}Report {{ report.externalReportId }}{% endblock %}
{% block breadcrumbs %}
    <li><a href="{{ path('dashboard_reports') }}">Reports</a></li>
    <li>{{ report.externalReportId|length > 30 ? report.externalReportId[:30] ~ '...' : report.externalReportId }}</li>
{% endblock %}

{% block page_heading %}
    {# Report header #}
    <div class="mb-6">
        <h1 class="text-2xl font-bold">Report from {{ report.reporterOrg }}</h1>
        <p class="text-sm text-base-content/50 mt-1">
            {{ report.dateRangeBegin|date('M j, Y') }} — {{ report.dateRangeEnd|date('M j, Y') }}
            <span class="mx-2">|</span>
            External ID: <span class="font-mono text-xs">{{ report.externalReportId }}</span>
        </p>
    </div>
{% endblock %}

{% block content %}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
        {# Report metadata #}
        <div class="card bg-base-100 border border-base-200 shadow-sm lg:col-span-2">
            <div class="card-body p-4">
                <h3 class="text-sm font-semibold mb-3">Report Details</h3>
                <div class="grid grid-cols-2 gap-3 text-sm">
                    <div>
                        <span class="text-base-content/50">Reporter</span>
                        <p class="font-medium">{{ report.reporterOrg }}</p>
                    </div>
                    <div>
                        <span class="text-base-content/50">Reporter Email</span>
                        <p class="font-medium">{{ report.reporterEmail }}</p>
                    </div>
                    <div>
                        <span class="text-base-content/50">Policy Domain</span>
                        <p class="font-medium">{{ report.policyDomain }}</p>
                    </div>
                    <div>
                        <span class="text-base-content/50">Processed</span>
                        <p class="font-medium">{{ report.processedAt|date('M j, Y H:i') }}</p>
                    </div>
                </div>

                <div class="divider my-3"></div>

                <h3 class="text-sm font-semibold mb-3">Published Policy</h3>
                <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 text-sm">
                    <div>
                        <span class="text-base-content/50">Policy (p)</span>
                        <p><twig:StatusBadge status="{{ report.policyP }}" label="p={{ report.policyP }}" /></p>
                    </div>
                    {% if report.policySp %}
                        <div>
                            <span class="text-base-content/50">Subdomain (sp)</span>
                            <p><twig:StatusBadge status="{{ report.policySp }}" label="sp={{ report.policySp }}" /></p>
                        </div>
                    {% endif %}
                    <div>
                        <span class="text-base-content/50">DKIM Alignment</span>
                        <p class="font-medium">{{ report.policyAdkim == 'r' ? 'Relaxed' : 'Strict' }}</p>
                    </div>
                    <div>
                        <span class="text-base-content/50">SPF Alignment</span>
                        <p class="font-medium">{{ report.policyAspf == 'r' ? 'Relaxed' : 'Strict' }}</p>
                    </div>
                    <div>
                        <span class="text-base-content/50">Percentage</span>
                        <p class="font-medium">{{ report.policyPct }}%</p>
                    </div>
                </div>
            </div>
        </div>

        {# Pass/fail donut #}
        <div class="card bg-base-100 border border-base-200 shadow-sm">
            <div class="card-body p-4">
                <h3 class="text-sm font-semibold mb-2">Authentication Summary</h3>
                <div class="text-center mb-2">
                    <span class="text-3xl font-bold">{{ totalMessages }}</span>
                    <span class="text-sm text-base-content/50 block">total messages</span>
                </div>
                <div {{ stimulus_controller('chart', { config: donutConfig }) }} style="min-height: 200px"></div>
            </div>
        </div>
    </div>

    {% if aiEnabled %}
        <turbo-frame id="report-explanation">
            <div class="card bg-base-100 border border-base-200 shadow-sm mb-6">
                <div class="card-body p-4">
                    <h3 class="text-sm font-semibold mb-2">AI explanation</h3>
                    {% if cachedExplanation is not null %}
                        <div class="text-sm whitespace-pre-line">{{ cachedExplanation }}</div>
                    {% elseif routineExplanation is not null %}
                        <div class="text-sm whitespace-pre-line">{{ routineExplanation }}</div>
                    {% elseif showExplainButton %}
                        <p class="text-sm text-base-content/60 mb-3">Get a plain-language explanation of this report.</p>
                        <form method="post" action="{{ path('dashboard_report_explain', { id: report.reportId }) }}" data-turbo-frame="report-explanation">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('explain_report') }}">
                            <button type="submit" class="btn btn-primary btn-sm">Explain this report</button>
                            <span class="text-xs text-base-content/50 ml-2">{{ aiRemaining }} of {{ aiLimit }} left this month</span>
                        </form>
                    {% endif %}
                </div>
            </div>
        </turbo-frame>
    {% endif %}

    {# By sender grouped view #}
    <div class="mb-6">
        <h2 class="text-lg font-semibold mb-3">By sender</h2>
        <div class="space-y-2">
            {% for group in senderGroups %}
                <details class="group">
                    <summary class="card bg-base-100 border border-base-200 shadow-sm cursor-pointer list-none">
                        <div class="card-body p-3 flex flex-row flex-wrap items-center gap-3">
                            <span class="font-medium truncate max-w-[18rem]" title="{{ group.displayLabel }}">
                                {{ group.displayLabel|length > 50 ? group.displayLabel[:50] ~ '…' : group.displayLabel }}
                            </span>
                            <span class="text-sm text-base-content/60">{{ group.totalMessages }} msg</span>
                            <span class="badge badge-sm badge-ghost">DKIM {{ group.dkimPassRate|number_format(0) }}%</span>
                            <span class="badge badge-sm badge-ghost">SPF {{ group.spfPassRate|number_format(0) }}%</span>
                            {% if group.dispositionNone > 0 %}
                                <span class="badge badge-sm badge-info">{{ group.dispositionNone }} none</span>
                            {% endif %}
                            {% if group.dispositionQuarantine > 0 %}
                                <span class="badge badge-sm badge-warning">{{ group.dispositionQuarantine }} quarantine</span>
                            {% endif %}
                            {% if group.dispositionReject > 0 %}
                                <span class="badge badge-sm badge-error">{{ group.dispositionReject }} reject</span>
                            {% endif %}
                            {% if group.senderIsAuthorized is same as(true) %}
                                <span class="badge badge-sm badge-success">Authorized</span>
                            {% elseif group.senderIsAuthorized is same as(false) %}
                                <span class="badge badge-sm badge-error">Unauthorized</span>
                            {% endif %}
                        </div>
                    </summary>
                    <div class="overflow-x-auto mt-1 ml-2 border-l-2 border-base-300 pl-3">
                        <table class="table table-xs">
                            <thead>
                                <tr>
                                    <th>Source IP</th>
                                    <th>Hostname</th>
                                    <th class="text-right">Count</th>
                                    <th>Disposition</th>
                                    <th>DKIM</th>
                                    <th>SPF</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for record in report.records|filter(record => record.sourceIp in group.sourceIps) %}
                                    <tr>
                                        <td class="font-mono text-xs">{{ record.sourceIp }}</td>
                                        <td class="text-xs">{{ record.resolvedHostname ?? record.resolvedOrg ?? '—' }}</td>
                                        <td class="text-right font-medium">{{ record.count }}</td>
                                        <td><twig:StatusBadge status="{{ record.disposition }}" /></td>
                                        <td><twig:StatusBadge status="{{ record.dkimResult }}" /></td>
                                        <td><twig:StatusBadge status="{{ record.spfResult }}" /></td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </details>
            {% else %}
                <p class="text-sm text-base-content/50">No records in this report.</p>
            {% endfor %}
        </div>
    </div>

    {# Records table #}
    <details>
        <summary class="cursor-pointer mb-3">
            <span class="text-sm font-semibold">Show raw records ({{ report.records|length }})</span>
        </summary>
        <div class="card bg-base-100 border border-base-200 shadow-sm">
            <div class="card-body p-4">
                <h3 class="text-sm font-semibold mb-3">Records ({{ report.records|length }})</h3>

                <div class="overflow-x-auto">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Source IP</th>
                                <th>Hostname</th>
                                <th class="text-right">Count</th>
                                <th>Disposition</th>
                                <th>DKIM</th>
                                <th>SPF</th>
                                <th>Header From</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for record in report.records %}
                                <tr>
                                    <td class="font-mono text-xs">{{ record.sourceIp }}</td>
                                    <td class="text-xs">{{ record.resolvedHostname ?? record.resolvedOrg ?? '—' }}</td>
                                    <td class="text-right font-medium">{{ record.count }}</td>
                                    <td><twig:StatusBadge status="{{ record.disposition }}" /></td>
                                    <td><twig:StatusBadge status="{{ record.dkimResult }}" /></td>
                                    <td><twig:StatusBadge status="{{ record.spfResult }}" /></td>
                                    <td class="text-xs">{{ record.headerFrom }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </details>
{% endblock %}
