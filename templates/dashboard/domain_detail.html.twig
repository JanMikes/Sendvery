{% extends 'dashboard/layout.html.twig' %}

{% block page_title %}{{ domain.domainName }}{% endblock %}
{% block breadcrumbs %}
    <li><a href="{{ path('dashboard_domains') }}">Domains</a></li>
    <li>{{ domain.domainName }}</li>
{% endblock %}

{% block page_heading %}
    {# Domain header #}
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
        <div>
            <h1 class="text-2xl font-bold">{{ domain.domainName }}</h1>
            <div class="flex items-center gap-2 mt-1">
                {% if domain.dmarcPolicy %}
                    <twig:StatusBadge status="{{ domain.dmarcPolicy }}" label="p={{ domain.dmarcPolicy }}" />
                {% endif %}
                {% if domain.isVerified %}
                    <span class="badge badge-sm badge-success">Verified</span>
                {% else %}
                    <span class="badge badge-sm badge-ghost">Unverified</span>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}

{% block content %}
    {% import 'components/_severity_glyph.html.twig' as severity %}

    {# One-line status banner (TASK-067) — the headline answer to "is this
       domain set up correctly?". Sits above the workspace tabs so it leads
       the page the same way the overview health banner leads /app. #}
    <twig:DomainStatusBanner :status="domainSetupStatus" :domainId="domain.domainId" />

    {# Sibling navigation: the legacy five-button header that used to sit here
       was removed (TASK-041) — DomainWorkspaceTabs (TASK-031) is now the sole
       cross-surface affordance for the domain workspace. Two stacked nav rows
       on the most-visited authenticated page read as unfinished. #}
    <twig:DomainWorkspaceTabs :domain="domain" active="overview" :tabCounts="tabCounts" />

    {# Per-protocol setup checklist (TASK-080) — the actionable body under the
       banner. Renders one of three states: all-green confirmation, partial
       checklist with Fix-this deep-links, or "no DNS check yet" with a
       re-check button. #}
    <twig:DomainSetupStatus :status="domainSetupStatus" :domainId="domain.domainId" :ruaExtendInstruction="ruaExtendInstruction" :ruaAddressCount="ruaAddressCount" />

    {% if reportAuthorizationFound is not null %}
        {% set reportHost = reportDomain ? reportDomain|split('@')|last : 'sendvery.com' %}
        {% if reportAuthorizationFound %}
            <div class="rounded-2xl border border-success/30 bg-success/5 p-5 mb-6" data-testid="report-authorization-row">
                <div class="flex items-start gap-3">
                    <div class="w-9 h-9 rounded-full bg-success/15 text-success flex items-center justify-center shrink-0">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                        </svg>
                    </div>
                    <div class="flex-1">
                        <div class="font-semibold text-base-content mb-1">Report authorization</div>
                        <p class="text-sm text-base-content/70" data-testid="report-authorization-configured">
                            Authorization record published — ISPs will deliver DMARC reports to Sendvery for this domain.
                        </p>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="rounded-2xl border border-warning/30 bg-warning/5 p-5 mb-6" data-testid="report-authorization-row">
                <div class="flex items-start gap-3">
                    <div class="w-9 h-9 rounded-full bg-warning/15 text-warning flex items-center justify-center shrink-0">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                        </svg>
                    </div>
                    <div class="flex-1">
                        <div class="font-semibold text-base-content mb-1">Report authorization missing</div>
                        <p class="text-sm text-base-content/70 mb-2" data-testid="report-authorization-missing">
                            Missing — ISPs may silently drop DMARC reports sent to Sendvery for this domain.
                        </p>
                        <p class="text-sm text-base-content/60 mb-1">
                            Publish this TXT record on <strong>{{ reportHost }}</strong>'s DNS:
                        </p>
                        <code class="text-xs font-mono bg-base-200 px-2 py-1.5 rounded break-all block" data-testid="report-authorization-record">{{ domain.domainName }}._report._dmarc.{{ reportHost }} IN TXT "v=DMARC1;"</code>
                        <p class="text-xs text-base-content/50 mt-2">SaaS customers: this is handled automatically. Self-hosters: add this record to your report address domain's DNS.</p>
                    </div>
                </div>
            </div>
        {% endif %}
    {% endif %}

    <div class="card bg-base-100 border border-base-200 shadow-sm mb-6" data-testid="domain-dkim-selector-card">
        <div class="card-body p-5">
            <div class="flex items-start gap-3 mb-3">
                <div class="w-9 h-9 rounded-full bg-info/10 text-info flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                    </svg>
                </div>
                <div class="flex-1">
                    <h3 class="text-sm font-semibold">DKIM selector</h3>
                    <p class="text-xs text-base-content/60 mt-0.5">
                        {% if domain.dkimSelector %}
                            Locked to <code class="font-mono text-xs bg-base-200 px-1 rounded">{{ domain.dkimSelector }}</code> — Sendvery checks this selector on every DNS scan.
                        {% else %}
                            Auto-detect mode — Sendvery tries common selectors from our registry on each DNS scan.
                        {% endif %}
                    </p>
                </div>
            </div>

            {# Detection result from the last DNS check #}
            {% if dkimDetection is not null %}
                <div class="rounded-lg border px-3 py-2 mb-3 text-xs {{ dkimDetection.keyFound ? 'border-success/30 bg-success/5' : 'border-warning/30 bg-warning/5' }}" data-testid="dkim-detection-status">
                    {% if dkimDetection.keyFound %}
                        <span class="font-semibold text-success">Found</span> — DKIM key at selector
                        <code class="font-mono bg-base-200 px-1 rounded" data-testid="dkim-detected-selector">{{ dkimDetection.selector }}</code>
                        {% if dkimDetection.keyBits %}
                            <span class="text-base-content/60">({{ dkimDetection.keyBits }}-bit {{ dkimDetection.keyType|default('RSA')|upper }})</span>
                        {% endif %}
                        {% if dkimDetection.matchedProviders is not empty %}
                            <span class="text-base-content/60">· {{ dkimDetection.matchedProviders|join(', ') }}</span>
                        {% endif %}
                    {% else %}
                        <span class="font-semibold text-warning">Not found</span> — no DKIM key detected on common selectors.
                        {% if dkimDetection.detectedProviders is not empty %}
                            We see <strong>{{ dkimDetection.detectedProviders|join(', ') }}</strong> MX records — try one of the suggested selectors below.
                        {% else %}
                            Set a custom selector if your provider isn't in our registry.
                        {% endif %}
                    {% endif %}
                </div>

                {# Saved vs detected mismatch warning #}
                {% if domain.dkimSelector and dkimDetection.keyFound and domain.dkimSelector != dkimDetection.selector %}
                    <div class="rounded-lg border border-warning/30 bg-warning/5 px-3 py-2 mb-3 text-xs" data-testid="dkim-selector-mismatch">
                        <span class="font-semibold text-warning">Mismatch</span> — saved selector is <code class="font-mono bg-base-200 px-1 rounded">{{ domain.dkimSelector }}</code> but the key was found at <code class="font-mono bg-base-200 px-1 rounded">{{ dkimDetection.selector }}</code>. Consider updating.
                    </div>
                {% endif %}
            {% endif %}

            {# Provider-aware selector suggestions #}
            {% if dkimSuggestedSelectors is not empty %}
                <div class="mb-3" data-testid="dkim-suggested-selectors">
                    <span class="text-xs text-base-content/60 mr-1">
                        {% if dkimDetection is not null and dkimDetection.detectedProviders is not empty %}
                            Suggestions for {{ dkimDetection.detectedProviders|join(', ') }}:
                        {% else %}
                            Common selectors:
                        {% endif %}
                    </span>
                    {% for sel in dkimSuggestedSelectors|slice(0, 8) %}
                        <button
                            type="button"
                            class="badge badge-sm badge-outline cursor-pointer hover:badge-primary mr-1 mb-1 {{ domain.dkimSelector == sel ? 'badge-primary' : '' }}"
                            data-testid="dkim-suggestion-chip"
                            onclick="document.querySelector('[data-testid=domain-dkim-selector-input]').value = '{{ sel|escape('js') }}';"
                        >{{ sel }}</button>
                    {% endfor %}
                </div>
            {% endif %}

            <form method="post" action="{{ path('dashboard_domain_set_dkim_selector', {id: domain.domainId}) }}" class="flex flex-col sm:flex-row gap-2">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('domain_dkim_selector') }}">
                <input
                    type="text"
                    name="selector"
                    value="{{ domain.dkimSelector ?? '' }}"
                    placeholder="e.g. selector1 — leave empty for auto-detect"
                    maxlength="63"
                    pattern="[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?"
                    title="A DKIM selector is a single DNS label: alphanumeric and hyphens only, not starting or ending with a hyphen."
                    class="input input-bordered input-sm flex-1"
                    data-testid="domain-dkim-selector-input"
                    aria-label="DKIM selector"
                >
                <button type="submit" class="btn btn-sm btn-primary" data-testid="domain-dkim-selector-submit">
                    Save & re-check DNS
                </button>
                {% if domain.dkimSelector %}
                    <button
                        type="submit"
                        name="selector"
                        value=""
                        class="btn btn-sm btn-ghost"
                        data-testid="dkim-reset-auto-detect"
                    >
                        Reset to auto-detect
                    </button>
                {% endif %}
            </form>
        </div>
    </div>

    {% if quarantineCount > 0 %}
        <div class="rounded-2xl border border-warning/30 bg-warning/5 p-5 mb-6">
            <div class="flex items-start gap-3">
                <div class="w-9 h-9 rounded-full bg-warning/15 text-warning flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div class="flex-1">
                    <div class="font-semibold text-base-content mb-1">
                        {{ quarantineCount }} DMARC report{{ quarantineCount > 1 ? 's' : '' }} waiting for {{ domain.domainName }}
                    </div>
                    <p class="text-sm text-base-content/70">
                        Email receivers are already sending reports for this domain — they're parked in quarantine until your DMARC TXT record is verified. Finish DNS verification to unlock them all at once.
                    </p>
                </div>
                <form method="post" action="{{ path('dashboard_domain_reverify', {id: domain.domainId}) }}" class="shrink-0">
                    <button type="submit" class="btn btn-sm btn-warning">Re-check DNS</button>
                </form>
            </div>
        </div>
    {% endif %}

    {# Quick stats #}
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <twig:StatCard title="Total Messages" value="{{ domain.totalMessages|number_format(0, '.', ',') }}" />
        <twig:StatCard
            title="Pass Rate"
            value="{{ domain.passRate|number_format(1) }}%"
            variant="{{ domain.passRate >= 90 ? 'success' : (domain.passRate >= 70 ? 'warning' : 'error') }}"
        />
        <a href="{{ path('dashboard_sender_inventory', {domainId: domain.domainId}) }}" class="block">
            <twig:StatCard title="Unique Senders" value="{{ domain.uniqueSenders }}" />
        </a>
        <twig:StatCard title="Reports" value="{{ domain.totalReports }}" />
    </div>

    {# DMARC policy explainer (TASK-037) — sits directly under the metrics
       that justify the next-tier recommendation. TASK-099: only render when
       a DMARC record is actually published — for a brand-new domain with
       no `_dmarc` TXT record at all, the controller's fallback to
       DmarcPolicy::None would otherwise have the explainer claim "DMARC
       reports are being collected", which is a factual lie. DomainSetupStatus
       above already covers the "publish DMARC first" affordance. #}
    {% if hasPublishedDmarcRecord %}
        <twig:DmarcPolicyExplainer :result="dmarcPolicyAdvice" />
    {% endif %}

    {# Charts row #}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <twig:ChartCard
            title="DMARC Pass/Fail Trend"
            description="Last 90 days"
            :config="trendChartConfig"
            height="280px"
        />

        {# Inlined ChartCard so we can attach a "View all senders →" link
           in the header AND a sender-summary stat row + labelled table
           (TASK-038). The shared ChartCard component is intentionally
           minimal — it owns one chart and no chrome. Mirrors the rest of
           the dashboard card shell. #}
        <div class="card bg-base-100 border border-base-200 shadow-sm">
            <div class="card-body p-4">
                <div class="flex items-center justify-between">
                    <div>
                        <h3 class="text-sm font-semibold">Top Senders</h3>
                        <p class="text-xs text-base-content/50 mt-0.5">By message volume</p>
                    </div>
                    {% if senders is not empty %}
                        <a href="{{ path('dashboard_sender_inventory', {domainId: domain.domainId}) }}"
                           class="text-xs text-primary hover:underline">View all senders →</a>
                    {% endif %}
                </div>

                {# Senders-by-authorization stat row. Renders whenever there's
                   anything to count — known_sender rows can exist even before
                   DMARC records do (manual seed, import, etc.). Each count
                   clicks through to the matching filter on the sender
                   inventory page (`?filter=authorized|unauthorized`). The
                   "unique IPs" count links to the unfiltered page — there is
                   no per-IP filter axis on the inventory today. #}
                {% if senderSummary.authorizedCount > 0 or senderSummary.unknownCount > 0 or senderSummary.uniqueIpCount > 0 %}
                    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-3 text-xs text-base-content/70">
                        <a href="{{ path('dashboard_sender_inventory', {domainId: domain.domainId, filter: 'authorized'}) }}"
                           class="hover:underline" data-testid="sender-summary-authorized">
                            <span class="font-semibold text-success">{{ senderSummary.authorizedCount }}</span> authorized
                        </a>
                        <span class="text-base-content/30">·</span>
                        <a href="{{ path('dashboard_sender_inventory', {domainId: domain.domainId, filter: 'unauthorized'}) }}"
                           class="hover:underline" data-testid="sender-summary-unknown">
                            <span class="font-semibold text-warning">{{ senderSummary.unknownCount }}</span> unknown
                        </a>
                        <span class="text-base-content/30">·</span>
                        <a href="{{ path('dashboard_sender_inventory', {domainId: domain.domainId}) }}"
                           class="hover:underline" data-testid="sender-summary-unique-ips">
                            <span class="font-semibold">{{ senderSummary.uniqueIpCount }}</span> unique IPs
                        </a>
                    </div>
                {% endif %}

                {% if senders is not empty %}
                    <div class="mt-3" style="min-height: 300px"
                         {{ stimulus_controller('chart', { config: senderChartConfig }) }}></div>

                    {# Labelled sender summary table — top 5 by volume. Each row
                       deep-links into the sender inventory page via the
                       `#sender-{id}` fragment (matching `id` attribute lives
                       on every inventory row). #}
                    <div class="overflow-x-auto mt-4" data-testid="top-senders-table">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Sender</th>
                                    <th class="text-right">Messages</th>
                                    <th class="text-right">DKIM</th>
                                    <th class="text-right">SPF</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for sender in senders %}
                                    <tr class="hover:bg-base-200/50 relative">
                                        <td class="font-medium">
                                            {% if sender.knownSenderId %}
                                                <a href="{{ path('dashboard_sender_inventory', {domainId: domain.domainId}) }}#sender-{{ sender.knownSenderId }}"
                                                   class="absolute inset-0 z-10"
                                                   aria-label="View {{ sender.displayLabel }} in sender inventory"></a>
                                            {% else %}
                                                <a href="{{ path('dashboard_sender_inventory', {domainId: domain.domainId}) }}"
                                                   class="absolute inset-0 z-10"
                                                   aria-label="View senders for {{ sender.displayLabel }}"></a>
                                            {% endif %}
                                            {{ sender.displayLabel }}
                                        </td>
                                        <td class="text-right">{{ sender.totalMessages|number_format(0, '.', ',') }}</td>
                                        <td class="text-right">
                                            <span class="{{ sender.dkimPassRate >= 90 ? 'text-success' : (sender.dkimPassRate >= 70 ? 'text-warning' : 'text-error') }}">
                                                {{ sender.dkimPassRate|number_format(1) }}%
                                            </span>
                                        </td>
                                        <td class="text-right">
                                            <span class="{{ sender.spfPassRate >= 90 ? 'text-success' : (sender.spfPassRate >= 70 ? 'text-warning' : 'text-error') }}">
                                                {{ sender.spfPassRate|number_format(1) }}%
                                            </span>
                                        </td>
                                        <td>
                                            {% if sender.senderIsAuthorized %}
                                                <span class="badge badge-sm badge-success">Authorized</span>
                                            {% else %}
                                                <span class="badge badge-sm badge-warning">Unknown</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    {# Educational empty state — DMARC newcomers see this on
                       day one before any reports have arrived. Explains the
                       cause/effect (publish DMARC → receivers send reports →
                       sender breakdown appears) and links to the canonical
                       "What is DMARC" KB article. #}
                    <div class="text-center py-10" data-testid="top-senders-empty-state">
                        <p class="text-sm text-base-content/70 max-w-md mx-auto">
                            DMARC reports tell us which servers are sending email as your domain. Sender breakdown appears here once Gmail/Outlook send their first report — usually within 24 hours of publishing DMARC.
                        </p>
                        <a href="{{ path('knowledge_base_article', {slug: 'what-is-dmarc'}) }}"
                           class="link link-primary text-sm mt-3 inline-block">
                            Learn what DMARC is →
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    {# Recent reports table #}
    <div class="card bg-base-100 border border-base-200 shadow-sm">
        <div class="card-body p-4">
            <div class="flex items-center justify-between mb-3">
                <h3 class="text-sm font-semibold">Recent Reports</h3>
                <a href="{{ path('dashboard_domain_reports', { id: domain.domainId }) }}" class="text-xs text-primary hover:underline">View all</a>
            </div>

            {% if reports is empty %}
                <p class="text-sm text-base-content/50 py-4 text-center">No reports for this domain yet.</p>
            {% else %}
                <div class="overflow-x-auto">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                {# Leading severity glyph column (TASK-069) — mirrors the
                                   shape of `_reports_table.html.twig` so the per-domain
                                   "Recent Reports" table reads the same as the global one. #}
                                <th class="w-8"><span class="sr-only">Health</span></th>
                                <th>Reporter</th>
                                <th>Date Range</th>
                                <th class="text-right">Records</th>
                                <th class="text-right">Pass Rate</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for report in reports %}
                                {% set reportTone = severity.pass_rate_tone(report.passRate)|trim %}
                                <tr class="hover:bg-base-200/50 cursor-pointer relative border-l-4 border-l-{{ reportTone }}">
                                    <td class="w-8">
                                        {{ severity.glyph(reportTone, 'sm') }}
                                    </td>
                                    <td class="font-medium">
                                        <a href="{{ path('dashboard_report_detail', { id: report.reportId }) }}"
                                           class="absolute inset-0 z-10"
                                           aria-label="View report from {{ report.reporterOrg }}"></a>
                                        {{ report.reporterOrg }}
                                    </td>
                                    <td>{{ report.dateRangeBegin|date('M j') }} — {{ report.dateRangeEnd|date('M j, Y') }}</td>
                                    <td class="text-right">{{ report.recordCount }}</td>
                                    <td class="text-right">
                                        <span class="text-{{ reportTone }}">
                                            {{ report.passRate|number_format(1) }}%
                                        </span>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
