{% extends 'dashboard/layout.html.twig' %}

{% block page_title %}{{ domain.domainName }}{% endblock %}
{% block breadcrumbs %}
    <li><a href="{{ path('dashboard_domains') }}">Domains</a></li>
    <li>{{ domain.domainName }}</li>
{% endblock %}

{% block content %}
    {# Domain header #}
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
        <div>
            <h1 class="text-2xl font-bold">{{ domain.domainName }}</h1>
            <div class="flex items-center gap-2 mt-1">
                {% if domain.dmarcPolicy %}
                    <twig:StatusBadge status="{{ domain.dmarcPolicy }}" label="p={{ domain.dmarcPolicy }}" />
                {% endif %}
                {% if domain.isVerified %}
                    <span class="badge badge-sm badge-success">Verified</span>
                {% else %}
                    <span class="badge badge-sm badge-ghost">Unverified</span>
                {% endif %}
            </div>
            <div class="flex items-center gap-2 mt-2 flex-wrap">
                {% if dnsHealth is null %}
                    <span class="badge badge-ghost badge-sm">SPF</span>
                    <span class="badge badge-ghost badge-sm">DKIM</span>
                    <span class="badge badge-ghost badge-sm">DMARC</span>
                    <span class="badge badge-ghost badge-sm">MX</span>
                {% else %}
                    <a href="{{ path('dashboard_domain_health', {id: domain.domainId}) }}#health-spf"
                       class="badge badge-sm {{ dnsHealth.isSpfVerified() ? 'badge-success' : 'badge-error' }}">SPF</a>
                    <a href="{{ path('dashboard_domain_health', {id: domain.domainId}) }}#health-dkim"
                       class="badge badge-sm {{ dnsHealth.isDkimVerified() ? 'badge-success' : 'badge-error' }}">DKIM</a>
                    <a href="{{ path('dashboard_domain_health', {id: domain.domainId}) }}#health-dmarc"
                       class="badge badge-sm {{ dnsHealth.isDmarcVerified() ? 'badge-success' : 'badge-error' }}">DMARC</a>
                    {% if dnsHealth.latestMxScore is null %}
                        <a href="{{ path('dashboard_domain_health', {id: domain.domainId}) }}#health-mx" class="badge badge-sm badge-ghost">MX</a>
                    {% elseif dnsHealth.latestMxScore >= 80 %}
                        <a href="{{ path('dashboard_domain_health', {id: domain.domainId}) }}#health-mx" class="badge badge-sm badge-success">MX</a>
                    {% elseif dnsHealth.latestMxScore >= 50 %}
                        <a href="{{ path('dashboard_domain_health', {id: domain.domainId}) }}#health-mx" class="badge badge-sm badge-warning">MX</a>
                    {% else %}
                        <a href="{{ path('dashboard_domain_health', {id: domain.domainId}) }}#health-mx" class="badge badge-sm badge-error">MX</a>
                    {% endif %}
                {% endif %}
            </div>
        </div>
        <div class="flex items-center gap-2">
            <a href="{{ path('dashboard_domain_reports', { id: domain.domainId }) }}" class="btn btn-ghost btn-sm">
                All reports
            </a>
            <a href="{{ path('dashboard_domain_dns_history', { id: domain.domainId }) }}" class="btn btn-ghost btn-sm">
                DNS History
            </a>
            <a href="{{ path('dashboard_domain_health', {id: domain.domainId}) }}" class="btn btn-ghost btn-sm">
                DNS Health Check
            </a>
            <a href="{{ path('dashboard_sender_inventory', {domainId: domain.domainId}) }}" class="btn btn-ghost btn-sm">
                Senders
            </a>
            <a href="{{ path('dashboard_blacklist_status', {id: domain.domainId}) }}" class="btn btn-ghost btn-sm">
                Blacklist
            </a>
        </div>
    </div>

    <twig:DomainWorkspaceTabs :domain="domain" active="overview" />

    {% if quarantineCount > 0 %}
        <div class="rounded-2xl border border-warning/30 bg-warning/5 p-5 mb-6">
            <div class="flex items-start gap-3">
                <div class="w-9 h-9 rounded-full bg-warning/15 text-warning flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div class="flex-1">
                    <div class="font-semibold text-base-content mb-1">
                        {{ quarantineCount }} DMARC report{{ quarantineCount > 1 ? 's' : '' }} waiting for {{ domain.domainName }}
                    </div>
                    <p class="text-sm text-base-content/70">
                        Email receivers are already sending reports for this domain — they're parked in quarantine until your DMARC TXT record is verified. Finish DNS verification to unlock them all at once.
                    </p>
                </div>
                <form method="post" action="{{ path('dashboard_domain_reverify', {id: domain.domainId}) }}" class="shrink-0">
                    <button type="submit" class="btn btn-sm btn-warning">Re-check DNS</button>
                </form>
            </div>
        </div>
    {% endif %}

    {# Quick stats #}
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <twig:StatCard title="Total Messages" value="{{ domain.totalMessages|number_format(0, '.', ',') }}" />
        <twig:StatCard
            title="Pass Rate"
            value="{{ domain.passRate|number_format(1) }}%"
            variant="{{ domain.passRate >= 90 ? 'success' : (domain.passRate >= 70 ? 'warning' : 'error') }}"
        />
        <a href="{{ path('dashboard_sender_inventory', {domainId: domain.domainId}) }}" class="block">
            <twig:StatCard title="Unique Senders" value="{{ domain.uniqueSenders }}" />
        </a>
        <twig:StatCard title="Reports" value="{{ domain.totalReports }}" />
    </div>

    {# Charts row #}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <twig:ChartCard
            title="DMARC Pass/Fail Trend"
            description="Last 90 days"
            :config="trendChartConfig"
            height="280px"
        />

        {% if senders is not empty %}
            {# Inlined ChartCard so we can attach a "View all senders →" link
               in the header — the shared ChartCard component has no slot for
               header extras. Mirrors the rest of the dashboard card shell. #}
            <div class="card bg-base-100 border border-base-200 shadow-sm">
                <div class="card-body p-4">
                    <div class="flex items-center justify-between">
                        <div>
                            <h3 class="text-sm font-semibold">Top Senders</h3>
                            <p class="text-xs text-base-content/50 mt-0.5">By message volume</p>
                        </div>
                        <a href="{{ path('dashboard_sender_inventory', {domainId: domain.domainId}) }}"
                           class="text-xs text-primary hover:underline">View all senders →</a>
                    </div>
                    <div class="mt-3" style="min-height: 300px"
                         {{ stimulus_controller('chart', { config: senderChartConfig }) }}></div>
                </div>
            </div>
        {% else %}
            <div class="card bg-base-100 border border-base-200 shadow-sm">
                <div class="card-body p-4">
                    <h3 class="text-sm font-semibold">Top Senders</h3>
                    <twig:EmptyState
                        title="No sender data"
                        message="Sender breakdown will appear once DMARC reports are processed."
                    />
                </div>
            </div>
        {% endif %}
    </div>

    {# Recent reports table #}
    <div class="card bg-base-100 border border-base-200 shadow-sm">
        <div class="card-body p-4">
            <div class="flex items-center justify-between mb-3">
                <h3 class="text-sm font-semibold">Recent Reports</h3>
                <a href="{{ path('dashboard_domain_reports', { id: domain.domainId }) }}" class="text-xs text-primary hover:underline">View all</a>
            </div>

            {% if reports is empty %}
                <p class="text-sm text-base-content/50 py-4 text-center">No reports for this domain yet.</p>
            {% else %}
                <div class="overflow-x-auto">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Reporter</th>
                                <th>Date Range</th>
                                <th class="text-right">Records</th>
                                <th class="text-right">Pass Rate</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for report in reports %}
                                <tr class="hover:bg-base-200/50 cursor-pointer relative">
                                    <td class="font-medium">
                                        <a href="{{ path('dashboard_report_detail', { id: report.reportId }) }}"
                                           class="absolute inset-0 z-10"
                                           aria-label="View report from {{ report.reporterOrg }}"></a>
                                        {{ report.reporterOrg }}
                                    </td>
                                    <td>{{ report.dateRangeBegin|date('M j') }} — {{ report.dateRangeEnd|date('M j, Y') }}</td>
                                    <td class="text-right">{{ report.recordCount }}</td>
                                    <td class="text-right">
                                        <span class="{{ report.passRate >= 90 ? 'text-success' : (report.passRate >= 70 ? 'text-warning' : 'text-error') }}">
                                            {{ report.passRate|number_format(1) }}%
                                        </span>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
