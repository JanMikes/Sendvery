{% extends 'dashboard/layout.html.twig' %}

{% block page_title %}Reports{% endblock %}
{% block breadcrumbs %}
    <li><a href="{{ path('dashboard_domains') }}">Domains</a></li>
    <li>Reports</li>
{% endblock %}

{% block page_heading %}
    <div class="mb-6">
        <h1 class="text-2xl font-bold">Reports — {{ domain.domainName }}</h1>
        <p class="text-sm text-base-content/60 mt-1 max-w-2xl">Every DMARC report we've received for this domain.</p>
    </div>
{% endblock %}

{% block content %}
    <twig:DomainWorkspaceTabs :domain="domain" active="reports" />

    <twig:ReportsFilterBar
        filter="{{ filter }}"
        reporterOptions="{{ reporterOptions }}"
        formAction="dashboard_domain_reports"
        domainId="{{ domainId }}"
        showDomainFilter="{{ false }}"
    />

    {% if reports is empty and currentPage == 1 %}
        {% if filter.hasActiveFilters() %}
            <div class="card bg-base-100 border border-base-200 shadow-sm">
                <div class="card-body p-8 text-center text-base-content/60">
                    No reports match the current filters.
                </div>
            </div>
        {% else %}
            <twig:EmptyState
                title="No reports yet"
                message="DMARC reports for this domain will appear here."
            />
        {% endif %}
    {% else %}
        <turbo-frame id="domain-reports-table">
            {% include 'dashboard/_domain_reports_table.html.twig' %}
        </turbo-frame>
    {% endif %}
{% endblock %}
