{% extends 'tools/_tool_layout.html.twig' %}

{% block title %}Free MX Record Checker — Mail Server Lookup & TLS Check | Sendvery{% endblock %}
{% block meta_description %}Check your MX records and mail server health. Verify MX priority, test mail server connectivity, check TLS certificates. Free MX checker tool.{% endblock %}
{% block og_image %}{{ absolute_url(path('og_image', {type: 'tool', slug: 'mx-checker'})) }}{% endblock %}

{% block tool_structured_data %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "What are MX records?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "MX (Mail Exchange) records are DNS records that specify which mail servers are responsible for receiving email for a domain. They include a priority value that determines the order servers are tried."
            }
        },
        {
            "@type": "Question",
            "name": "What does MX priority mean?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "MX priority is a number where lower values mean higher priority. A server with priority 10 will be tried before one with priority 20. Multiple MX records with the same priority provide load balancing."
            }
        },
        {
            "@type": "Question",
            "name": "Why does TLS matter for email?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Without TLS (STARTTLS), email is transmitted in plaintext between servers, making it readable by anyone who can intercept the traffic. STARTTLS encrypts the connection between mail servers."
            }
        },
        {
            "@type": "Question",
            "name": "What happens if MX records are missing?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Without MX records, sending servers fall back to the domain's A record for mail delivery. This usually means email bounces or is delivered to the wrong server. Always configure proper MX records."
            }
        }
    ]
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "{{ url('home') }}"},
        {"@type": "ListItem", "position": 2, "name": "Tools", "item": "{{ url('tools_domain_health') }}"},
        {"@type": "ListItem", "position": 3, "name": "MX Checker"}
    ]
}
</script>
{% endblock %}

{% block breadcrumb_title %}MX Checker{% endblock %}
{% block tool_title %}MX Record Checker{% endblock %}
{% block tool_description %}Look up your MX records and check mail server health. Verify priority configuration, test connectivity, and check TLS support.{% endblock %}

{% block checker_card %}<twig:MxChecker domain="{{ initialDomain ?? '' }}" />{% endblock %}

{% block seo_content %}
{# MX generator — client-side only, see assets/controllers/mx_generator_controller.js #}
<twig:SectionContainer bgClass="bg-base-200/50">
    <div class="max-w-3xl mx-auto">
        <h2 id="mx-generator" class="text-2xl md:text-3xl font-medium tracking-tight text-zinc-900 mb-3">MX Record Generator</h2>
        <p class="text-base-content/70 mb-6">Pick a mailbox provider preset and we'll render the matching MX records — priority and host, ready for your DNS zone. Microsoft 365 needs your tenant slug.</p>

        <div
            class="card bg-base-100 border border-base-200 shadow-sm rounded-2xl"
            data-controller="mx-generator"
            data-mx-generator-presets-value="{{ mxPresetsJson|e('html_attr') }}"
        >
            <div class="card-body space-y-6">
                <div class="form-control">
                    <label class="label" for="mx-generator-preset"><span class="label-text font-semibold">Mailbox provider</span></label>
                    <select
                        id="mx-generator-preset"
                        class="select select-bordered"
                        data-mx-generator-target="preset"
                        data-action="change->mx-generator#presetChanged"
                    >
                        <option value="" selected disabled>Choose a provider…</option>
                        {% for preset in mxPresets %}
                            <option value="{{ preset.key }}">{{ preset.label }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div hidden data-mx-generator-target="tenantPanel" class="form-control">
                    <label class="label" for="mx-generator-tenant"><span class="label-text font-semibold">Microsoft 365 tenant slug</span></label>
                    <input
                        id="mx-generator-tenant"
                        type="text"
                        class="input input-bordered font-mono text-sm"
                        placeholder="acme-com"
                        data-mx-generator-target="tenant"
                        data-action="input->mx-generator#presetChanged"
                    />
                    <span class="label-text-alt text-xs mt-1 text-base-content/60">Microsoft 365 generates a unique host like <code>acme-com.mail.protection.outlook.com</code>. Use the slug shown in your Microsoft admin centre.</span>
                </div>

                <div hidden data-mx-generator-target="panel" class="space-y-3">
                    <div class="label-text font-semibold">Publish these as MX records on your apex domain</div>
                    <pre class="bg-base-200 rounded-lg p-4 overflow-x-auto"><code class="text-sm" data-mx-generator-target="output"></code></pre>
                    <div class="flex flex-wrap gap-3 items-center">
                        <button type="button" class="btn btn-sm" data-action="click->mx-generator#copy">Copy</button>
                        <p class="text-sm text-base-content/60">Test in DNS before making this your live record. We don't publish for you.</p>
                    </div>
                    <p class="text-sm text-base-content/60">New to MX priority and redundancy? Read <a class="link link-primary" href="{{ path('knowledge_base_article', {slug: 'mx-records-explained'}) }}">MX records explained</a>.</p>
                </div>
            </div>
        </div>
    </div>
</twig:SectionContainer>

<twig:SectionContainer>
    <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold mb-6">What are MX records?</h2>
        <div class="prose prose-lg max-w-none text-base-content/80">
            <p>
                MX (Mail Exchange) records are DNS records that tell the world which servers handle email for your domain. When someone sends you an email, their mail server queries your MX records to find out where to deliver it.
            </p>
            <p>
                Each MX record has a <strong>priority</strong> (lower number = higher priority) and a <strong>hostname</strong> pointing to the mail server. Most domains have multiple MX records for redundancy — if the primary server is down, email is delivered to the backup.
            </p>
        </div>
    </div>
</twig:SectionContainer>

<twig:SectionContainer bgClass="bg-base-200/50">
    <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold mb-6">Security risks</h2>
        <div class="space-y-4">
            <div class="flex items-start gap-3 p-4 rounded-lg bg-error/5 border border-error/10">
                <svg class="w-6 h-6 text-error shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"></path></svg>
                <div>
                    <h3 class="font-bold">No TLS encryption</h3>
                    <p class="text-sm text-base-content/60 mt-1">Your mail server's TLS certificate expired 2 weeks ago. Every email since has been transmitted in plaintext — readable by anyone on the network path.</p>
                </div>
            </div>
            <div class="flex items-start gap-3 p-4 rounded-lg bg-warning/5 border border-warning/10">
                <svg class="w-6 h-6 text-warning shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <div>
                    <h3 class="font-bold">MX pointing to decommissioned server</h3>
                    <p class="text-sm text-base-content/60 mt-1">You migrated to a new mail provider but left the old MX record. Email is being delivered to a server you no longer control — or bouncing entirely.</p>
                </div>
            </div>
        </div>
    </div>
</twig:SectionContainer>

<twig:SectionContainer>
    <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold">Frequently asked questions</h2>
    </div>
    <twig:FaqAccordion :items="[
        {question: 'What are MX records?', answer: 'MX records tell sending servers where to deliver email for your domain. They include a priority (lower = preferred) and a hostname. Multiple MX records provide redundancy.'},
        {question: 'What does MX priority mean?', answer: 'Lower numbers mean higher priority. A server with priority 10 is tried before priority 20. Same-priority servers receive load-balanced traffic.'},
        {question: 'Why does STARTTLS matter?', answer: 'Without STARTTLS, email between servers is transmitted in plaintext. Anyone intercepting the traffic can read the contents. STARTTLS encrypts the connection.'},
        {question: 'What if MX records are missing?', answer: 'Without MX records, sending servers fall back to the A record. This usually means email bounces. Always configure proper MX records for reliable delivery.'}
    ]" />
</twig:SectionContainer>
{% endblock %}
