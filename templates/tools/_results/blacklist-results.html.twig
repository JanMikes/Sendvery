<div class="card bg-base-100 border border-base-300 mt-6">
    <div class="card-body">
        <div class="flex items-center justify-between mb-4">
            <h3 class="card-title text-lg">
                Blacklist Results for <span class="font-mono text-primary">{{ domain }}</span>
                {% if result.ipAddress != domain %}
                    <span class="text-sm font-normal text-base-content/50">(resolved to {{ result.ipAddress }})</span>
                {% endif %}
            </h3>
            {% if result.isListed %}
                {% include 'tools/_results/_status_badge.html.twig' with {status: 'fail'} %}
            {% else %}
                {% include 'tools/_results/_status_badge.html.twig' with {status: 'pass'} %}
            {% endif %}
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
            <div class="stat bg-base-200 rounded-lg p-3">
                <div class="stat-title text-xs">Lists checked</div>
                <div class="stat-value text-lg">{{ result.totalChecked }}</div>
            </div>
            <div class="stat bg-base-200 rounded-lg p-3">
                <div class="stat-title text-xs">Listings</div>
                <div class="stat-value text-lg {{ result.listedCount > 0 ? 'text-error' : 'text-success' }}">{{ result.listedCount }}</div>
            </div>
        </div>

        <div class="space-y-2">
            {% for provider, data in result.results %}
                <div class="flex items-center justify-between p-3 rounded-lg {{ data.listed ? 'bg-error/5 border border-error/10' : 'bg-base-200/50' }}">
                    <code class="text-sm font-mono">{{ provider }}</code>
                    {% if data.listed %}
                        <span class="badge badge-error gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                            Listed
                        </span>
                    {% else %}
                        <span class="badge badge-success badge-outline gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Clean
                        </span>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </div>
</div>
