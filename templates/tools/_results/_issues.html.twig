{# Reusable issues list for DNS check results #}
{% if issues is not empty %}
<div class="space-y-2 mt-4">
    {% for issue in issues %}
        <div class="flex items-start gap-3 p-3 rounded-lg {% if issue.severity.value == 'critical' %}bg-error/10 text-error{% elseif issue.severity.value == 'warning' %}bg-warning/10 text-warning{% else %}bg-info/10 text-info{% endif %}">
            {% if issue.severity.value == 'critical' %}
                <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"></path></svg>
            {% elseif issue.severity.value == 'warning' %}
                <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            {% else %}
                <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            {% endif %}
            <div>
                <p class="text-sm font-medium">{{ issue.message }}</p>
                {% if issue.recommendation %}
                    <p class="text-xs mt-1 opacity-80">{{ issue.recommendation }}</p>
                {% endif %}
            </div>
        </div>
    {% endfor %}
</div>
{% endif %}
