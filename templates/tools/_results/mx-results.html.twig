<div class="card bg-base-100 border border-base-300 mt-6">
    <div class="card-body">
        <div class="flex items-center justify-between mb-4">
            <h3 class="card-title text-lg">MX Results for <span class="font-mono text-primary">{{ domain }}</span></h3>
            {% if result.isPassing %}
                {% include 'tools/_results/_status_badge.html.twig' with {status: 'pass'} %}
            {% elseif result.hasRecords %}
                {% include 'tools/_results/_status_badge.html.twig' with {status: 'warning'} %}
            {% else %}
                {% include 'tools/_results/_status_badge.html.twig' with {status: 'fail'} %}
            {% endif %}
        </div>

        {% if result.records is not empty %}
            <div class="overflow-x-auto mb-4">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Priority</th>
                            <th>Host</th>
                            <th>IP</th>
                            <th>Reachable</th>
                            <th>TLS</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for record in result.records %}
                            <tr>
                                <td class="font-mono">{{ record.priority }}</td>
                                <td class="font-mono text-sm">{{ record.host }}</td>
                                <td class="font-mono text-sm">{{ record.ip|default('N/A') }}</td>
                                <td>
                                    {% if record.reachable %}
                                        <span class="badge badge-success badge-sm">Yes</span>
                                    {% else %}
                                        <span class="badge badge-error badge-sm">No</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if record.tlsSupported is null %}
                                        <span class="badge badge-ghost badge-sm">N/A</span>
                                    {% elseif record.tlsSupported %}
                                        <span class="badge badge-success badge-sm">STARTTLS</span>
                                    {% else %}
                                        <span class="badge badge-warning badge-sm">No TLS</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="bg-base-200 rounded-lg p-4 mb-4 text-center">
                <p class="text-base-content/60">No MX records found for this domain.</p>
            </div>
        {% endif %}

        {% include 'tools/_results/_issues.html.twig' with {issues: result.issues} %}
    </div>
</div>
