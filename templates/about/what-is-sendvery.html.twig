{% extends 'marketing_layout.html.twig' %}

{% block title %}What is Sendvery? — Email Health & Deliverability Platform{% endblock %}
{% block meta_description %}Sendvery is an open-source email health monitoring platform. DMARC report parsing, DNS monitoring, and AI-powered insights for developers, small businesses, and agencies — from $5.99/mo or self-hosted free forever.{% endblock %}

{% block content %}
    {# 1. HERO #}
    <twig:SectionContainer>
        <div class="max-w-4xl mx-auto text-center">
            <div class="inline-flex">
                <span class="badge badge-outline badge-lg">Email Health & Deliverability</span>
            </div>
            <h1 class="text-3xl md:text-5xl font-bold mt-6">Stop deleting DMARC reports. Start understanding them.</h1>
            <p class="mt-6 text-lg text-base-content/70 max-w-2xl mx-auto">
                Sendvery watches your SPF, DKIM, and DMARC continuously, parses every aggregate report, and translates the noise into plain-English insights — so the first time you hear about a deliverability problem isn't from an angry customer.
            </p>
            <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
                <a href="{{ path('auth_login') }}" class="btn btn-primary btn-lg">Get started free</a>
                <a href="#how-different" class="btn btn-outline btn-lg">Why Sendvery?</a>
            </div>
        </div>
    </twig:SectionContainer>

    {# 2. THE PROBLEM #}
    <twig:SectionContainer bgClass="bg-base-200/30">
        <div class="max-w-3xl mx-auto">
            <div class="text-center mb-10">
                <h2 class="text-2xl md:text-3xl font-bold">The problem nobody warns you about</h2>
            </div>
            <div class="space-y-5 text-base-content/80 text-lg leading-relaxed">
                <p>
                    Email authentication records are set once and forgotten. Then services get added, DNS providers get migrated, DKIM keys quietly expire, and your records break — silently. The mail servers rejecting your messages don't ring a bell; they just drop them. You only find out when customers complain about missing invoices, or worse, when somebody spoofs your domain in a phishing campaign and your brand takes the hit.
                </p>
                <p>
                    Running <code class="bg-base-200 px-1.5 py-0.5 rounded text-sm">dig</code> against an MX record tells you nothing about whether real mail is being authenticated. DMARC reports do — but they arrive as compressed XML attachments from Google, Yahoo, and Microsoft, and reading them by hand is nobody's idea of a Tuesday afternoon.
                </p>
            </div>
            <div class="mt-10 text-center">
                <a href="{{ path('tools_domain_health') }}" class="btn btn-sm btn-primary">Check your domain in 30 seconds</a>
            </div>
        </div>
    </twig:SectionContainer>

    {# 3. PRODUCT PREVIEW (stylized HTML mock) #}
    <twig:SectionContainer>
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-10">
                <h2 class="text-2xl md:text-3xl font-bold">A dashboard, not a wall of XML</h2>
                <p class="mt-3 text-base-content/60 max-w-2xl mx-auto">Every monitored domain rolls up into one view — current health, pass rate, and the next action you should take.</p>
            </div>

            <div class="relative">
                <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-accent/10 blur-3xl -z-10" aria-hidden="true"></div>
                <div class="transform md:rotate-[-1deg] shadow-2xl shadow-primary/10 rounded-2xl">
                    <div class="card bg-base-100 border border-base-300/60 overflow-hidden">
                        <div class="card-body p-0">
                            <div class="flex items-center gap-2 px-5 py-3 bg-base-200/60 border-b border-base-300/60">
                                <span class="w-3 h-3 rounded-full bg-error/60" aria-hidden="true"></span>
                                <span class="w-3 h-3 rounded-full bg-warning/60" aria-hidden="true"></span>
                                <span class="w-3 h-3 rounded-full bg-success/60" aria-hidden="true"></span>
                                <span class="ml-3 text-xs text-base-content/50">app.sendvery.com / dashboard</span>
                            </div>
                            <div class="p-6">
                                <div class="flex items-center justify-between mb-4">
                                    <h3 class="text-lg font-semibold">Your domains</h3>
                                    <span class="badge badge-outline badge-sm">3 monitored</span>
                                </div>
                                <div class="overflow-x-auto">
                                    <table class="table table-sm">
                                        <thead>
                                            <tr>
                                                <th scope="col">Domain</th>
                                                <th scope="col">Health</th>
                                                <th scope="col">DMARC pass rate</th>
                                                <th scope="col"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td class="font-mono text-sm">acme.io</td>
                                                <td><span class="badge badge-success badge-sm">Healthy</span></td>
                                                <td class="font-semibold">99.4%</td>
                                                <td><span class="link link-primary text-sm">View report</span></td>
                                            </tr>
                                            <tr>
                                                <td class="font-mono text-sm">shop.example.com</td>
                                                <td><span class="badge badge-warning badge-sm">DKIM drift</span></td>
                                                <td class="font-semibold">87.1%</td>
                                                <td><span class="link link-primary text-sm">View report</span></td>
                                            </tr>
                                            <tr>
                                                <td class="font-mono text-sm">newsletter.example.org</td>
                                                <td><span class="badge badge-error badge-sm">SPF broken</span></td>
                                                <td class="font-semibold">41.8%</td>
                                                <td><span class="link link-primary text-sm">View report</span></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <p class="mt-6 text-center text-xs text-base-content/50">Illustrative — your data, your domains.</p>
            </div>
        </div>
    </twig:SectionContainer>

    {# 4. PERSONA CARDS #}
    <twig:SectionContainer bgClass="bg-base-200/30">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-10">
                <h2 class="text-2xl md:text-3xl font-bold">Built for the people who actually own email</h2>
                <p class="mt-3 text-base-content/60">Three audiences. One product. Different superpowers.</p>
            </div>

            <div class="grid md:grid-cols-3 gap-6">
                {# Developer #}
                <div class="card card-bordered bg-base-100 border-base-300/60">
                    <div class="card-body">
                        <div class="w-10 h-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center mb-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
                            </svg>
                        </div>
                        <h3 class="card-title text-lg">Developer</h3>
                        <p class="text-sm text-base-content/70"><strong class="text-base-content/90">What they need:</strong> visibility into their own infrastructure without an enterprise contract.</p>
                        <p class="text-sm text-base-content/70 mt-2"><strong class="text-base-content/90">Outcome:</strong> get alerted before deliverability tanks — and self-host the whole thing if you'd rather not pay anyone.</p>
                    </div>
                </div>

                {# Small Business #}
                <div class="card card-bordered bg-base-100 border-base-300/60">
                    <div class="card-body">
                        <div class="w-10 h-10 rounded-lg bg-secondary/10 text-secondary flex items-center justify-center mb-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z" />
                            </svg>
                        </div>
                        <h3 class="card-title text-lg">Small Business</h3>
                        <p class="text-sm text-base-content/70"><strong class="text-base-content/90">What they need:</strong> someone — or something — to translate "DMARC quarantine" into "do these three things by Friday".</p>
                        <p class="text-sm text-base-content/70 mt-2"><strong class="text-base-content/90">Outcome:</strong> understand deliverability in plain English, fix issues before invoices go missing.</p>
                    </div>
                </div>

                {# Agency #}
                <div class="card card-bordered bg-base-100 border-base-300/60">
                    <div class="card-body">
                        <div class="w-10 h-10 rounded-lg bg-accent/10 text-accent flex items-center justify-center mb-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
                            </svg>
                        </div>
                        <h3 class="card-title text-lg">Agency</h3>
                        <p class="text-sm text-base-content/70"><strong class="text-base-content/90">What they need:</strong> one dashboard across every client domain, with alerts that justify the monthly retainer.</p>
                        <p class="text-sm text-base-content/70 mt-2"><strong class="text-base-content/90">Outcome:</strong> prove value to clients with reports instead of "trust me, it's fine" emails.</p>
                    </div>
                </div>
            </div>

            <div class="mt-10 text-center">
                <a href="{{ path('auth_login') }}" class="btn btn-primary">Add your first domain — free</a>
            </div>
        </div>
    </twig:SectionContainer>

    {# 5. HOW IS SENDVERY DIFFERENT? #}
    <twig:SectionContainer id="how-different">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-10">
                <h2 class="text-2xl md:text-3xl font-bold">How is Sendvery different?</h2>
                <p class="mt-3 text-base-content/60 max-w-2xl mx-auto">There are good tools in this space. None of them combine continuous monitoring, AI-powered explanations, open source, and a $5.99 entry price.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div class="card bg-base-100 border border-base-300/60">
                    <div class="card-body">
                        <h3 class="font-semibold">MXToolbox</h3>
                        <p class="text-xs uppercase tracking-wider text-base-content/50 mt-1">One-off lookups</p>
                        <ul class="mt-3 text-sm space-y-1.5 text-base-content/70">
                            <li>Free single-record checks</li>
                            <li>No continuous monitoring</li>
                            <li>No DMARC report parsing</li>
                            <li>No AI guidance</li>
                        </ul>
                    </div>
                </div>

                <div class="card bg-base-100 border border-base-300/60">
                    <div class="card-body">
                        <h3 class="font-semibold">dmarcian</h3>
                        <p class="text-xs uppercase tracking-wider text-base-content/50 mt-1">Enterprise pricing</p>
                        <ul class="mt-3 text-sm space-y-1.5 text-base-content/70">
                            <li>Solid DMARC dashboards</li>
                            <li>Starts in the tens of $/mo</li>
                            <li>No AI insights</li>
                            <li>Closed source</li>
                        </ul>
                    </div>
                </div>

                <div class="card bg-base-100 border border-base-300/60">
                    <div class="card-body">
                        <h3 class="font-semibold">Self-hosted PowerDMARC / parsedmarc</h3>
                        <p class="text-xs uppercase tracking-wider text-base-content/50 mt-1">DIY stack</p>
                        <ul class="mt-3 text-sm space-y-1.5 text-base-content/70">
                            <li>Free if you have ops capacity</li>
                            <li>Elasticsearch + Grafana to babysit</li>
                            <li>No managed AI layer</li>
                            <li>Steep learning curve</li>
                        </ul>
                    </div>
                </div>

                <div class="card bg-base-100 border-primary border-2 relative">
                    <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                        <span class="badge badge-primary badge-sm">Sendvery</span>
                    </div>
                    <div class="card-body">
                        <h3 class="font-semibold text-primary">Sendvery</h3>
                        <p class="text-xs uppercase tracking-wider text-primary/70 mt-1">From $5.99/mo</p>
                        <ul class="mt-3 text-sm space-y-1.5 text-base-content/80">
                            <li>Continuous DNS + DMARC monitoring</li>
                            <li>AI-powered plain-English insights</li>
                            <li>Open source (AGPL-3.0), self-host free</li>
                            <li>One-line Docker setup</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </twig:SectionContainer>

    {# 6. BUILT IN THE OPEN #}
    <twig:SectionContainer bgClass="bg-base-200/30">
        <div class="max-w-3xl mx-auto">
            <div class="card bg-base-100 border border-base-300/60">
                <div class="card-body">
                    <div class="flex items-start gap-4 flex-col sm:flex-row">
                        <div class="w-12 h-12 rounded-lg bg-base-200 flex items-center justify-center flex-shrink-0">
                            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                            </svg>
                        </div>
                        <div class="flex-1">
                            <h2 class="text-lg font-semibold">Built in the open</h2>
                            {% if github_stats is not null %}
                                <p class="text-sm text-base-content/70 mt-1">
                                    Every line of Sendvery is public. Last commit
                                    <strong class="text-base-content">{{ github_stats.lastCommitAt|date('M j, Y') }}</strong>{% if github_stats.stars > 0 %}, {{ github_stats.stars|number_format }} GitHub stars{% endif %}.
                                </p>
                                <div class="mt-3 flex flex-wrap gap-2 items-center">
                                    <span class="badge badge-outline badge-sm">AGPL-3.0</span>
                                    <span class="badge badge-outline badge-sm">Self-hostable</span>
                                    <a href="{{ path('about_open_source') }}" class="link link-primary text-sm ml-2">How self-hosting works →</a>
                                </div>
                            {% else %}
                                <p class="text-sm text-base-content/70 mt-1">
                                    Open source on GitHub — repo opens at launch. Read the architecture, audit the data flows, or self-host the whole thing.
                                </p>
                                <div class="mt-3 flex flex-wrap gap-2 items-center">
                                    <span class="badge badge-outline badge-sm">AGPL-3.0</span>
                                    <span class="badge badge-outline badge-sm">Self-hostable</span>
                                    <a href="{{ path('about_open_source') }}" class="link link-primary text-sm ml-2">How self-hosting works →</a>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </twig:SectionContainer>

    {# 7. FOUNDER BLOCKQUOTE #}
    <twig:SectionContainer>
        <div class="max-w-3xl mx-auto">
            <blockquote class="relative">
                <div class="text-5xl text-primary/30 leading-none mb-2" aria-hidden="true">&ldquo;</div>
                <p class="text-xl md:text-2xl text-base-content/90 leading-relaxed italic">
                    I was deleting my DMARC reports for years. They'd arrive as XML attachments from Google and Yahoo, I'd glance at the subject line, and delete them. I had no idea what was in them or whether anything was wrong. Turns out, quite a lot was. I built Sendvery so the next developer doesn't have to feel that uneasy about their own infrastructure.
                </p>
                <footer class="mt-6 flex items-center gap-4">
                    <div class="avatar avatar-placeholder">
                        <div class="bg-primary text-primary-content w-12 rounded-full">
                            <span class="text-base font-semibold">JM</span>
                        </div>
                    </div>
                    <div>
                        <div class="font-semibold">Jan Mikeš</div>
                        <div class="text-sm text-base-content/60">
                            Founder ·
                            <a href="https://github.com/janmikes" target="_blank" rel="noopener" class="link link-hover">GitHub</a>
                        </div>
                    </div>
                </footer>
            </blockquote>
        </div>
    </twig:SectionContainer>

    {# 8. FINAL CTA #}
    <twig:SectionContainer bgClass="bg-primary/10">
        <div class="text-center max-w-2xl mx-auto">
            <h2 class="text-2xl md:text-3xl font-bold">Start monitoring your domain in 60 seconds</h2>
            <p class="mt-4 text-base-content/70">Free tier covers one domain forever. No credit card, no setup wizard, no enterprise sales call.</p>
            <div class="mt-8">
                <a href="{{ path('auth_login') }}" class="btn btn-primary btn-lg">Get started free</a>
            </div>
        </div>
    </twig:SectionContainer>
{% endblock %}
