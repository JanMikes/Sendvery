{% extends 'base.html.twig' %}

{% block title %}Invitation unavailable — Sendvery{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center p-6 bg-base-200">
    <div class="card max-w-md w-full bg-base-100 shadow">
        <div class="card-body text-center">
            <div class="w-16 h-16 mx-auto bg-warning/10 text-warning rounded-full flex items-center justify-center">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <h1 class="text-xl font-bold mt-4">This invitation isn't available</h1>
            <p class="text-base-content/70">{{ reason }}</p>
            <div class="mt-4 flex justify-center gap-2">
                <a href="{{ path('home') }}" class="btn btn-ghost">Back to website</a>
                <a href="{{ path('auth_login') }}" class="btn btn-primary">Sign in</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
