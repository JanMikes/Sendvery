{% extends 'base.html.twig' %}

{% block title %}Wrong account — Sendvery{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center p-6 bg-base-200">
    <div class="card max-w-md w-full bg-base-100 shadow">
        <div class="card-body text-center">
            <div class="w-16 h-16 mx-auto bg-warning/10 text-warning rounded-full flex items-center justify-center">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728L5.636 5.636m12.728 12.728L18.364 5.636M5.636 18.364l12.728-12.728"/>
                </svg>
            </div>
            <h1 class="text-xl font-bold mt-4">Wrong account</h1>
            <p class="text-base-content/70">
                This invitation to join <strong>{{ teamName }}</strong> is for
                <span class="font-mono">{{ invitedEmail }}</span>, but you're signed in as
                <span class="font-mono">{{ currentEmail }}</span>.
            </p>
            <p class="text-sm text-base-content/50 mt-2">
                Sign out, then re-open the invitation link and sign in as the invited address.
            </p>
            <div class="mt-4 flex justify-center gap-2">
                <a href="{{ path('auth_logout') }}" class="btn btn-primary">Sign out and try again</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
