{% extends 'emails/_layout.html.twig' %}
{% import 'emails/_components.html.twig' as ui %}

{% set passRateColor = digest.averagePassRate >= 95
    ? '#16a34a'
    : (digest.averagePassRate >= 80 ? '#d97706' : '#dc2626') %}

{% block subject %}Sendvery weekly report — {{ digest.teamName }}{% endblock %}
{% block preheader %}{{ digest.totalMessages|number_format }} messages · {{ digest.averagePassRate|number_format(1) }}% pass rate · {{ digest.totalDomains }} domain{{ digest.totalDomains != 1 ? 's' : '' }}.{% endblock %}
{% block header_meta %}{{ dateRange }}{% endblock %}

{% block content %}
    {{ ui.pretitle('Weekly report') }}
    {{ ui.heading('How ' ~ digest.teamName|e ~ ' did this week') }}
    {{ ui.muted(dateRange|e) }}

    {# Summary stat tiles #}
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 8px 0 24px 0;">
        <tr>
            <td width="33%" style="padding: 4px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px;">
                    <tr><td style="padding: 16px 12px; text-align: center;">
                        <div style="font-size: 26px; font-weight: 700; color: #0f172a; line-height: 1.1; letter-spacing: -0.02em;">{{ digest.totalMessages|number_format }}</div>
                        <div style="margin-top: 6px; font-size: 11px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.08em;">Messages</div>
                    </td></tr>
                </table>
            </td>
            <td width="33%" style="padding: 4px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px;">
                    <tr><td style="padding: 16px 12px; text-align: center;">
                        <div style="font-size: 26px; font-weight: 700; color: {{ passRateColor }}; line-height: 1.1; letter-spacing: -0.02em;">{{ digest.averagePassRate|number_format(1) }}%</div>
                        <div style="margin-top: 6px; font-size: 11px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.08em;">Pass rate</div>
                    </td></tr>
                </table>
            </td>
            <td width="33%" style="padding: 4px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px;">
                    <tr><td style="padding: 16px 12px; text-align: center;">
                        <div style="font-size: 26px; font-weight: 700; color: #0f172a; line-height: 1.1; letter-spacing: -0.02em;">{{ digest.totalDomains }}</div>
                        <div style="margin-top: 6px; font-size: 11px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.08em;">Domain{{ digest.totalDomains != 1 ? 's' : '' }}</div>
                    </td></tr>
                </table>
            </td>
        </tr>
    </table>

    {# Per-domain breakdown #}
    {% if digest.domains|length > 0 %}
        {{ ui.subheading('Domain breakdown') }}
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 0 0 8px 0; border-collapse: collapse;">
            <tr>
                <td style="padding: 8px 12px; font-size: 11px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.08em; background-color: #f8fafc; border-radius: 8px 0 0 8px;">Domain</td>
                <td style="padding: 8px 12px; font-size: 11px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.08em; background-color: #f8fafc; text-align: right;">Messages</td>
                <td style="padding: 8px 12px; font-size: 11px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.08em; background-color: #f8fafc; text-align: right;">Pass rate</td>
                <td style="padding: 8px 12px; font-size: 11px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.08em; background-color: #f8fafc; text-align: right; border-radius: 0 8px 8px 0;">Δ</td>
            </tr>
            {% for domain in digest.domains %}
                {% set domainColor = domain.passRate >= 95
                    ? '#16a34a'
                    : (domain.passRate >= 80 ? '#d97706' : '#dc2626') %}
                <tr>
                    <td style="padding: 12px; font-size: 13px; color: #0f172a; font-weight: 500; border-bottom: 1px solid #f1f5f9; font-family: 'JetBrains Mono', ui-monospace, Menlo, Consolas, monospace;">{{ domain.domainName }}</td>
                    <td style="padding: 12px; font-size: 13px; color: #475569; text-align: right; border-bottom: 1px solid #f1f5f9;">{{ domain.totalMessages|number_format }}</td>
                    <td style="padding: 12px; font-size: 13px; color: {{ domainColor }}; font-weight: 600; text-align: right; border-bottom: 1px solid #f1f5f9;">{{ domain.passRate|number_format(1) }}%</td>
                    <td style="padding: 12px; font-size: 13px; text-align: right; border-bottom: 1px solid #f1f5f9;">
                        {% if domain.passRateDelta is not null %}
                            <span style="color: {{ domain.passRateDelta >= 0 ? '#16a34a' : '#dc2626' }}; font-weight: 500;">
                                {{ domain.passRateDelta >= 0 ? '+' : '' }}{{ domain.passRateDelta|number_format(1) }}%
                            </span>
                        {% else %}
                            <span style="color: #cbd5e1;">—</span>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </table>
    {% endif %}

    {# Alerts this week #}
    {% if digest.alertsCount > 0 %}
        {{ ui.subheading('Alerts this week <span style="font-weight:400;color:#94a3b8;font-size:13px;">(' ~ digest.alertsCount ~ ')</span>') }}
        {% for domain in digest.domains %}
            {% for alert in domain.alerts %}
                {% set alertPalette = {
                    critical: { bg: '#fef2f2', border: '#dc2626', label: '#991b1b' },
                    warning:  { bg: '#fffbeb', border: '#d97706', label: '#92400e' },
                    info:     { bg: '#eff6ff', border: '#2563eb', label: '#1e3a8a' }
                } %}
                {% set ap = alertPalette[alert.severity] ?? alertPalette.info %}
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 0 0 6px 0;">
                    <tr><td style="padding: 10px 14px; background-color: {{ ap.bg }}; border-left: 3px solid {{ ap.border }}; border-radius: 0 8px 8px 0;">
                        <div style="font-size: 11px; font-weight: 600; color: {{ ap.label }}; text-transform: uppercase; letter-spacing: 0.06em;">{{ domain.domainName }}</div>
                        <div style="margin-top: 2px; font-size: 13px; color: #0f172a;">{{ alert.title }}</div>
                    </td></tr>
                </table>
            {% endfor %}
        {% endfor %}
    {% endif %}

    {# New senders #}
    {% set has_new_senders = false %}
    {% for domain in digest.domains %}
        {% if domain.newSenders|length > 0 %}{% set has_new_senders = true %}{% endif %}
    {% endfor %}
    {% if has_new_senders %}
        {{ ui.subheading('New senders discovered') }}
        {% for domain in digest.domains %}
            {% if domain.newSenders|length > 0 %}
                <p style="margin: 0 0 4px 0; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.06em;">{{ domain.domainName }}</p>
                <p style="margin: 0 0 14px 0; line-height: 1.9;">
                    {% for sender in domain.newSenders %}
                        <span style="display: inline-block; padding: 3px 10px; margin: 2px 4px 2px 0; background-color: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; border-radius: 999px; font-size: 12px; font-family: 'JetBrains Mono', ui-monospace, Menlo, Consolas, monospace;">{{ sender }}</span>
                    {% endfor %}
                </p>
            {% endif %}
        {% endfor %}
    {% endif %}

    {# Currently broken DNS #}
    {% if digest.currentlyBrokenDns|length > 0 %}
        {{ ui.subheading('DNS records still broken') }}
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 0 0 16px 0;">
            <tr><td style="padding: 14px 18px; background-color: #fef2f2; border: 1px solid #fecaca; border-radius: 10px;">
                {% for item in digest.currentlyBrokenDns %}
                    <div style="margin-bottom: {{ loop.last ? '0' : '14px' }};">
                        <div style="font-size: 13px; color: #991b1b; font-weight: 600; margin-bottom: 4px;">
                            {{ item.checkType }} — <span style="font-family:'JetBrains Mono',ui-monospace,Menlo,Consolas,monospace;">{{ item.domainName }}</span>
                        </div>
                        {% for message in item.issueMessages %}
                            <div style="font-size: 12px; color: #7f1d1d; line-height: 1.6;">{{ message }}</div>
                        {% endfor %}
                        <div style="margin-top: 4px; font-size: 11px; color: #b91c1c;">Last checked {{ item.checkedAt|date('M j, H:i') }}</div>
                    </div>
                {% endfor %}
            </td></tr>
        </table>
    {% endif %}

    {# DNS changes #}
    {% if digest.dnsChangesCount > 0 %}
        {{ ui.callout(
            'warning',
            '<strong>' ~ digest.dnsChangesCount ~ '</strong> DNS change' ~ (digest.dnsChangesCount != 1 ? 's' : '') ~ ' detected this week.'
        ) }}
    {% endif %}

    {{ ui.button('View full dashboard', dashboardUrl) }}
{% endblock %}

{% block footer_note %}
    <p style="margin: 0 0 6px 0; font-size: 11px; color: #94a3b8;">
        You can manage your email preferences in your dashboard settings.
    </p>
{% endblock %}
