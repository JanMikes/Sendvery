{% extends 'emails/_layout.html.twig' %}
{% import 'emails/_components.html.twig' as ui %}

{% block subject %}You're now the Owner of {{ teamName }}{% endblock %}
{% block preheader %}{{ previousOwnerEmail }} transferred ownership of {{ teamName }} to you.{% endblock %}

{% block content %}
    {{ ui.pretitle('Ownership received') }}
    {{ ui.heading('You’re now the Owner of ' ~ teamName|e) }}

    {{ ui.lead(
        '<strong style="color:#0f172a;">' ~ previousOwnerEmail|e
        ~ '</strong> transferred ownership of the Sendvery team '
        ~ '<strong style="color:#0f172a;">' ~ teamName|e ~ '</strong> to you.'
    ) }}

    {{ ui.paragraph(
        'As Owner you can invite or remove teammates, change roles, transfer ownership again, and adjust team settings. '
        ~ previousOwnerEmail|e ~ ' is now an Admin on the team — they keep elevated rights but can’t transfer ownership.'
    ) }}

    {{ ui.button('Manage the team', teamSettingsUrl) }}

    {{ ui.callout('warning', 'If you weren’t expecting this transfer, reach out to <strong>' ~ previousOwnerEmail|e ~ '</strong> to sort it out — they triggered the change.') }}
{% endblock %}
