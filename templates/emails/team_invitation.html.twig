{% extends 'emails/_layout.html.twig' %}
{% import 'emails/_components.html.twig' as ui %}

{% block subject %}You're invited to {{ teamName }} on Sendvery{% endblock %}
{% block preheader %}{{ inviterEmail }} invited you to collaborate on DMARC monitoring in {{ teamName }}.{% endblock %}

{% block content %}
    {{ ui.pretitle('Team invitation') }}
    {{ ui.heading('Join ' ~ teamName|e ~ ' on Sendvery') }}

    {{ ui.lead(
        '<strong style="color:#0f172a;">' ~ inviterEmail|e ~ '</strong> invited you to collaborate on DMARC monitoring in their Sendvery team '
        ~ '<strong style="color:#0f172a;">' ~ teamName|e ~ '</strong> as a <strong style="color:#0f172a;">' ~ role|e ~ '</strong>.'
    ) }}

    {{ ui.paragraph('Click below to accept. We’ll sign you in (or create your account) and add you to the team automatically — no password needed.') }}

    {{ ui.button('Accept invitation', acceptUrl) }}

    {{ ui.fineprint(
        'This link expires on <strong style="color:#475569;">' ~ expiresAt|date('Y-m-d') ~ '</strong>. '
        ~ 'If you weren’t expecting this invitation, you can safely ignore the email — your address won’t be added to the team unless you click the link.'
    ) }}
{% endblock %}
