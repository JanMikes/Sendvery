{% extends 'emails/_layout.html.twig' %}
{% import 'emails/_components.html.twig' as ui %}

{% block subject %}Your first DMARC report just arrived{% endblock %}
{% block preheader %}DMARC reports are now flowing for {{ domainName }}. You're officially monitored.{% endblock %}

{% block content %}
    {{ ui.pretitle('You’re all set', '#16a34a') }}
    {{ ui.heading('Your first DMARC report just arrived') }}

    {{ ui.lead(
        'We just received the first DMARC aggregate report for <strong style="color:#0f172a;font-family:\'JetBrains Mono\',ui-monospace,Menlo,Consolas,monospace;">'
        ~ domainName|e
        ~ '</strong>'
        ~ (reporterOrg ? ' from <strong style="color:#0f172a;">' ~ reporterOrg|e ~ '</strong>' : '')
        ~ '.'
    ) }}

    {{ ui.paragraph('That means your DNS is published correctly and email receivers are sending you visibility into what’s happening with your domain. Sendvery is now collecting and parsing these reports for you.') }}

    {{ ui.button('See your report', dashboardUrl) }}

    {{ ui.callout('info', 'Most senders batch DMARC reports daily, so you’ll see more arrive every day from now on. Pass-rate trends become meaningful after about a week of data.') }}
{% endblock %}
