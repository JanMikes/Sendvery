<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Domain ownership claim — {{ inquiry.domain }}</title>
</head>
<body style="margin: 0; padding: 0; background: #f4f4f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background: #f4f4f5; padding: 24px;">
        <tr>
            <td align="center">
                <table width="600" cellpadding="0" cellspacing="0" style="background: #fff; border-radius: 8px; box-shadow: 0 1px 3px rgba(0,0,0,.08);">
                    <tr>
                        <td style="padding: 20px 28px; background: #b45309;">
                            <h1 style="margin: 0; color: #fff; font-size: 18px;">Domain ownership claim</h1>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 24px 28px; font-size: 14px; color: #3f3f46; line-height: 1.6;">
                            <p>A user is asking to claim ownership of a domain another team is monitoring.</p>

                            <table cellpadding="6" cellspacing="0" style="font-size: 14px; margin: 16px 0; border-collapse: collapse;">
                                <tr><td style="color: #71717a;">Domain</td><td><strong>{{ inquiry.domain }}</strong></td></tr>
                                <tr><td style="color: #71717a;">Requested by</td><td>{{ inquiry.inquiringUser.email }}</td></tr>
                                <tr><td style="color: #71717a;">Their team</td><td>{{ inquiry.inquiringTeam.name }} ({{ inquiry.inquiringTeam.id }})</td></tr>
                                <tr><td style="color: #71717a;">Current owner team</td><td>{{ inquiry.currentOwnerTeam.name }} ({{ inquiry.currentOwnerTeam.id }})</td></tr>
                                <tr><td style="color: #71717a;">Submitted</td><td>{{ inquiry.createdAt | date('Y-m-d H:i:s T') }}</td></tr>
                            </table>

                            <p style="font-size: 13px; color: #71717a;">
                                Review the request. If legitimate, transfer ownership in psql:
                            </p>
                            <pre style="background: #f4f4f5; padding: 12px; border-radius: 4px; font-size: 12px; overflow-x: auto;">UPDATE monitored_domain SET team_id = '{{ inquiry.inquiringTeam.id }}'
WHERE LOWER(domain) = LOWER('{{ inquiry.domain }}');</pre>

                            <p style="font-size: 12px; color: #a1a1aa; margin-top: 24px;">
                                Inquiry ID: {{ inquiry.id }}
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
