{% extends 'emails/_layout.html.twig' %}
{% import 'emails/_components.html.twig' as ui %}

{% block subject %}Domain ownership claim — {{ inquiry.domain }}{% endblock %}
{% block preheader %}A user is asking to claim a domain another team is monitoring. Review and decide.{% endblock %}
{% block accent_color %}#b45309{% endblock %}

{% block content %}
    {{ ui.pretitle('Action required', '#b45309') }}
    {{ ui.heading('Domain ownership claim') }}

    {{ ui.paragraph('A user is asking to claim ownership of a domain another team is currently monitoring. Review the request below before taking any action.') }}

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 8px 0 24px 0; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden;">
        <tr><td style="padding: 4px 18px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                {{ ui.detail_row('Domain', '<strong style="color:#0f172a;font-family:\'JetBrains Mono\',ui-monospace,Menlo,Consolas,monospace;">' ~ inquiry.domain|e ~ '</strong>') }}
                {{ ui.detail_row('Requested by', inquiry.inquiringUser.email|e) }}
                {{ ui.detail_row('Their team', inquiry.inquiringTeam.name|e ~ ' <span style="color:#94a3b8;font-family:\'JetBrains Mono\',ui-monospace,Menlo,Consolas,monospace;font-size:12px;">(' ~ inquiry.inquiringTeam.id ~ ')</span>') }}
                {{ ui.detail_row('Current owner', inquiry.currentOwnerTeam.name|e ~ ' <span style="color:#94a3b8;font-family:\'JetBrains Mono\',ui-monospace,Menlo,Consolas,monospace;font-size:12px;">(' ~ inquiry.currentOwnerTeam.id ~ ')</span>') }}
                {{ ui.detail_row('Submitted', inquiry.createdAt|date('Y-m-d H:i:s T'), true) }}
            </table>
        </td></tr>
    </table>

    {{ ui.subheading('If legitimate, transfer ownership in psql:') }}

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 8px 0 16px 0;">
        <tr><td style="padding: 14px 16px; background-color: #0f172a; border-radius: 10px; font-family: 'JetBrains Mono', ui-monospace, Menlo, Consolas, monospace; font-size: 12px; line-height: 1.6; color: #e2e8f0; word-break: break-all;">
            UPDATE monitored_domain SET team_id = '{{ inquiry.inquiringTeam.id }}'<br>
            WHERE LOWER(domain) = LOWER('{{ inquiry.domain }}');
        </td></tr>
    </table>

    {{ ui.fineprint('Inquiry ID: <span style="font-family:\'JetBrains Mono\',ui-monospace,Menlo,Consolas,monospace;">' ~ inquiry.id ~ '</span>') }}
{% endblock %}
