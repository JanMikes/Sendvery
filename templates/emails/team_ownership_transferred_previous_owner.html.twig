{% extends 'emails/_layout.html.twig' %}
{% import 'emails/_components.html.twig' as ui %}

{% block subject %}Ownership of {{ teamName }} has been transferred{% endblock %}
{% block preheader %}You transferred {{ teamName }} to {{ newOwnerEmail }}. You're now an Admin.{% endblock %}
{% block accent_color %}#475569{% endblock %}

{% block content %}
    {{ ui.pretitle('Ownership transferred', '#475569') }}
    {{ ui.heading('Ownership transferred') }}

    {{ ui.lead(
        'You transferred ownership of the Sendvery team <strong style="color:#0f172a;">' ~ teamName|e
        ~ '</strong> to <strong style="color:#0f172a;">' ~ newOwnerEmail|e ~ '</strong>.'
    ) }}

    {{ ui.paragraph('You’re now an Admin on the team. You can still invite and remove teammates, change roles, and manage settings — only ownership transfers and a few owner-only safeguards are off-limits.') }}

    {{ ui.button('Team settings', teamSettingsUrl, '#475569') }}

    {{ ui.callout('danger', '<strong>If this wasn’t you</strong>, contact support immediately so we can investigate and restore your ownership.') }}
{% endblock %}
