<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>New beta access request</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f4f4f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color: #f4f4f5; padding: 40px 20px;">
        <tr>
            <td align="center">
                <table role="presentation" width="560" cellpadding="0" cellspacing="0" style="background-color: #ffffff; border-radius: 12px; overflow: hidden;">
                    <tr>
                        <td style="padding: 32px 40px;">
                            <h1 style="margin: 0 0 8px; font-size: 20px; color: #18181b;">New beta access request</h1>
                            <p style="margin: 0 0 24px; color: #71717a; font-size: 14px;">Plan: <strong>{{ event.requestedPlan.value|capitalize }}</strong></p>

                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="font-size: 14px; color: #18181b;">
                                <tr>
                                    <td style="padding: 8px 0; width: 120px; color: #71717a;">Name</td>
                                    <td style="padding: 8px 0;">{{ event.name }}</td>
                                </tr>
                                <tr>
                                    <td style="padding: 8px 0; color: #71717a;">Email</td>
                                    <td style="padding: 8px 0;"><a href="mailto:{{ event.email }}" style="color: #6366f1;">{{ event.email }}</a></td>
                                </tr>
                                {% if event.company is not null %}
                                <tr>
                                    <td style="padding: 8px 0; color: #71717a;">Company</td>
                                    <td style="padding: 8px 0;">{{ event.company }}</td>
                                </tr>
                                {% endif %}
                                {% if event.domainCount is not null %}
                                <tr>
                                    <td style="padding: 8px 0; color: #71717a;">Domains</td>
                                    <td style="padding: 8px 0;">{{ event.domainCount }}</td>
                                </tr>
                                {% endif %}
                            </table>

                            {% if event.message is not null %}
                                <hr style="border: none; border-top: 1px solid #e4e4e7; margin: 20px 0;">
                                <p style="margin: 0 0 8px; font-size: 13px; font-weight: 600; color: #71717a; text-transform: uppercase; letter-spacing: 0.05em;">Message</p>
                                <p style="margin: 0; white-space: pre-wrap; font-size: 14px; line-height: 1.6; color: #18181b;">{{ event.message }}</p>
                            {% endif %}
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
