{% extends 'emails/_layout.html.twig' %}
{% import 'emails/_components.html.twig' as ui %}

{% set accentMap = {
    critical: '#dc2626',
    warning:  '#d97706',
    info:     '#2563eb'
} %}
{% set pretitleMap = {
    critical: 'Critical alert',
    warning:  'Warning alert',
    info:     'Info alert'
} %}
{% set calloutVariantMap = {
    critical: 'danger',
    warning:  'warning',
    info:     'info'
} %}

{% set accent = accentMap[severity] ?? '#2563eb' %}
{% set pretitle = pretitleMap[severity] ?? 'Alert' %}

{% block subject %}[{{ severity|upper }}] {{ title }}{% endblock %}
{% block preheader %}{{ title }}{% if domainName %} — {{ domainName }}{% endif %}{% endblock %}
{% block accent_color %}{{ accent }}{% endblock %}

{% block content %}
    {{ ui.pretitle(pretitle, accent) }}
    {{ ui.heading(title|e) }}

    {% if domainName %}
        {{ ui.muted('Domain: <strong style="color:#0f172a;font-family:\'JetBrains Mono\',ui-monospace,Menlo,Consolas,monospace;">' ~ domainName|e ~ '</strong>') }}
    {% endif %}

    {{ ui.button('View alert details', alertUrl, accent) }}

    {{ ui.callout(calloutVariantMap[severity] ?? 'info', 'You’re receiving this because alerts for this team are enabled. You can change notification preferences in your dashboard settings.') }}
{% endblock %}
