{% extends 'emails/_layout.html.twig' %}
{% import 'emails/_components.html.twig' as ui %}

{% block subject %}Confirm your Sendvery beta signup{% endblock %}
{% block preheader %}One click to confirm your email and join the Sendvery beta waitlist.{% endblock %}

{% block content %}
    {{ ui.pretitle('Confirm your signup') }}
    {{ ui.heading('Confirm your beta signup') }}

    {{ ui.lead('Thanks for signing up for the Sendvery beta. Please confirm your email address by clicking the button below.') }}

    {{ ui.button('Confirm my email', confirmUrl) }}

    {{ ui.subheading('What happens next?') }}
    {{ ui.muted('We’ll notify you as soon as Sendvery is ready for beta testers. You’ll be among the first to try DMARC report parsing, DNS monitoring, and AI-powered email authentication insights.') }}

    {{ ui.link_fallback(confirmUrl) }}
{% endblock %}
