{% extends 'emails/_layout.html.twig' %}
{% import 'emails/_components.html.twig' as ui %}

{% block subject %}You're invited to the Sendvery beta{% endblock %}
{% block preheader %}Monitor DMARC, track DNS, keep email deliverability healthy — all in one place.{% endblock %}

{% block content %}
    {{ ui.pretitle('Beta invitation') }}
    {{ ui.heading('You’re invited to the Sendvery beta') }}

    {% if invitedByEmail %}
        {{ ui.lead(
            '<strong style="color:#0f172a;">' ~ invitedByEmail|e
            ~ '</strong> has invited you to try Sendvery — the email health and deliverability dashboard.'
        ) }}
    {% else %}
        {{ ui.lead('You’ve been invited to try Sendvery — the email health and deliverability dashboard.') }}
    {% endif %}

    {{ ui.paragraph('Monitor your DMARC reports, track DNS changes, and keep your email deliverability healthy — all in one place.') }}

    {{ ui.button('Accept invitation', acceptUrl) }}

    {{ ui.fineprint('This invitation expires in 7 days.') }}
{% endblock %}
