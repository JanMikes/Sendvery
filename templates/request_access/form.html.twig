{% extends 'marketing_layout.html.twig' %}

{% block title %}Request beta access — Sendvery{% endblock %}
{% block meta_description %}Sendvery hosted plans are in private beta. Request access and we'll get back to you with next steps.{% endblock %}

{% block content %}
<section class="py-24 lg:py-32 bg-gradient-to-br from-base-100 via-base-100 to-primary/5">
    <div class="container mx-auto px-4">
        <div class="max-w-xl mx-auto text-center">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-warning/10 text-warning-content text-sm font-medium mb-8">
                <span class="w-2 h-2 rounded-full bg-warning animate-pulse"></span>
                Private beta
            </div>
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight">
                Request beta access
            </h1>
            <p class="mt-4 text-base-content/60 text-lg">
                Sendvery hosted plans are in private beta. Tell us a bit about your setup and we'll get back to you with next steps.
            </p>
            <p class="mt-2 text-sm text-base-content/50">
                Prefer to self-host? <a href="{{ path('about_open_source') }}" class="link link-primary">Run Sendvery yourself — free, forever</a>.
            </p>
        </div>

        <div class="max-w-xl mx-auto mt-10">
            {% if success %}
                <div class="card bg-base-100 border border-success/30 shadow-sm">
                    <div class="card-body text-center py-12">
                        <div class="w-14 h-14 rounded-full bg-success/10 flex items-center justify-center mx-auto mb-4">
                            <svg class="w-7 h-7 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                        <h2 class="text-xl font-bold">Thanks — request received</h2>
                        <p class="mt-2 text-base-content/60">We'll get back to you at <span class="font-medium">{{ data.email }}</span> shortly. Check your inbox for a confirmation email.</p>
                        <div class="mt-6">
                            <a href="{{ path('home') }}" class="btn btn-outline btn-sm">Back to home</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <form method="post" action="{{ path('request_beta_access') }}" class="card bg-base-100 border border-base-200 shadow-sm">
                    <div class="card-body space-y-4">
                        {% if errors|length > 0 %}
                            <div class="alert alert-error">
                                <ul class="text-sm list-disc list-inside">
                                    {% for error in errors %}
                                        <li>{{ error }}</li>
                                    {% endfor %}
                                </ul>
                            </div>
                        {% endif %}

                        <input type="hidden" name="source" value="{{ source }}">

                        <div class="form-control">
                            <label class="label" for="name">
                                <span class="label-text font-medium">Your name <span class="text-error">*</span></span>
                            </label>
                            <input type="text" id="name" name="name" required maxlength="255"
                                   value="{{ data.name }}"
                                   class="input input-bordered w-full">
                        </div>

                        <div class="form-control">
                            <label class="label" for="email">
                                <span class="label-text font-medium">Work email <span class="text-error">*</span></span>
                            </label>
                            <input type="email" id="email" name="email" required maxlength="255"
                                   value="{{ data.email }}"
                                   class="input input-bordered w-full">
                        </div>

                        <div class="form-control">
                            <label class="label" for="company">
                                <span class="label-text font-medium">Company <span class="text-base-content/50 text-xs">(optional)</span></span>
                            </label>
                            <input type="text" id="company" name="company" maxlength="255"
                                   value="{{ data.company ?? '' }}"
                                   class="input input-bordered w-full">
                        </div>

                        <div class="form-control">
                            <label class="label" for="plan">
                                <span class="label-text font-medium">Plan you're interested in</span>
                            </label>
                            <select id="plan" name="plan" class="select select-bordered w-full">
                                {% for plan in plans %}
                                    {% if plan.value != 'free' %}
                                        <option value="{{ plan.value }}" {{ data.requestedPlan == plan ? 'selected' : '' }}>
                                            {{ plan.value|capitalize }}
                                        </option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                        </div>

                        <div class="form-control">
                            <label class="label" for="domain_count">
                                <span class="label-text font-medium">How many domains do you need to monitor? <span class="text-base-content/50 text-xs">(optional)</span></span>
                            </label>
                            <input type="number" id="domain_count" name="domain_count" min="1" max="10000"
                                   value="{{ data.domainCount ?? '' }}"
                                   class="input input-bordered w-full">
                        </div>

                        <div class="form-control">
                            <label class="label" for="message">
                                <span class="label-text font-medium">Anything we should know? <span class="text-base-content/50 text-xs">(optional)</span></span>
                            </label>
                            <textarea id="message" name="message" rows="4" maxlength="2000"
                                      class="textarea textarea-bordered w-full"
                                      placeholder="Current setup, what you'd like to solve, timing...">{{ data.message ?? '' }}</textarea>
                        </div>

                        <button type="submit" class="btn btn-primary w-full">Request access</button>

                        <p class="text-xs text-base-content/50 text-center">
                            By submitting you agree we may contact you about Sendvery beta access. No spam, ever.
                        </p>
                    </div>
                </form>
            {% endif %}
        </div>
    </div>
</section>
{% endblock %}
