<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: Helvetica, Arial, sans-serif; font-size: 12px; color: #1a1a1a; line-height: 1.5; margin: 30px; }
        h1 { font-size: 24px; color: #6366f1; margin-bottom: 4px; }
        h2 { font-size: 16px; color: #374151; margin-top: 24px; margin-bottom: 8px; border-bottom: 1px solid #e5e7eb; padding-bottom: 4px; }
        .subtitle { font-size: 12px; color: #6b7280; margin-bottom: 20px; }
        .grade-box { display: inline-block; font-size: 48px; font-weight: bold; padding: 8px 20px; border-radius: 8px; margin-right: 16px; }
        .grade-a { color: #22c55e; background: #f0fdf4; }
        .grade-b { color: #3b82f6; background: #eff6ff; }
        .grade-c { color: #f59e0b; background: #fffbeb; }
        .grade-d, .grade-f { color: #ef4444; background: #fef2f2; }
        .score-text { font-size: 20px; font-weight: bold; }
        table { width: 100%; border-collapse: collapse; margin-top: 8px; }
        th, td { padding: 6px 8px; text-align: left; border-bottom: 1px solid #e5e7eb; font-size: 11px; }
        th { background: #f9fafb; font-weight: 600; }
        .stat-row { display: flex; justify-content: space-between; padding: 4px 0; }
        .stat-label { color: #6b7280; }
        .stat-value { font-weight: 600; }
        .footer { margin-top: 30px; padding-top: 10px; border-top: 1px solid #e5e7eb; font-size: 10px; color: #9ca3af; text-align: center; }
        .pass { color: #22c55e; }
        .fail { color: #ef4444; }
    </style>
</head>
<body>
    <h1>Sendvery Domain Report</h1>
    <p class="subtitle">{{ domain.domainName }} &mdash; Generated {{ generatedAt|date('F j, Y') }}</p>

    {% if healthSnapshot %}
        <h2>Health Score</h2>
        <div style="margin-bottom: 16px;">
            <span class="grade-box grade-{{ healthSnapshot.grade|lower }}">{{ healthSnapshot.grade }}</span>
            <span class="score-text">{{ healthSnapshot.score }}/100</span>
        </div>
        <table>
            <tr><th>Category</th><th>Score</th></tr>
            <tr><td>SPF</td><td>{{ healthSnapshot.spfScore }}%</td></tr>
            <tr><td>DKIM</td><td>{{ healthSnapshot.dkimScore }}%</td></tr>
            <tr><td>DMARC</td><td>{{ healthSnapshot.dmarcScore }}%</td></tr>
            <tr><td>MX</td><td>{{ healthSnapshot.mxScore }}%</td></tr>
            <tr><td>Blacklist</td><td>{{ healthSnapshot.blacklistScore }}%</td></tr>
        </table>
    {% endif %}

    {% if reportData %}
        <h2>DMARC Summary</h2>
        <table>
            <tr><td class="stat-label">Total Reports</td><td class="stat-value">{{ reportData.total_reports }}</td></tr>
            <tr><td class="stat-label">Total Messages</td><td class="stat-value">{{ reportData.total_messages|number_format(0, '.', ',') }}</td></tr>
            <tr><td class="stat-label">Pass Rate</td><td class="stat-value {{ reportData.pass_rate >= 90 ? 'pass' : 'fail' }}">{{ reportData.pass_rate|number_format(1) }}%</td></tr>
            <tr><td class="stat-label">Known Senders</td><td class="stat-value">{{ reportData.total_senders }} ({{ reportData.authorized_senders }} authorized)</td></tr>
            <tr><td class="stat-label">Blacklisted IPs (7d)</td><td class="stat-value {{ reportData.blacklisted_ips > 0 ? 'fail' : 'pass' }}">{{ reportData.blacklisted_ips }}</td></tr>
        </table>
    {% endif %}

    {% if senders is not empty %}
        <h2>Top Senders</h2>
        <table>
            <thead>
                <tr><th>IP</th><th>Hostname</th><th>Organization</th><th>Messages</th><th>Pass Rate</th><th>Status</th></tr>
            </thead>
            <tbody>
                {% for sender in senders %}
                    <tr>
                        <td>{{ sender.sourceIp }}</td>
                        <td>{{ sender.hostname ?? '-' }}</td>
                        <td>{{ sender.organization ?? '-' }}</td>
                        <td>{{ sender.totalMessages|number_format(0, '.', ',') }}</td>
                        <td class="{{ sender.passRate >= 90 ? 'pass' : 'fail' }}">{{ sender.passRate|number_format(1) }}%</td>
                        <td>{{ sender.isAuthorized ? 'Authorized' : 'Unknown' }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}

    <div class="footer">
        Generated by Sendvery &mdash; sendvery.com &mdash; {{ generatedAt|date('Y-m-d H:i:s T') }}
    </div>
</body>
</html>
