{% extends 'onboarding/layout.html.twig' %}

{% set step = 4 %}

{% block page_title %}Setup complete{% endblock %}

{% block content %}
<div class="card bg-base-100 shadow-xl">
    <div class="card-body text-center">
        <div class="flex justify-center mb-4">
            <svg class="w-20 h-20 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>

        <h2 class="text-2xl font-bold mb-2">You're all set!</h2>
        <p class="text-base-content/60 mb-6">
            Your account is ready. Head to your dashboard to start monitoring.
        </p>

        <a href="{{ path('dashboard_overview') }}" class="btn btn-primary w-full">
            Go to dashboard
        </a>
    </div>
</div>
{% endblock %}
