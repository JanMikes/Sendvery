{% extends 'onboarding/layout.html.twig' %}

{% set step = 4 %}

{% block page_title %}Setup complete{% endblock %}

{% block content %}
<div class="space-y-6">
    {% if status is not null and severity is not null and severity.value != 'ok' %}
        {% set isCritical = severity.value == 'critical' %}
        <div class="rounded-2xl border p-5 sm:p-6 {{ isCritical ? 'bg-error/5 border-error/30' : 'bg-warning/5 border-warning/30' }}">
            <div class="flex items-start gap-3">
                <div class="w-9 h-9 rounded-full flex items-center justify-center shrink-0 {{ isCritical ? 'bg-error/15 text-error' : 'bg-warning/15 text-warning' }}">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M5.07 19h13.86c1.54 0 2.5-1.67 1.73-2.5L13.73 4a2 2 0 00-3.46 0L3.34 16.5c-.77.83.19 2.5 1.73 2.5z"/>
                    </svg>
                </div>
                <div class="flex-1">
                    {% if status.dmarcVerifiedAt is null %}
                        <div class="font-semibold text-base-content mb-1">DMARC record not detected yet</div>
                        <p class="text-sm text-base-content/70">
                            We couldn't find a DMARC TXT record for <span class="font-mono">{{ status.domainName }}</span>. You can still finish onboarding — once you publish the record, the daily check will pick it up. If you just published it, DNS can take a few minutes to propagate.
                        </p>
                    {% elseif not status.dmarcCurrentlyValid %}
                        <div class="font-semibold text-base-content mb-1">DMARC record changed</div>
                        <p class="text-sm text-base-content/70">
                            We saw a valid DMARC record for <span class="font-mono">{{ status.domainName }}</span> before, but the latest check couldn't find one. Verify the TXT record is still published.
                        </p>
                    {% else %}
                        <div class="font-semibold text-base-content mb-1">No reports yet</div>
                        <p class="text-sm text-base-content/70">
                            DMARC is published for <span class="font-mono">{{ status.domainName }}</span> but no reports have arrived. Most senders batch reports daily — if you don't see anything by tomorrow, double-check that the <code class="kbd kbd-xs">rua</code> tag points at <span class="font-mono">reports@sendvery.com</span>.
                        </p>
                    {% endif %}
                </div>
            </div>
        </div>
    {% endif %}

    <div class="card bg-base-100 shadow-xl border border-base-200">
        <div class="card-body p-8 sm:p-10 text-center">
            <div class="flex justify-center mb-6">
                <div class="relative">
                    <div class="absolute inset-0 bg-success/20 rounded-full blur-2xl"></div>
                    <div class="relative w-20 h-20 rounded-full bg-success/15 flex items-center justify-center ring-8 ring-success/5">
                        <svg class="w-10 h-10 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                    </div>
                </div>
            </div>

            <h1 class="text-3xl sm:text-4xl font-bold mb-3">You're all set! 🎉</h1>
            <p class="text-base-content/60 max-w-md mx-auto mb-8">
                Sendvery is now watching your domain. Here's what happens next.
            </p>

            {# What happens next — clear timeline #}
            <div class="text-left max-w-md mx-auto space-y-4 mb-8">
                <div class="flex items-start gap-3">
                    <div class="w-8 h-8 rounded-full bg-primary/10 text-primary flex items-center justify-center shrink-0 font-semibold text-sm">1</div>
                    <div>
                        <div class="font-semibold text-base-content">Reports start arriving</div>
                        <p class="text-sm text-base-content/60">First DMARC reports typically land within 24 hours — sometimes within minutes if you have high volume.</p>
                    </div>
                </div>
                <div class="flex items-start gap-3">
                    <div class="w-8 h-8 rounded-full bg-primary/10 text-primary flex items-center justify-center shrink-0 font-semibold text-sm">2</div>
                    <div>
                        <div class="font-semibold text-base-content">We parse and analyze</div>
                        <p class="text-sm text-base-content/60">Every report is parsed automatically. You'll see charts, sources, and pass/fail rates in your dashboard.</p>
                    </div>
                </div>
                <div class="flex items-start gap-3">
                    <div class="w-8 h-8 rounded-full bg-primary/10 text-primary flex items-center justify-center shrink-0 font-semibold text-sm">3</div>
                    <div>
                        <div class="font-semibold text-base-content">You get alerts when it matters</div>
                        <p class="text-sm text-base-content/60">We'll email you on real problems — drops in authentication, suspicious senders, or expiring records.</p>
                    </div>
                </div>
            </div>

            <a href="{{ path('dashboard_overview') }}" class="btn btn-primary w-full gap-2">
                Go to dashboard
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                </svg>
            </a>
        </div>
    </div>

    <p class="text-center text-sm text-base-content/50">
        Need a hand? Check the <a href="{{ path('knowledge_base_index') }}" class="link link-primary">knowledge base</a> — it's full of guides.
    </p>
</div>
{% endblock %}
