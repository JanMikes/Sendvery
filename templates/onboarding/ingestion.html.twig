{% extends 'onboarding/layout.html.twig' %}

{% set step = 3 %}

{% block page_title %}Connect reports{% endblock %}

{% block content %}
<div class="space-y-6">
    {# Intro #}
    <div class="text-center">
        <h1 class="text-3xl sm:text-4xl font-bold text-base-content mb-2">Get your DMARC reports flowing</h1>
        <p class="text-base-content/60 max-w-xl mx-auto">
            Every day, mail providers like Google and Microsoft send XML reports describing who tried to send email as you. We turn those reports into clear charts and alerts.
        </p>
    </div>

    {% if errors|length > 0 %}
        <div class="alert alert-error rounded-xl">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.072 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            <div>
                {% for error in errors %}
                    <p>{{ error }}</p>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# Option 1: Forward reports #}
    <div class="card bg-base-100 shadow-xl border border-base-200">
        <div class="card-body p-6 sm:p-8">
            <div class="flex items-start gap-4 mb-4">
                <div class="w-12 h-12 rounded-2xl bg-primary/10 text-primary flex items-center justify-center shrink-0">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap mb-1">
                        <h2 class="text-xl font-bold">Forward reports to us</h2>
                        <span class="badge badge-primary badge-sm">Recommended</span>
                    </div>
                    <p class="text-sm text-base-content/60">
                        Easiest setup. Add one line to your DMARC DNS record and reports start flowing in within 24 hours.
                    </p>
                </div>
            </div>

            <div class="bg-base-200/60 rounded-xl p-4 mb-4">
                <div class="text-xs uppercase tracking-wide font-semibold text-base-content/50 mb-2">Add to your DMARC record</div>
                <div class="mockup-code text-sm rounded-lg">
                    <pre data-prefix="$"><code>rua=mailto:reports@sendvery.com</code></pre>
                </div>
            </div>

            <form method="post" action="{{ path('onboarding_ingestion') }}">
                <input type="hidden" name="method" value="forward">
                <button type="submit" class="btn btn-primary w-full gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    I've updated my DMARC record
                </button>
            </form>
        </div>
    </div>

    {# Divider #}
    <div class="flex items-center gap-3 text-xs uppercase tracking-wide text-base-content/40">
        <div class="flex-1 h-px bg-base-300"></div>
        <span>or</span>
        <div class="flex-1 h-px bg-base-300"></div>
    </div>

    {# Option 2: Connect mailbox #}
    <div class="card bg-base-100 shadow-xl border border-base-200">
        <div class="card-body p-6 sm:p-8">
            <details class="group">
                <summary class="cursor-pointer list-none">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-2xl bg-secondary/10 text-secondary flex items-center justify-center shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"/>
                            </svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <h2 class="text-xl font-bold mb-1">Connect a mailbox via IMAP</h2>
                            <p class="text-sm text-base-content/60">
                                Already receive DMARC reports in a mailbox? Connect it and we'll fetch them automatically every 15 minutes.
                            </p>
                        </div>
                        <svg class="w-5 h-5 text-base-content/40 shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </div>
                </summary>

                <form method="post" action="{{ path('onboarding_ingestion') }}" class="mt-6 pt-6 border-t border-base-200">
                    <input type="hidden" name="method" value="mailbox">

                    <div class="grid grid-cols-3 gap-3 mb-3">
                        <div class="form-control col-span-2">
                            <label class="label pb-1"><span class="label-text text-sm font-medium">Host</span></label>
                            <input type="text" name="host" placeholder="imap.example.com" class="input input-bordered w-full font-mono text-sm">
                        </div>
                        <div class="form-control col-span-1">
                            <label class="label pb-1"><span class="label-text text-sm font-medium">Port</span></label>
                            <input type="number" name="port" value="993" class="input input-bordered w-full font-mono text-sm">
                        </div>
                    </div>

                    <div class="form-control mb-3">
                        <label class="label pb-1"><span class="label-text text-sm font-medium">Username</span></label>
                        <input type="text" name="username" placeholder="dmarc@example.com" class="input input-bordered w-full text-sm">
                    </div>

                    <div class="form-control mb-3">
                        <label class="label pb-1"><span class="label-text text-sm font-medium">Password</span></label>
                        <input type="password" name="password" class="input input-bordered w-full text-sm">
                    </div>

                    <div class="form-control mb-4">
                        <label class="label pb-1"><span class="label-text text-sm font-medium">Encryption</span></label>
                        <select name="encryption" class="select select-bordered w-full text-sm">
                            <option value="ssl">SSL (recommended)</option>
                            <option value="tls">TLS</option>
                            <option value="none">None</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-secondary w-full gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                        </svg>
                        Connect mailbox &amp; finish
                    </button>
                    <p class="text-xs text-base-content/50 text-center mt-3">
                        Credentials are encrypted at rest. You can disconnect any time.
                    </p>
                </form>
            </details>
        </div>
    </div>

    <div class="text-center">
        <a href="{{ path('onboarding_complete') }}" class="link link-hover text-sm text-base-content/50">Skip — I'll set this up later</a>
    </div>
</div>
{% endblock %}
