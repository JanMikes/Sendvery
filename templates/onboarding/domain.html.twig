{% extends 'onboarding/layout.html.twig' %}

{% set step = 2 %}

{% block page_title %}Add domain{% endblock %}

{% block content %}
<div class="space-y-6">
    {# Intro #}
    <div class="text-center">
        <h1 class="text-3xl sm:text-4xl font-bold text-base-content mb-2">Add your first domain</h1>
        <p class="text-base-content/60 max-w-md mx-auto">
            This is the domain you send email from — like <span class="font-mono text-base-content/80">acme.com</span>. We'll instantly inspect its DNS records.
        </p>
    </div>

    {# Why this matters — small explainer #}
    <div class="bg-info/5 border border-info/20 rounded-2xl p-4 sm:p-5">
        <div class="flex items-start gap-3">
            <div class="w-9 h-9 rounded-full bg-info/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-info" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <div class="text-sm leading-relaxed">
                <div class="font-semibold text-base-content mb-1">Why we check DNS</div>
                <p class="text-base-content/70">
                    <strong class="font-semibold">SPF</strong>, <strong class="font-semibold">DKIM</strong>, and <strong class="font-semibold">DMARC</strong> are three DNS records that prove your emails are really from you. Without them, spammers can impersonate your domain and your real emails land in spam.
                </p>
            </div>
        </div>
    </div>

    <div class="card bg-base-100 shadow-xl border border-base-200">
        <div class="card-body p-6 sm:p-8">
            {% if errors|length > 0 %}
                <div class="alert alert-error mb-4 rounded-xl">
                    <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.072 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                    <div>
                        {% for error in errors %}
                            <p>{{ error }}</p>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            <form method="post" action="{{ path('onboarding_domain') }}">
                <div class="form-control">
                    <label class="label pb-2" for="domain_name">
                        <span class="label-text font-semibold">Domain name</span>
                    </label>
                    <input type="text"
                           id="domain_name"
                           name="domain_name"
                           value="{{ data.domainName }}"
                           placeholder="example.com"
                           class="input input-bordered w-full text-base font-mono"
                           required
                           autofocus>
                </div>

                {% if dnsResults is not null %}
                    <div class="mt-6 pt-6 border-t border-base-200">
                        <div class="flex items-center justify-between mb-3">
                            <h3 class="font-semibold text-base">DNS check results</h3>
                            <span class="text-xs text-base-content/50">Live lookup</span>
                        </div>

                        <div class="space-y-2">
                            {# SPF #}
                            <div class="flex items-start gap-3 p-3 rounded-xl border {{ dnsResults.spf.rawRecord ? 'bg-success/5 border-success/20' : 'bg-warning/5 border-warning/20' }}">
                                <div class="w-7 h-7 rounded-full flex items-center justify-center shrink-0 {{ dnsResults.spf.rawRecord ? 'bg-success/15 text-success' : 'bg-warning/15 text-warning' }}">
                                    {% if dnsResults.spf.rawRecord %}
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                                    {% else %}
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M5.07 19h13.86c1.54 0 2.5-1.67 1.73-2.5L13.73 4a2 2 0 00-3.46 0L3.34 16.5c-.77.83.19 2.5 1.73 2.5z"/></svg>
                                    {% endif %}
                                </div>
                                <div class="min-w-0 flex-1">
                                    <div class="flex items-center gap-2 flex-wrap">
                                        <span class="font-semibold text-sm">SPF</span>
                                        <span class="text-xs text-base-content/50">Sender Policy Framework</span>
                                    </div>
                                    <div class="text-sm {{ dnsResults.spf.rawRecord ? 'text-success' : 'text-warning' }}">
                                        {{ dnsResults.spf.rawRecord ? 'Record found' : 'No record found' }}
                                    </div>
                                </div>
                            </div>

                            {# DKIM #}
                            <div class="flex items-start gap-3 p-3 rounded-xl border {{ dnsResults.dkim.keyExists ? 'bg-success/5 border-success/20' : 'bg-warning/5 border-warning/20' }}">
                                <div class="w-7 h-7 rounded-full flex items-center justify-center shrink-0 {{ dnsResults.dkim.keyExists ? 'bg-success/15 text-success' : 'bg-warning/15 text-warning' }}">
                                    {% if dnsResults.dkim.keyExists %}
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                                    {% else %}
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M5.07 19h13.86c1.54 0 2.5-1.67 1.73-2.5L13.73 4a2 2 0 00-3.46 0L3.34 16.5c-.77.83.19 2.5 1.73 2.5z"/></svg>
                                    {% endif %}
                                </div>
                                <div class="min-w-0 flex-1">
                                    <div class="flex items-center gap-2 flex-wrap">
                                        <span class="font-semibold text-sm">DKIM</span>
                                        <span class="text-xs text-base-content/50">DomainKeys Identified Mail</span>
                                    </div>
                                    <div class="text-sm {{ dnsResults.dkim.keyExists ? 'text-success' : 'text-warning' }}">
                                        {{ dnsResults.dkim.keyExists ? 'Record found' : 'No record found (normal — uses provider-specific selectors)' }}
                                    </div>
                                </div>
                            </div>

                            {# DMARC #}
                            <div class="flex items-start gap-3 p-3 rounded-xl border {{ dnsResults.dmarc.rawRecord ? 'bg-success/5 border-success/20' : 'bg-error/5 border-error/20' }}">
                                <div class="w-7 h-7 rounded-full flex items-center justify-center shrink-0 {{ dnsResults.dmarc.rawRecord ? 'bg-success/15 text-success' : 'bg-error/15 text-error' }}">
                                    {% if dnsResults.dmarc.rawRecord %}
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                                    {% else %}
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                                    {% endif %}
                                </div>
                                <div class="min-w-0 flex-1">
                                    <div class="flex items-center gap-2 flex-wrap">
                                        <span class="font-semibold text-sm">DMARC</span>
                                        <span class="text-xs text-base-content/50">Reporting & policy</span>
                                    </div>
                                    <div class="text-sm {{ dnsResults.dmarc.rawRecord ? 'text-success' : 'text-error' }}">
                                        {% if dnsResults.dmarc.rawRecord %}
                                            Record found <span class="opacity-70">— policy:</span> <span class="font-mono">{{ dnsResults.dmarc.policy }}</span>
                                        {% else %}
                                            No record found — we'll help you set one up
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <a href="{{ path('onboarding_ingestion', {domain: data.domainName}) }}" class="btn btn-primary w-full mt-6 gap-2">
                        Continue
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                        </svg>
                    </a>
                {% else %}
                    <button type="submit" class="btn btn-primary w-full mt-6 gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                        Add domain &amp; check DNS
                    </button>
                {% endif %}
            </form>

            <div class="text-center mt-4">
                <a href="{{ path('onboarding_ingestion') }}" class="link link-hover text-sm text-base-content/50">Skip for now</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
