{% extends 'onboarding/layout.html.twig' %}

{% set step = 1 %}

{% block page_title %}Team setup{% endblock %}

{% block content %}
<div class="space-y-6">
    {# Intro header — outside card, larger and warmer #}
    <div class="text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-semibold mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
            Takes about 2 minutes
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-base-content mb-2">Welcome to Sendvery 👋</h1>
        <p class="text-base-content/60 max-w-md mx-auto">
            Let's get your email monitoring set up. We'll start with the basics — no credit card, no commitments.
        </p>
    </div>

    <div class="card bg-base-100 shadow-xl border border-base-200">
        <div class="card-body p-6 sm:p-8">
            <h2 class="text-xl font-bold mb-1">Name your team</h2>
            <p class="text-base-content/60 text-sm mb-6">
                A team is your workspace inside Sendvery. You'll be able to invite teammates later to share alerts and reports.
            </p>

            <form method="post" action="{{ path('onboarding_team') }}">
                <div class="form-control">
                    <label class="label pb-2" for="team_name">
                        <span class="label-text font-semibold">Team name</span>
                    </label>
                    <input type="text"
                           id="team_name"
                           name="team_name"
                           value="{{ suggestedName }}"
                           placeholder="Acme Inc."
                           class="input input-bordered w-full text-base"
                           required
                           autofocus>
                    <label class="label pt-2">
                        <span class="label-text-alt text-base-content/50">
                            Tip: use your company name. You can rename this any time from settings.
                        </span>
                    </label>
                </div>

                <button type="submit" class="btn btn-primary w-full mt-6 gap-2">
                    Continue
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                    </svg>
                </button>
            </form>
        </div>
    </div>

    {# Reassurance row — what they get #}
    <div class="grid sm:grid-cols-3 gap-3 text-sm">
        <div class="flex items-start gap-2 text-base-content/60">
            <svg class="w-5 h-5 text-success shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Free forever, self-hosted
        </div>
        <div class="flex items-start gap-2 text-base-content/60">
            <svg class="w-5 h-5 text-success shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Open source (AGPL-3.0)
        </div>
        <div class="flex items-start gap-2 text-base-content/60">
            <svg class="w-5 h-5 text-success shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Your data stays yours
        </div>
    </div>
</div>
{% endblock %}
