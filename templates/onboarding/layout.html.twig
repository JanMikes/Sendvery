{% extends 'base.html.twig' %}

{% block title %}{% block page_title %}Setup{% endblock %} — Sendvery{% endblock %}

{% block body %}
<div class="min-h-screen bg-base-200 flex flex-col">
    {# Header #}
    <header class="bg-base-100 border-b border-base-200">
        <div class="container mx-auto px-4 py-4 flex items-center justify-between">
            <a href="{{ path('home') }}" class="text-xl font-bold text-primary tracking-tight">Sendvery</a>
            <span class="text-sm text-base-content/50">{{ app.user.email }}</span>
        </div>
    </header>

    {# Progress steps #}
    <div class="container mx-auto px-4 py-6">
        <ul class="steps steps-horizontal w-full max-w-lg mx-auto">
            <li class="step {{ step >= 1 ? 'step-primary' : '' }}">Team</li>
            <li class="step {{ step >= 2 ? 'step-primary' : '' }}">Domain</li>
            <li class="step {{ step >= 3 ? 'step-primary' : '' }}">Ingestion</li>
            <li class="step {{ step >= 4 ? 'step-primary' : '' }}">Done</li>
        </ul>
    </div>

    {# Content #}
    <div class="flex-1 flex items-start justify-center px-4 pb-12">
        <div class="w-full max-w-lg">
            {% block content %}{% endblock %}
        </div>
    </div>
</div>
{% endblock %}
