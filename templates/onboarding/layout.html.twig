{% extends 'base.html.twig' %}

{% block title %}{% block page_title %}Setup{% endblock %} — Sendvery{% endblock %}

{% set steps_data = [
    { num: 1, label: 'Team',    desc: 'Name your workspace' },
    { num: 2, label: 'Domain',  desc: 'Add what to monitor' },
    { num: 3, label: 'Reports', desc: 'Connect your data' },
    { num: 4, label: 'Done',    desc: 'Start monitoring' },
] %}

{% block body %}
<div class="min-h-screen bg-gradient-to-b from-base-200 to-base-100 flex flex-col">
    {# Header #}
    <header class="bg-base-100/80 backdrop-blur border-b border-base-200">
        <div class="container mx-auto px-4 py-4 flex items-center justify-between">
            <a href="{{ path('home') }}" class="text-xl font-bold text-primary tracking-tight">Sendvery</a>
            <div class="flex items-center gap-3 text-sm">
                <span class="text-base-content/50 hidden sm:inline">Signed in as</span>
                <span class="text-base-content/70 font-medium">{{ app.user.email }}</span>
            </div>
        </div>
    </header>

    {# Progress steps — custom stepper that spans the content width #}
    <div class="container mx-auto px-4 pt-10 pb-2">
        <div class="w-full max-w-2xl mx-auto">
            <ol class="relative flex justify-between">
                {# Background track #}
                <div class="absolute top-5 left-5 right-5 h-[3px] bg-base-300 rounded-full"></div>

                {# Progress fill (driven by `step` variable) #}
                <div class="absolute top-5 left-5 h-[3px] bg-primary rounded-full transition-all duration-500"
                     style="width: calc((100% - 2.5rem) * {{ ((step - 1) / 3) }});"></div>

                {% for s in steps_data %}
                    <li class="relative flex flex-col items-center gap-2 z-10 flex-1">
                        {% if step > s.num %}
                            {# Completed #}
                            <div class="w-10 h-10 rounded-full bg-primary text-primary-content flex items-center justify-center shadow-sm ring-4 ring-base-200">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                                </svg>
                            </div>
                        {% elseif step == s.num %}
                            {# Current — pulsing ring for emphasis #}
                            <div class="w-10 h-10 rounded-full bg-primary text-primary-content flex items-center justify-center shadow-md ring-4 ring-primary/20 font-semibold text-sm">
                                {{ s.num }}
                            </div>
                        {% else %}
                            {# Upcoming #}
                            <div class="w-10 h-10 rounded-full bg-base-100 border-2 border-base-300 text-base-content/40 flex items-center justify-center font-semibold text-sm ring-4 ring-base-200">
                                {{ s.num }}
                            </div>
                        {% endif %}

                        <div class="text-center mt-1">
                            <div class="text-sm font-semibold {{ step >= s.num ? 'text-base-content' : 'text-base-content/40' }}">
                                {{ s.label }}
                            </div>
                            <div class="text-xs text-base-content/50 hidden sm:block mt-0.5">{{ s.desc }}</div>
                        </div>
                    </li>
                {% endfor %}
            </ol>
        </div>
    </div>

    {# Content #}
    <div class="flex-1 flex items-start justify-center px-4 pt-8 pb-16">
        <div class="w-full max-w-2xl">
            {% block content %}{% endblock %}
        </div>
    </div>
</div>
{% endblock %}
