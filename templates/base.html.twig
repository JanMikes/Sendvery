<!DOCTYPE html>
<html lang="en" data-theme="sendvery">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Sendvery{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}Sendvery — Email health & deliverability monitoring. Free DMARC, SPF, DKIM checker tools. AI-powered insights. Open source.{% endblock %}">
    {# TASK-142: canonical + og:url derive from the matched ROUTE name (no query string),
       so /tools/spf-checker?domain=foo.com and /tools/spf-checker canonicalize to the same URL.
       The fallback to app.request.uri keeps the link working for routes that don't expose a name. #}
    {% set _canonical_route = app.request.attributes.get('_route') %}
    {% set _canonical_url = _canonical_route ? url(_canonical_route, app.request.attributes.get('_route_params')|default([])) : app.request.uri %}
    <link rel="canonical" href="{% block canonical %}{{ _canonical_url }}{% endblock %}">
    {# TASK-142: pages that add no organic search value (auth, dashboard, legal noise pages)
       override this block with noindex,follow so they don't compete for ranking signal. #}
    {% block robots %}{% endblock %}

    {# Favicon / app-icon set — served from the public/ web root (not AssetMapper),
       so use root-absolute paths. Generated from assets/logo via rsvg + pngquant/oxipng
       (white envelope-pulse mark on the teal brand tile). SVG for modern browsers, ICO
       for legacy, PNG fallbacks, apple-touch for iOS home-screen, web manifest for
       Android/PWA (incl. maskable), mask-icon for Safari pinned tabs, msapplication for
       Windows tiles. theme-color tints the mobile browser chrome with the brand teal. #}
    <link rel="icon" href="/favicon.ico" sizes="32x32">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png">
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png">
    <link rel="icon" href="/favicon-96x96.png" sizes="96x96" type="image/png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180">
    <link rel="mask-icon" href="/mask-icon.svg" color="#0f766e">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="#0f766e">
    <meta name="msapplication-TileColor" content="#0f766e">
    <meta name="msapplication-config" content="/browserconfig.xml">

    <meta property="og:title" content="{% block og_title %}{{ block('title') }}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ block('meta_description') }}{% endblock %}">
    <meta property="og:type" content="{% block og_type %}website{% endblock %}">
    <meta property="og:url" content="{{ _canonical_url }}">
    <meta property="og:site_name" content="Sendvery">
    <meta property="og:image" content="{% block og_image %}{{ absolute_url(asset('images/og-default.webp')) }}{% endblock %}">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ block('og_title') }}">
    <meta name="twitter:description" content="{{ block('og_description') }}">
    <meta name="twitter:image" content="{{ block('og_image') }}">

    {% block structured_data %}{% endblock %}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}

    {% if google_analytics_id %}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ google_analytics_id }}"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '{{ google_analytics_id }}');
    </script>
    {% endif %}
</head>
<body class="min-h-screen bg-base-100 font-sans text-base-content">
    {% block body %}{% endblock %}
</body>
</html>
