{# Full feature-by-feature comparison of the four public tiers.
   No props — all values are static and match docs/05-monetization.md.
   The "AI Insights" row is conditional on the `ai_available` Twig global. #}

{% set check %}
<svg class="w-4 h-4 text-success inline" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
</svg>
{% endset %}

{% set dash %}<span class="text-base-content/30">—</span>{% endset %}

{# Desktop variant — full matrix table. #}
<div class="hidden md:block overflow-x-auto">
    <table class="table table-zebra w-full">
        <thead>
            <tr>
                <th class="w-1/3">Feature</th>
                <th class="text-center">Free</th>
                <th class="text-center">Personal</th>
                <th class="text-center">Pro</th>
                <th class="text-center">Business</th>
            </tr>
        </thead>
        <tbody>
            <tr class="bg-base-300/20">
                <td colspan="5" class="text-xs font-semibold uppercase tracking-wide text-base-content/50 py-2">Limits</td>
            </tr>
            <tr>
                <td>Domains</td>
                <td class="text-center">1</td>
                <td class="text-center">5</td>
                <td class="text-center">20</td>
                <td class="text-center">50</td>
            </tr>
            <tr>
                <td>Reports / month</td>
                <td class="text-center">100</td>
                <td class="text-center">1,000</td>
                <td class="text-center">10,000</td>
                <td class="text-center">50,000</td>
            </tr>
            <tr>
                <td>Report retention</td>
                <td class="text-center">30 days</td>
                <td class="text-center">1 year</td>
                <td class="text-center">2 years</td>
                <td class="text-center">Unlimited</td>
            </tr>
            <tr>
                <td>Team members (seats)</td>
                <td class="text-center">1</td>
                <td class="text-center">1</td>
                <td class="text-center">3</td>
                <td class="text-center">10</td>
            </tr>

            <tr class="bg-base-300/20">
                <td colspan="5" class="text-xs font-semibold uppercase tracking-wide text-base-content/50 py-2">Features</td>
            </tr>
            <tr>
                <td>DMARC + DNS monitoring</td>
                <td class="text-center">{{ check }}</td>
                <td class="text-center">{{ check }}</td>
                <td class="text-center">{{ check }}</td>
                <td class="text-center">{{ check }}</td>
            </tr>
            <tr>
                <td>Real-time alerts</td>
                <td class="text-center">{{ dash }}</td>
                <td class="text-center">{{ check }}</td>
                <td class="text-center">{{ check }}</td>
                <td class="text-center">{{ check }}</td>
            </tr>
            <tr>
                <td>Blacklist monitoring</td>
                <td class="text-center">{{ dash }}</td>
                <td class="text-center">{{ check }}</td>
                <td class="text-center">{{ check }}</td>
                <td class="text-center">{{ check }}</td>
            </tr>
            <tr>
                <td>Sender inventory</td>
                <td class="text-center">{{ dash }}</td>
                <td class="text-center">{{ check }}</td>
                <td class="text-center">{{ check }}</td>
                <td class="text-center">{{ check }}</td>
            </tr>
            <tr>
                <td>Email HTML reports</td>
                <td class="text-center">{{ dash }}</td>
                <td class="text-center">{{ check }}</td>
                <td class="text-center">{{ check }}</td>
                <td class="text-center">{{ check }}</td>
            </tr>

            <tr class="bg-base-300/20">
                <td colspan="5" class="text-xs font-semibold uppercase tracking-wide text-base-content/50 py-2">Advanced</td>
            </tr>
            <tr>
                <td>API access + webhooks</td>
                <td class="text-center">{{ dash }}</td>
                <td class="text-center">{{ dash }}</td>
                <td class="text-center">{{ check }}</td>
                <td class="text-center">{{ check }}</td>
            </tr>
            <tr>
                <td>White-label PDF reports</td>
                <td class="text-center">{{ dash }}</td>
                <td class="text-center">{{ dash }}</td>
                <td class="text-center">{{ dash }}</td>
                <td class="text-center">{{ check }}</td>
            </tr>
            <tr>
                <td>
                    AI Insights
                    {% if not ai_available %}<span class="badge badge-ghost badge-xs ml-1">coming soon</span>{% endif %}
                </td>
                <td class="text-center"><span class="text-base-content/40 text-xs">Contact us</span></td>
                <td class="text-center">
                    {% if ai_available %}
                        {{ check }} <span class="text-xs text-base-content/50">50/mo</span>
                    {% else %}
                        {{ dash }}
                    {% endif %}
                </td>
                <td class="text-center">
                    {% if ai_available %}
                        {{ check }} <span class="text-xs text-base-content/50">200/mo</span>
                    {% else %}
                        {{ dash }}
                    {% endif %}
                </td>
                <td class="text-center">
                    {% if ai_available %}
                        {{ check }} <span class="text-xs text-base-content/50">500/mo</span>
                    {% else %}
                        {{ dash }}
                    {% endif %}
                </td>
            </tr>

            <tr class="bg-base-300/20">
                <td colspan="5" class="text-xs font-semibold uppercase tracking-wide text-base-content/50 py-2">Support</td>
            </tr>
            <tr>
                <td>Support</td>
                <td class="text-center">Community</td>
                <td class="text-center">Email</td>
                <td class="text-center">Priority</td>
                <td class="text-center">Priority + SLA</td>
            </tr>
        </tbody>
    </table>
</div>

