{# Loading skeleton — matches the shape of a result card so the layout doesn't jump #}
<div class="card bg-base-100 border border-base-300 mt-6 animate-pulse" aria-hidden="true">
    <div class="card-body">
        <div class="flex items-center justify-between mb-4">
            <div class="h-5 bg-base-300 rounded w-1/2"></div>
            <div class="h-6 bg-base-300 rounded-full w-20"></div>
        </div>

        <div class="bg-base-200 rounded-lg p-4 mb-4">
            <div class="h-3 bg-base-300 rounded w-24 mb-2"></div>
            <div class="h-4 bg-base-300 rounded w-full"></div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
            <div class="bg-base-200 rounded-lg p-3 h-16"></div>
            <div class="bg-base-200 rounded-lg p-3 h-16"></div>
            <div class="bg-base-200 rounded-lg p-3 h-16"></div>
            <div class="bg-base-200 rounded-lg p-3 h-16"></div>
        </div>

        <div class="space-y-2">
            <div class="h-4 bg-base-200 rounded w-3/4"></div>
            <div class="h-4 bg-base-200 rounded w-2/3"></div>
        </div>
    </div>
</div>
