{# Empty state — shown when no data is available #}
{% props title, message, actionUrl = null, actionLabel = null, icon = null %}

<div class="flex flex-col items-center justify-center py-12 px-4 text-center">
    {% if icon %}
        <div class="w-16 h-16 rounded-full bg-base-200 flex items-center justify-center mb-4 text-base-content/30">
            {{ icon|raw }}
        </div>
    {% else %}
        <div class="w-16 h-16 rounded-full bg-base-200 flex items-center justify-center mb-4 text-base-content/30">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
        </div>
    {% endif %}

    <h3 class="text-lg font-semibold mb-1">{{ title }}</h3>
    <p class="text-sm text-base-content/50 max-w-sm">{{ message }}</p>

    {% if actionUrl and actionLabel %}
        <a href="{{ actionUrl }}" class="btn btn-primary btn-sm mt-4">{{ actionLabel }}</a>
    {% endif %}
</div>
