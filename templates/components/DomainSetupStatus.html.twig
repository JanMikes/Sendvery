{# Expanded per-protocol setup checklist (TASK-080). Three render branches —
   all-green card, partial checklist with per-row Fix-this links, or an
   all-Unknown info card with a Re-check now form button. All copy and state
   are pre-computed on DomainSetupStatus; this template is a props-only
   renderer with zero conditional logic beyond branch selection. #}
{% props status, domainId %}

{# TASK-097: `banner_only` (the all-green state) suppresses the panel — the
   one-line "Monitoring active" banner above is enough; the all-green
   confirmation card would just repeat the same news a second time. #}
{% if status.displayMode.value != 'banner_only' %}

{% set allConfigured = true %}
{% set allUnknown = true %}
{% set configuredCount = 0 %}
{% for protocol in status.protocols %}
    {% if protocol.state.value != 'configured' %}{% set allConfigured = false %}{% endif %}
    {% if protocol.state.value != 'unknown' %}{% set allUnknown = false %}{% endif %}
    {% if protocol.state.value == 'configured' %}{% set configuredCount = configuredCount + 1 %}{% endif %}
{% endfor %}

{% if allConfigured %}
    {# (a) All four checks passing — confirmation card. Matches the same
       rounded-2xl shell as the quarantine warning so it doesn't visually
       fight when both render on the same page. #}
    <div class="rounded-2xl border border-success/30 bg-success/5 p-5 mb-6" data-testid="domain-setup-status-all-green">
        <div class="flex items-start gap-3">
            <div class="w-9 h-9 rounded-full bg-success/15 text-success flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
            </div>
            <div class="flex-1">
                <div class="font-semibold text-base-content mb-1">DNS setup is complete</div>
                <p class="text-sm text-base-content/70">
                    SPF, DKIM, DMARC and MX are all in place for this domain. Reports flow in automatically — nothing for you to do here.
                </p>
            </div>
        </div>
    </div>
{% elseif allUnknown %}
    {# (c) No DNS check yet — info card. Re-check button mirrors the same form
       posted to dashboard_domain_reverify used by the quarantine and
       verification banners. #}
    <div class="rounded-2xl border border-info/30 bg-info/5 p-5 mb-6" data-testid="domain-setup-status-pending">
        <div class="flex items-start gap-3">
            <div class="w-9 h-9 rounded-full bg-info/15 text-info flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <div class="flex-1">
                <div class="font-semibold text-base-content mb-1">We haven't checked DNS yet</div>
                <p class="text-sm text-base-content/70">
                    Your first DNS check usually runs within 5 minutes of adding a domain. Re-check now to skip the wait.
                </p>
            </div>
            <form method="post" action="{{ path('dashboard_domain_reverify', {id: domainId}) }}" class="shrink-0">
                <button type="submit" class="btn btn-sm btn-info btn-outline">Re-check now</button>
            </form>
        </div>
    </div>
{% else %}
    {# (b) Partial setup — the actionable checklist. Each row shows a glyph
       sized to match the alerts list pattern, the precomputed status line,
       and (for failing rows) a one-sentence next-step plus a per-row "Fix
       this" deep-link to the matching #health-{protocol} anchor. #}
    <div class="card bg-base-100 border border-base-200 shadow-sm mb-6" data-testid="domain-setup-status-checklist">
        <div class="card-body p-5">
            <div class="flex items-start justify-between gap-3 mb-4">
                <div>
                    <div class="text-xs font-semibold uppercase tracking-wider text-base-content/50 mb-1">DNS setup</div>
                    <h2 class="text-lg font-semibold text-base-content">{{ configuredCount }} of 4 checks passing</h2>
                    <p class="text-sm text-base-content/60 mt-1">Finish the items below to start receiving DMARC reports for this domain.</p>
                </div>
            </div>
            <ul class="space-y-3">
                {% for protocol in status.protocols %}
                    {% set rowTone = {
                        'configured': {ring: 'bg-success/15 text-success', label: 'OK'},
                        'missing':    {ring: 'bg-error/15 text-error',     label: 'Missing'},
                        'invalid':    {ring: 'bg-warning/15 text-warning', label: 'Invalid'},
                        'unknown':    {ring: 'bg-base-200 text-base-content/50', label: 'Pending'},
                    }[protocol.state.value] %}
                    <li class="flex items-start gap-3" data-testid="domain-setup-row-{{ protocol.name|lower }}">
                        <span class="w-6 h-6 rounded-full {{ rowTone.ring }} flex items-center justify-center shrink-0 mt-0.5" aria-label="{{ rowTone.label }}">
                            {% if protocol.state.value == 'configured' %}
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                                </svg>
                            {% else %}
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"/>
                                </svg>
                            {% endif %}
                        </span>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span class="font-medium text-sm text-base-content">{{ protocol.name }}</span>
                                <span class="text-sm text-base-content/70">{{ protocol.statusLine }}</span>
                            </div>
                            {% if protocol.nextStep is not null %}
                                <p class="text-sm text-base-content/60 mt-1">{{ protocol.nextStep }}</p>
                                <a href="{{ path('dashboard_domain_health', {id: domainId}) }}#{{ protocol.healthAnchor }}"
                                   class="link link-primary text-sm mt-1 inline-block">
                                    Fix this →
                                </a>
                            {% endif %}
                        </div>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>
{% endif %}

{% endif %}
