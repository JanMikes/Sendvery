{% props title, subtitle = '', ctaText = '', ctaHref = '', ctaAction = '' %}

<section class="relative overflow-hidden bg-gradient-to-br from-base-100 via-base-100 to-primary/5 py-24 lg:py-32">
    <div class="container mx-auto text-center relative z-10">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight max-w-4xl mx-auto leading-tight">
            {{ title }}
        </h1>
        {% if subtitle %}
            <p class="mt-6 text-lg md:text-xl text-base-content/70 max-w-2xl mx-auto">
                {{ subtitle }}
            </p>
        {% endif %}
        {% if ctaText %}
            <div class="mt-10">
                <a href="{{ ctaHref }}"
                   class="btn btn-primary btn-lg"
                   {% if ctaAction %}{{ stimulus_action('scroll-to', 'scroll', 'click') }} data-scroll-to-target-value="{{ ctaAction }}"{% endif %}>
                    {{ ctaText }}
                </a>
            </div>
        {% endif %}
        {% block hero_extra %}{% endblock %}
    </div>
</section>
