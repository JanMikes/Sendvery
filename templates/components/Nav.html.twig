{# Navigation bar — responsive with mobile hamburger, dark mode toggle, tools dropdown #}
<nav class="navbar bg-base-100/80 backdrop-blur-md sticky top-0 z-50 border-b border-base-200"
     {{ stimulus_controller('mobile-nav') }}>
    <div class="container mx-auto">
        {# Logo #}
        <div class="flex-1">
            <a href="{{ path('home') }}" class="text-xl font-bold text-primary tracking-tight">
                Sendvery
            </a>
        </div>

        {# Desktop nav #}
        <div class="hidden lg:flex items-center gap-1">
            {# Tools dropdown #}
            <div class="dropdown dropdown-hover">
                <div tabindex="0" role="button" class="btn btn-ghost btn-sm">
                    Tools
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </div>
                <ul tabindex="0" class="dropdown-content menu bg-base-100 rounded-box shadow-lg border border-base-200 w-64 p-2 z-50">
                    <li><a href="{{ path('tools_spf_checker') }}">SPF Checker</a></li>
                    <li><a href="{{ path('tools_dkim_checker') }}">DKIM Checker</a></li>
                    <li><a href="{{ path('tools_dmarc_checker') }}">DMARC Checker</a></li>
                    <li><a href="{{ path('tools_email_auth_checker') }}">Email Auth Checker</a></li>
                    <li><a href="{{ path('tools_mx_checker') }}">MX Checker</a></li>
                    <li><a href="{{ path('tools_blacklist_checker') }}">Blacklist Checker</a></li>
                    <li><a href="{{ path('tools_dns_monitoring') }}">DNS Monitoring</a></li>
                    <li><a href="{{ path('tools_domain_health') }}">Domain Health</a></li>
                </ul>
            </div>

            <a href="{{ path('pricing') }}" class="btn btn-ghost btn-sm">Pricing</a>
            <a href="{{ path('about_open_source') }}" class="btn btn-ghost btn-sm">Open Source</a>

            {# Dark mode toggle #}
            <button class="btn btn-ghost btn-sm btn-square" {{ stimulus_action('dark-mode', 'toggle') }} aria-label="Toggle dark mode">
                <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
            </button>

            <a href="{{ path('home') }}#dns-checker" class="btn btn-primary btn-sm" {{ stimulus_action('scroll-to', 'scroll', 'click') }} data-scroll-to-target-value="dns-checker">
                Check your domain
            </a>
        </div>

        {# Mobile hamburger #}
        <div class="lg:hidden flex items-center gap-2">
            <button class="btn btn-ghost btn-sm btn-square" {{ stimulus_action('dark-mode', 'toggle') }} aria-label="Toggle dark mode">
                <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
            </button>
            <button class="btn btn-ghost btn-sm btn-square" {{ stimulus_action('mobile-nav', 'toggle') }} aria-label="Menu">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
            </button>
        </div>
    </div>

    {# Mobile menu #}
    <div class="lg:hidden hidden border-t border-base-200 bg-base-100"
         {{ stimulus_target('mobile-nav', 'menu') }}>
        <div class="container mx-auto py-4 flex flex-col gap-2">
            <span class="text-xs font-semibold text-base-content/50 uppercase tracking-wider px-3">Tools</span>
            <a href="{{ path('tools_spf_checker') }}" class="btn btn-ghost btn-sm justify-start">SPF Checker</a>
            <a href="{{ path('tools_dkim_checker') }}" class="btn btn-ghost btn-sm justify-start">DKIM Checker</a>
            <a href="{{ path('tools_dmarc_checker') }}" class="btn btn-ghost btn-sm justify-start">DMARC Checker</a>
            <a href="{{ path('tools_email_auth_checker') }}" class="btn btn-ghost btn-sm justify-start">Email Auth Checker</a>
            <a href="{{ path('tools_mx_checker') }}" class="btn btn-ghost btn-sm justify-start">MX Checker</a>
            <a href="{{ path('tools_blacklist_checker') }}" class="btn btn-ghost btn-sm justify-start">Blacklist Checker</a>
            <a href="{{ path('tools_dns_monitoring') }}" class="btn btn-ghost btn-sm justify-start">DNS Monitoring</a>
            <a href="{{ path('tools_domain_health') }}" class="btn btn-ghost btn-sm justify-start">Domain Health</a>
            <div class="divider my-1"></div>
            <a href="{{ path('pricing') }}" class="btn btn-ghost btn-sm justify-start">Pricing</a>
            <a href="{{ path('about_open_source') }}" class="btn btn-ghost btn-sm justify-start">Open Source</a>
            <a href="{{ path('home') }}#dns-checker" class="btn btn-primary btn-sm mt-2">Check your domain</a>
        </div>
    </div>
</nav>
