{# Top navigation — responsive with mobile hamburger and Tools dropdown.

   NOTE: we deliberately do NOT put daisyUI's `.navbar` class on the outer
   <nav> element. `.navbar` makes its container `display: flex`, which would
   then treat the top bar and the mobile menu panel as side-by-side flex
   items — the mobile menu would render as a narrow column next to the bar
   instead of dropping below it. Outer <nav> stays block; the top bar gets
   the visual chrome (min-height, padding) instead.

   NOTE (TASK-065): we deliberately do NOT mirror the sidebar attention
   badges (TASK-060 alerts count, TASK-061 unverified domains count, the
   existing quarantine count) on the marketing-site Dashboard CTA above.
   The marketing nav renders on PUBLIC pages (Pricing, Learn, Tools); a red
   count on the Dashboard button while the user is researching or sharing
   those pages would feel intrusive and would betray the user's session
   state to any over-the-shoulder onlooker. The dashboard sidebar is the
   right home for live attention signals — once the user is signed in and
   working, not while they're browsing public content. #}
<nav class="bg-base-100/80 backdrop-blur-md sticky top-0 z-50 border-b border-base-200 shadow-sm shadow-zinc-900/5"
     {{ stimulus_controller('mobile-nav') }}>
    <div class="container mx-auto flex items-center w-full gap-2 min-h-16 px-4">
        {# Logo #}
        <div class="flex-1 min-w-0">
            <a href="{{ path('home') }}" class="inline-flex items-center gap-2 text-xl font-bold text-primary tracking-tight">
                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 7.5 12 13l9-5.5"/>
                    <rect x="3" y="5" width="18" height="13" rx="2"/>
                    <path d="m9 14.5 2.5 2.5 4-5"/>
                </svg>
                Sendvery
            </a>
        </div>

        {# Desktop nav #}
        <div class="hidden lg:flex items-center gap-1">
            {# TASK-123: cold-visitor entry point to the long-form explainer.
               "Learn" is taken by the knowledge-base route, so the wording is
               the question framing ("What is this?") — ≤ 12 chars to keep the
               nav rhythm at 1024px. No badge per TASK-065 / CLAUDE.md. #}
            <a href="{{ path('about_what_is_sendvery') }}" class="btn btn-ghost btn-sm">What is this?</a>

            {# Tools dropdown #}
            <div class="dropdown dropdown-hover">
                <div tabindex="0" role="button" class="btn btn-ghost btn-sm">
                    Tools
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </div>
                <ul tabindex="0" class="dropdown-content menu bg-base-100 rounded-box shadow-lg border border-base-200 w-64 p-2 z-50">
                    <li><a href="{{ path('tools_spf_checker') }}">SPF Checker</a></li>
                    <li><a href="{{ path('tools_dkim_checker') }}">DKIM Checker</a></li>
                    <li><a href="{{ path('tools_dmarc_checker') }}">DMARC Checker</a></li>
                    <li><a href="{{ path('tools_email_auth_checker') }}">Email Auth Checker</a></li>
                    <li><a href="{{ path('tools_mx_checker') }}">MX Checker</a></li>
                    <li><a href="{{ path('tools_blacklist_checker') }}">Blacklist Checker</a></li>
                    <li><a href="{{ path('tools_dns_monitoring') }}">DNS Monitoring</a></li>
                    <li><a href="{{ path('tools_domain_health') }}">Domain Health</a></li>
                </ul>
            </div>

            <a href="{{ path('knowledge_base_index') }}" class="btn btn-ghost btn-sm">Learn</a>
            <a href="{{ path('pricing') }}" class="btn btn-ghost btn-sm">Pricing</a>
            <a href="{{ path('about_open_source') }}" class="btn btn-ghost btn-sm">Open Source</a>
            <a href="{{ path('about_contact') }}" class="btn btn-ghost btn-sm">Contact</a>

            {% if app.user %}
                <a href="{{ path('dashboard_overview') }}" class="btn btn-primary btn-sm">Dashboard</a>
            {% else %}
                <a href="{{ path('auth_login') }}" class="btn btn-ghost btn-sm">Sign in</a>
                <a href="{{ path('home') }}#dns-checker" class="btn btn-primary btn-sm" {{ stimulus_action('scroll-to', 'scroll', 'click') }} data-scroll-to-target-value="dns-checker">
                    Check your domain
                </a>
            {% endif %}
        </div>

        {# Mobile hamburger #}
        <div class="lg:hidden flex items-center gap-2">
            <button class="btn btn-ghost btn-sm btn-square" {{ stimulus_action('mobile-nav', 'toggle') }} aria-label="Menu">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
            </button>
        </div>
    </div>

    {# Mobile menu — compact list (11 items + divider + CTA fit a phone viewport
       only if we keep vertical rhythm tight). Plain anchors with py-2 give us
       a denser layout than daisyUI's btn-sm + gap-2. #}
    <div class="lg:hidden hidden border-t border-base-200 bg-base-100"
         {{ stimulus_target('mobile-nav', 'menu') }}>
        <div class="container mx-auto py-2 flex flex-col">
            {# TASK-123: same first-item placement on mobile — flat-link style, no dropdown wrapper. #}
            <a href="{{ path('about_what_is_sendvery') }}" class="px-3 py-2 rounded-btn text-sm font-medium hover:bg-base-200">What is this?</a>
            <div class="border-t border-base-200 my-2"></div>
            <span class="text-xs font-semibold text-base-content/50 uppercase tracking-wider px-3 pt-2 pb-1">Tools</span>
            <a href="{{ path('tools_spf_checker') }}" class="px-3 py-2 rounded-btn text-sm font-medium hover:bg-base-200">SPF Checker</a>
            <a href="{{ path('tools_dkim_checker') }}" class="px-3 py-2 rounded-btn text-sm font-medium hover:bg-base-200">DKIM Checker</a>
            <a href="{{ path('tools_dmarc_checker') }}" class="px-3 py-2 rounded-btn text-sm font-medium hover:bg-base-200">DMARC Checker</a>
            <a href="{{ path('tools_email_auth_checker') }}" class="px-3 py-2 rounded-btn text-sm font-medium hover:bg-base-200">Email Auth Checker</a>
            <a href="{{ path('tools_mx_checker') }}" class="px-3 py-2 rounded-btn text-sm font-medium hover:bg-base-200">MX Checker</a>
            <a href="{{ path('tools_blacklist_checker') }}" class="px-3 py-2 rounded-btn text-sm font-medium hover:bg-base-200">Blacklist Checker</a>
            <a href="{{ path('tools_dns_monitoring') }}" class="px-3 py-2 rounded-btn text-sm font-medium hover:bg-base-200">DNS Monitoring</a>
            <a href="{{ path('tools_domain_health') }}" class="px-3 py-2 rounded-btn text-sm font-medium hover:bg-base-200">Domain Health</a>
            <div class="border-t border-base-200 my-2"></div>
            <a href="{{ path('knowledge_base_index') }}" class="px-3 py-2 rounded-btn text-sm font-medium hover:bg-base-200">Learn</a>
            <a href="{{ path('pricing') }}" class="px-3 py-2 rounded-btn text-sm font-medium hover:bg-base-200">Pricing</a>
            <a href="{{ path('about_open_source') }}" class="px-3 py-2 rounded-btn text-sm font-medium hover:bg-base-200">Open Source</a>
            <a href="{{ path('about_contact') }}" class="px-3 py-2 rounded-btn text-sm font-medium hover:bg-base-200">Contact</a>
            {% if app.user %}
                <a href="{{ path('dashboard_overview') }}" class="btn btn-primary btn-sm mt-3">Dashboard</a>
            {% else %}
                <a href="{{ path('auth_login') }}" class="px-3 py-2 rounded-btn text-sm font-medium hover:bg-base-200">Sign in</a>
                <a href="{{ path('home') }}#dns-checker" class="btn btn-primary btn-sm mt-2">Check your domain</a>
            {% endif %}
        </div>
    </div>
</nav>
