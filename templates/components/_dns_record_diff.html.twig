{#
   TASK-127 — inline token-level diff for a CHANGED row on the DNS history
   page. Renders the current-record text with the tags that differ
   highlighted: removed tags strike through in error tone, added tags pop
   in success tone with `font-bold`. Unchanged tags render neutral so they
   visually fall back while the diff stands out.

   `diff` must be a `DnsRecordDiff`. Twig's auto-escape escapes each
   `segment.text` (raw user-controlled DNS record content), so we never
   render anything with `|raw`.
#}
{% macro render(diff) %}
    <code class="text-xs break-all leading-relaxed">
        {%- for segment in diff.segments -%}
            {%- if segment.kind.value == 'removed' -%}
                <span class="bg-error/20 line-through decoration-error/70 rounded-sm px-0.5">{{ segment.text }}</span>
            {%- elseif segment.kind.value == 'added' -%}
                <span class="bg-success/20 font-bold text-success-content/90 rounded-sm px-0.5">{{ segment.text }}</span>
            {%- else -%}
                {{- segment.text -}}
            {%- endif -%}
        {%- endfor -%}
    </code>
{% endmacro %}

{#
   Default-collapsed `<details>` revealing the full before/after records.
   Lives below the inline diff for the rare case where the user wants to
   eyeball the entire previous-vs-current record verbatim (long noisy
   records — long SPF chains, MX with many hosts).
#}
{% macro expander(diff) %}
    <details class="mt-2 group">
        <summary class="text-xs text-base-content/60 cursor-pointer hover:text-base-content list-none flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            <span>Show full before/after</span>
        </summary>
        <div class="mt-2 space-y-2">
            <div>
                <p class="text-xs uppercase tracking-wide text-base-content/50 mb-1">Before</p>
                <div class="bg-base-200 rounded-btn px-3 py-2">
                    {% if diff.previousRecord is empty %}
                        <span class="text-xs text-base-content/50 italic">No record</span>
                    {% else %}
                        <code class="text-xs break-all">{{ diff.previousRecord }}</code>
                    {% endif %}
                </div>
            </div>
            <div>
                <p class="text-xs uppercase tracking-wide text-base-content/50 mb-1">After</p>
                <div class="bg-base-200 rounded-btn px-3 py-2">
                    {% if diff.currentRecord is empty %}
                        <span class="text-xs text-base-content/50 italic">No record</span>
                    {% else %}
                        <code class="text-xs break-all">{{ diff.currentRecord }}</code>
                    {% endif %}
                </div>
            </div>
        </div>
    </details>
{% endmacro %}
