{# Domain card — summary for a monitored domain #}
{% props domainId, domainName, passRate = 0, totalReports = 0, latestReportDate = null, dmarcPolicy = null, teamName = null, severity = 'unverified', dnsGrade = null, dnsGradeColor = null, spfPass = null, dkimPass = null, dmarcPass = null, mxScore = null, domainHealthUrl = null %}

{# Severity tone map (single source of truth for left-border + glyph chip). #}
{% set severityTone = severity == 'healthy' ? 'success' : (severity == 'attention' ? 'warning' : 'error') %}

{# TASK-130: card root switched from `<a>` to `<div>` + stretched-link `<a>`
   inside, mirroring the pattern the old dns_health_overview.html.twig used.
   The reason: the new "DNS Health →" footer link is a real inner `<a>`, and
   nested anchors are invalid HTML. Stretched-link makes the whole card a
   click target for the domain-detail destination while the footer link gets
   its own click via `relative z-10` so the stretched link does not eat it. #}
<div class="card bg-base-100 border border-base-200 shadow-sm hover:shadow-md hover:border-primary/30 transition-all border-l-4 border-l-{{ severityTone }} relative">
    <a href="{{ path('dashboard_domain_detail', { id: domainId }) }}"
       class="absolute inset-0"
       aria-label="Open {{ domainName }}"></a>
    <div class="card-body p-4">
        <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-full bg-{{ severityTone }}/10 flex items-center justify-center shrink-0" aria-hidden="true">
                <svg class="w-5 h-5 text-{{ severityTone }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    {% if severity == 'healthy' %}
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                    {% elseif severity == 'attention' %}
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                    {% else %}
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    {% endif %}
                </svg>
            </div>
            <div class="flex items-start justify-between flex-1 min-w-0">
                <div class="min-w-0">
                    <h3 class="font-semibold text-base">{{ domainName }}</h3>
                    {% if teamName %}
                        <span class="inline-flex items-center gap-1 text-[10px] text-base-content/50 mt-0.5">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                            {{ teamName }}
                        </span>
                    {% endif %}
                    {% if dmarcPolicy %}
                        <twig:StatusBadge status="{{ dmarcPolicy }}" label="p={{ dmarcPolicy }}" />
                    {% endif %}
                </div>
                <div class="text-right shrink-0">
                    <div class="text-2xl font-bold {{ passRate >= 90 ? 'text-success' : (passRate >= 70 ? 'text-warning' : 'text-error') }}">
                        {{ passRate|number_format(1) }}%
                    </div>
                    <span class="text-xs text-base-content/50">pass rate</span>
                </div>
            </div>
        </div>

        {# TASK-130: DNS-health badge row — letter grade chip + four protocol
           badges (SPF/DKIM/DMARC/MX). These render as NON-INTERACTIVE styled
           spans by design: the card-wrap is a stretched-link `<a>`, so nested
           anchors would be invalid HTML. The "DNS Health →" footer link
           carries the single deep-link to the per-domain drill-down. #}
        {% if dnsGrade is not null or spfPass is not null or dkimPass is not null or dmarcPass is not null or mxScore is not null %}
            <div class="flex flex-wrap items-center gap-2 mt-3">
                {% if dnsGrade is not null %}
                    <span class="badge {{ dnsGradeColor ?? 'badge-ghost' }} font-bold"
                          aria-label="DNS health grade {{ dnsGrade }} for {{ domainName }}">{{ dnsGrade }}</span>
                {% endif %}
                {% if spfPass is not null %}
                    <span class="badge {{ spfPass ? 'badge-success' : 'badge-error' }}"
                          aria-label="SPF {{ spfPass ? 'verified' : 'not verified' }}">SPF</span>
                {% endif %}
                {% if dkimPass is not null %}
                    <span class="badge {{ dkimPass ? 'badge-success' : 'badge-error' }}"
                          aria-label="DKIM {{ dkimPass ? 'verified' : 'not verified' }}">DKIM</span>
                {% endif %}
                {% if dmarcPass is not null %}
                    <span class="badge {{ dmarcPass ? 'badge-success' : 'badge-error' }}"
                          aria-label="DMARC {{ dmarcPass ? 'verified' : 'not verified' }}">DMARC</span>
                {% endif %}
                {% if mxScore is not null %}
                    {% if mxScore >= 80 %}
                        <span class="badge badge-success" aria-label="MX records healthy">MX</span>
                    {% elseif mxScore >= 50 %}
                        <span class="badge badge-warning" aria-label="MX records degraded">MX</span>
                    {% else %}
                        <span class="badge badge-error" aria-label="MX records failing">MX</span>
                    {% endif %}
                {% endif %}
            </div>
        {% endif %}

        <div class="flex items-center gap-4 mt-3 text-xs text-base-content/50">
            <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                {{ totalReports }} {{ totalReports == 1 ? 'report' : 'reports' }}
            </span>
            {% if latestReportDate %}
                <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    {{ latestReportDate|date('M j, Y') }}
                </span>
            {% endif %}
        </div>

        {% if domainHealthUrl %}
            {# Single navigation destination from the badge area to the
               per-domain DNS drill-down. `relative z-10` stacks above the
               stretched-link card wrap so this anchor receives its own clicks. #}
            <div class="card-actions justify-end mt-3">
                <a href="{{ domainHealthUrl }}"
                   class="btn btn-ghost btn-xs relative z-10">
                    DNS Health
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </a>
            </div>
        {% endif %}
    </div>
</div>
