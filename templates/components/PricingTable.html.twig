{# Pricing card grid (DEC-052..057). The "Add AI Insights" toggle only
   renders when `ai_available` is true — i.e. ANTHROPIC_API_KEY is set.
   Without the key we have no real AI service to charge for, so the toggle
   stays hidden and the AI tier markup is suppressed entirely. #}

<div data-controller="pricing"
     data-pricing-billing-value="annual"
     data-pricing-ai-value="false"
     class="max-w-6xl mx-auto">

    <div class="flex flex-col md:flex-row gap-4 items-center justify-center mb-10">
        <div class="join">
            <button
                type="button"
                data-pricing-target="billingButton"
                data-action="pricing#setBilling"
                data-billing="monthly"
                aria-pressed="false"
                class="btn btn-sm join-item"
            >Monthly</button>
            <button
                type="button"
                data-pricing-target="billingButton"
                data-action="pricing#setBilling"
                data-billing="annual"
                aria-pressed="true"
                class="btn btn-sm join-item btn-active"
            >Annual <span class="badge badge-success badge-xs ml-2">−2 months</span></button>
        </div>
        {% if ai_available %}
            <label class="label gap-2 cursor-pointer">
                <input
                    type="checkbox"
                    data-pricing-target="aiToggle"
                    data-action="pricing#toggleAi"
                    class="toggle toggle-sm toggle-primary"
                >
                <span class="label-text">✨ Add AI Insights</span>
            </label>
        {% endif %}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">

        <div
            class="card bg-base-100 border border-base-300 shadow-sm"
            data-pricing-target="card"
            data-ai-available="false"
            data-price-monthly="$0"
            data-price-annual="$0"
            data-price-ai-monthly="$0"
            data-price-ai-annual="$0"
            data-strike-monthly=""
            data-strike-annual=""
            data-strike-ai-monthly=""
            data-strike-ai-annual=""
            data-note-monthly="Get started with 1 domain. No credit card."
            data-note-annual="Get started with 1 domain. No credit card."
            data-note-ai-monthly="Get started with 1 domain. No credit card."
            data-note-ai-annual="Get started with 1 domain. No credit card."
            data-chip-monthly=""
            data-chip-annual=""
            data-chip-ai-monthly=""
            data-chip-ai-annual=""
        >
            <div class="card-body">
                <h3 class="card-title text-lg">Free</h3>
                <div class="mt-2">
                    <span class="text-3xl font-bold" data-pricing-target="price">$0</span>
                    <span class="text-base-content/50 text-sm">/mo</span>
                    <span class="line-through text-base-content/40 text-sm ml-2 invisible" data-pricing-target="strikethrough"></span>
                </div>
                <p class="text-sm text-base-content/60 mt-2" data-pricing-target="billingNote">Get started with 1 domain. No credit card.</p>
                <div class="badge badge-success badge-sm mt-1 hidden" data-pricing-target="savingsChip"></div>
                <ul class="mt-4 space-y-2 text-sm">
                    <li>1 domain</li>
                    <li>100 reports/mo</li>
                    <li>30-day retention</li>
                    <li>DMARC + DNS monitoring</li>
                </ul>
                <div class="card-actions mt-6">
                    <a href="{{ path('auth_login') }}" class="btn btn-outline btn-sm w-full">Get started free</a>
                </div>
            </div>
        </div>

        <div
            class="card bg-base-100 border-2 border-primary shadow-lg relative"
            data-pricing-target="card"
            data-ai-available="{{ ai_available ? 'true' : 'false' }}"
            data-base-plan="personal"
            data-price-monthly="$5.99"
            data-price-annual="$4.99"
            data-price-ai-monthly="$9.99"
            data-price-ai-annual="$8.99"
            data-strike-monthly=""
            data-strike-annual="$5.99"
            data-strike-ai-monthly=""
            data-strike-ai-annual="$9.99"
            data-note-monthly="Billed monthly · Cancel anytime"
            data-note-annual="Billed annually at $59.88"
            data-note-ai-monthly="Billed monthly · Cancel anytime"
            data-note-ai-annual="Billed annually at $107.88"
            data-chip-monthly=""
            data-chip-annual="Save $12/yr"
            data-chip-ai-monthly=""
            data-chip-ai-annual="Save $12/yr"
        >
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="badge badge-primary badge-sm">Most popular</span>
            </div>
            <div class="card-body">
                <h3 class="card-title text-lg">Personal</h3>
                <div class="mt-2">
                    <span class="text-3xl font-bold" data-pricing-target="price">$4.99</span>
                    <span class="text-base-content/50 text-sm">/mo</span>
                    <span class="line-through text-base-content/40 text-sm ml-2" data-pricing-target="strikethrough">$5.99</span>
                </div>
                <p class="text-sm text-base-content/60 mt-2" data-pricing-target="billingNote">Billed annually at $59.88</p>
                <div class="badge badge-success badge-sm mt-1" data-pricing-target="savingsChip">Save $12/yr</div>
                <ul class="mt-4 space-y-2 text-sm">
                    <li>5 domains</li>
                    <li>1,000 reports/mo</li>
                    <li>1-year retention</li>
                    <li>Blacklist monitoring</li>
                    {% if ai_available %}
                        <li data-pricing-target="aiFeature" hidden>✨ AI Insights · 50 on-demand/mo</li>
                    {% endif %}
                </ul>
                <div class="card-actions mt-6">
                    <a
                        data-pricing-target="cta"
                        data-turbo="false"{# checkout 302 → Stripe carries a #fragment; Turbo's fetch-redirect would strip it, so force a native navigation #}
                        href="{{ path('dashboard_billing_upgrade', {plan: 'personal', interval: 'annual'}) }}"
                        data-href-monthly="{{ path('dashboard_billing_upgrade', {plan: 'personal', interval: 'monthly'}) }}"
                        data-href-annual="{{ path('dashboard_billing_upgrade', {plan: 'personal', interval: 'annual'}) }}"
                        {% if ai_available %}
                            data-href-ai-monthly="{{ path('dashboard_billing_upgrade', {plan: 'personal_ai', interval: 'monthly'}) }}"
                            data-href-ai-annual="{{ path('dashboard_billing_upgrade', {plan: 'personal_ai', interval: 'annual'}) }}"
                        {% endif %}
                        data-label-monthly="Get Personal"
                        data-label-annual="Get Personal"
                        data-label-ai-monthly="Get Personal + AI"
                        data-label-ai-annual="Get Personal + AI"
                        class="btn btn-primary btn-sm w-full"
                    >Get Personal</a>
                </div>
            </div>
        </div>

        <div
            class="card bg-base-100 border border-base-300 shadow-sm"
            data-pricing-target="card"
            data-ai-available="{{ ai_available ? 'true' : 'false' }}"
            data-base-plan="pro"
            data-price-monthly="$23.99"
            data-price-annual="$19.99"
            data-price-ai-monthly="$33.99"
            data-price-ai-annual="$29.99"
            data-strike-monthly=""
            data-strike-annual="$23.99"
            data-strike-ai-monthly=""
            data-strike-ai-annual="$33.99"
            data-note-monthly="Billed monthly · Cancel anytime"
            data-note-annual="Billed annually at $239.88"
            data-note-ai-monthly="Billed monthly · Cancel anytime"
            data-note-ai-annual="Billed annually at $359.88"
            data-chip-monthly=""
            data-chip-annual="Save $48/yr"
            data-chip-ai-monthly=""
            data-chip-ai-annual="Save $48/yr"
        >
            <div class="card-body">
                <h3 class="card-title text-lg">Pro</h3>
                <div class="mt-2">
                    <span class="text-3xl font-bold" data-pricing-target="price">$19.99</span>
                    <span class="text-base-content/50 text-sm">/mo</span>
                    <span class="line-through text-base-content/40 text-sm ml-2" data-pricing-target="strikethrough">$23.99</span>
                </div>
                <p class="text-sm text-base-content/60 mt-2" data-pricing-target="billingNote">Billed annually at $239.88</p>
                <div class="badge badge-success badge-sm mt-1" data-pricing-target="savingsChip">Save $48/yr</div>
                <ul class="mt-4 space-y-2 text-sm">
                    <li>20 domains</li>
                    <li>10,000 reports/mo</li>
                    <li>3 team members</li>
                    <li>2-year retention</li>
                    <li>API access + webhooks</li>
                    {% if ai_available %}
                        <li data-pricing-target="aiFeature" hidden>✨ AI Insights · 200 on-demand/mo</li>
                    {% endif %}
                </ul>
                <div class="card-actions mt-6">
                    <a
                        data-pricing-target="cta"
                        data-turbo="false"{# checkout 302 → Stripe carries a #fragment; Turbo's fetch-redirect would strip it, so force a native navigation #}
                        href="{{ path('dashboard_billing_upgrade', {plan: 'pro', interval: 'annual'}) }}"
                        data-href-monthly="{{ path('dashboard_billing_upgrade', {plan: 'pro', interval: 'monthly'}) }}"
                        data-href-annual="{{ path('dashboard_billing_upgrade', {plan: 'pro', interval: 'annual'}) }}"
                        {% if ai_available %}
                            data-href-ai-monthly="{{ path('dashboard_billing_upgrade', {plan: 'pro_ai', interval: 'monthly'}) }}"
                            data-href-ai-annual="{{ path('dashboard_billing_upgrade', {plan: 'pro_ai', interval: 'annual'}) }}"
                        {% endif %}
                        data-label-monthly="Get Pro"
                        data-label-annual="Get Pro"
                        data-label-ai-monthly="Get Pro + AI"
                        data-label-ai-annual="Get Pro + AI"
                        class="btn btn-primary btn-sm w-full"
                    >Get Pro</a>
                </div>
            </div>
        </div>

        <div
            class="card bg-base-100 border border-base-300 shadow-sm"
            data-pricing-target="card"
            data-ai-available="{{ ai_available ? 'true' : 'false' }}"
            data-base-plan="business"
            data-price-monthly="$59.99"
            data-price-annual="$49.99"
            data-price-ai-monthly="$79.99"
            data-price-ai-annual="$69.99"
            data-strike-monthly=""
            data-strike-annual="$59.99"
            data-strike-ai-monthly=""
            data-strike-ai-annual="$79.99"
            data-note-monthly="Billed monthly · Cancel anytime"
            data-note-annual="Billed annually at $599.88"
            data-note-ai-monthly="Billed monthly · Cancel anytime"
            data-note-ai-annual="Billed annually at $839.88"
            data-chip-monthly=""
            data-chip-annual="Save $120/yr"
            data-chip-ai-monthly=""
            data-chip-ai-annual="Save $120/yr"
        >
            <div class="card-body">
                <h3 class="card-title text-lg">Business</h3>
                <div class="mt-2">
                    <span class="text-3xl font-bold" data-pricing-target="price">$49.99</span>
                    <span class="text-base-content/50 text-sm">/mo</span>
                    <span class="line-through text-base-content/40 text-sm ml-2" data-pricing-target="strikethrough">$59.99</span>
                </div>
                <p class="text-sm text-base-content/60 mt-2" data-pricing-target="billingNote">Billed annually at $599.88</p>
                <div class="badge badge-success badge-sm mt-1" data-pricing-target="savingsChip">Save $120/yr</div>
                <ul class="mt-4 space-y-2 text-sm">
                    <li>50 domains</li>
                    <li>50,000 reports/mo</li>
                    <li>10 team members</li>
                    <li>Unlimited retention</li>
                    <li>White-label PDF reports</li>
                    {% if ai_available %}
                        <li data-pricing-target="aiFeature" hidden>✨ AI Insights · 500 on-demand/mo</li>
                    {% endif %}
                </ul>
                <div class="card-actions mt-6">
                    <a
                        data-pricing-target="cta"
                        data-turbo="false"{# checkout 302 → Stripe carries a #fragment; Turbo's fetch-redirect would strip it, so force a native navigation #}
                        href="{{ path('dashboard_billing_upgrade', {plan: 'business', interval: 'annual'}) }}"
                        data-href-monthly="{{ path('dashboard_billing_upgrade', {plan: 'business', interval: 'monthly'}) }}"
                        data-href-annual="{{ path('dashboard_billing_upgrade', {plan: 'business', interval: 'annual'}) }}"
                        {% if ai_available %}
                            data-href-ai-monthly="{{ path('dashboard_billing_upgrade', {plan: 'business_ai', interval: 'monthly'}) }}"
                            data-href-ai-annual="{{ path('dashboard_billing_upgrade', {plan: 'business_ai', interval: 'annual'}) }}"
                        {% endif %}
                        data-label-monthly="Get Business"
                        data-label-annual="Get Business"
                        data-label-ai-monthly="Get Business + AI"
                        data-label-ai-annual="Get Business + AI"
                        class="btn btn-primary btn-sm w-full"
                    >Get Business</a>
                </div>
            </div>
        </div>

    </div>

    <p class="text-center mt-8 text-sm text-base-content/60">
        Need more? <a href="mailto:jan.mikes@sendvery.com?subject=Enterprise%20inquiry" class="link link-primary">Talk to us about Enterprise →</a>
    </p>
    <p class="text-center mt-3 text-xs text-base-content/40">VAT included where applicable. Prices in USD.</p>
</div>
