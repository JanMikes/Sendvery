{% props items = [] %}

<div class="space-y-3 max-w-3xl mx-auto">
    {% for item in items %}
        <div class="collapse collapse-arrow bg-base-200/50 border border-base-300">
            <input type="radio" name="faq" {% if loop.first %}checked="checked"{% endif %}>
            <div class="collapse-title font-semibold">{{ item.question }}</div>
            <div class="collapse-content text-base-content/70 text-sm">
                <p>{{ item.answer|raw }}</p>
            </div>
        </div>
    {% endfor %}
</div>
