{% props title, description, icon = '' %}

<div class="card bg-base-200/50 border border-base-300 hover:border-primary/30 transition-colors">
    <div class="card-body">
        {% if icon %}
            <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-2 text-primary">
                {{ icon|raw }}
            </div>
        {% endif %}
        <h3 class="card-title text-lg">{{ title }}</h3>
        <p class="text-base-content/60 text-sm">{{ description }}</p>
    </div>
</div>
