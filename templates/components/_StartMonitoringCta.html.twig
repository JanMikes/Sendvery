{# Post-scan CTA used by every checker result template.

   Inputs:
     - domain (string)          The domain that was just scanned.
     - variant ('wide'|'compact'|'banner') Display style. Defaults to 'wide'.
                                'compact' — small inline card inside cramped result cards (e.g. home).
                                'wide'    — full result-card-width CTA shown directly under tool results.
                                'banner'  — full-bleed gradient section, intended outside the card.
#}
{% set variant = variant|default('wide') %}
{% set isLoggedIn = app.user is not null %}

{% if isLoggedIn %}
    {% set ctaHref = path('dashboard_domain_add', {domain: domain}) %}
    {% set ctaButton = 'Add ' ~ domain ~ ' to your account' %}
    {% set ctaButtonShort = 'Add to account' %}
    {% set ctaHeadline = 'Track ' ~ domain ~ ' in your dashboard' %}
    {% set ctaBody = "We'll watch this domain's DNS, parse incoming DMARC reports, and alert you the moment something changes." %}
{% else %}
    {% set ctaHref = path('auth_login', {domain: domain}) %}
    {% set ctaButton = 'Start monitoring ' ~ domain ~ ' →' %}
    {% set ctaButtonShort = 'Start now →' %}
    {% set ctaHeadline = 'Stay ahead of email breakage' %}
    {% set ctaBody = 'SPF and DKIM break silently — a new sender, a DNS migration, an expired key. Sendvery checks ' ~ domain ~ ' every day and alerts you the moment something changes.' %}
{% endif %}

{% if variant == 'compact' %}
    <div class="mt-4 rounded-xl border border-primary/20 bg-gradient-to-br from-primary/5 to-base-100 p-4 flex items-center justify-between gap-3">
        <div class="min-w-0">
            <p class="text-sm font-semibold leading-tight">
                {% if isLoggedIn %}
                    Add <span class="font-mono text-primary truncate">{{ domain }}</span>
                {% else %}
                    Monitor <span class="font-mono text-primary truncate">{{ domain }}</span>
                {% endif %}
            </p>
            <p class="text-xs text-base-content/60 mt-0.5">
                {% if isLoggedIn %}Track DNS changes & parse DMARC reports.{% else %}Get alerts when records change.{% endif %}
            </p>
        </div>
        <a href="{{ ctaHref }}" class="btn btn-primary btn-sm shrink-0 whitespace-nowrap">
            {{ ctaButtonShort }}
        </a>
    </div>
{% elseif variant == 'banner' %}
    <section class="py-12 lg:py-16 bg-gradient-to-br from-primary/10 via-base-100 to-accent-500/5">
        <div class="container mx-auto">
            <div class="max-w-3xl mx-auto text-center">
                <h2 class="text-2xl md:text-3xl font-bold">{{ ctaHeadline }}</h2>
                {% if isLoggedIn %}
                    <p class="mt-3 text-base-content/60 text-base md:text-lg">{{ ctaBody }}</p>
                {% else %}
                    {# TASK-117: 3-bullet "what you also get" list replaces the single-paragraph sell for first-touch visitors. Names the round-4 features (DMARC parsing, sender inventory, regression alerts) that a public DMARC-record lookup tool can't surface, so a visitor seeing a D grade doesn't walk away thinking we're a DNS-change watcher. #}
                    <ul class="mt-5 space-y-2 text-left max-w-xl mx-auto">
                        <li class="flex gap-3 items-start">
                            <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M5 13l4 4L19 7"/></svg>
                            <span class="text-sm md:text-base text-base-content/80">Parse every DMARC report automatically — see who's sending as you, with what pass rate</span>
                        </li>
                        <li class="flex gap-3 items-start">
                            <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M5 13l4 4L19 7"/></svg>
                            <span class="text-sm md:text-base text-base-content/80">Get alerted the moment a sender starts failing or your pass rate drops</span>
                        </li>
                        <li class="flex gap-3 items-start">
                            <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M5 13l4 4L19 7"/></svg>
                            <span class="text-sm md:text-base text-base-content/80">Plain-English setup guidance — no XML reading required</span>
                        </li>
                    </ul>
                {% endif %}
                <div class="mt-7">
                    <a href="{{ ctaHref }}" class="btn btn-primary btn-lg h-auto py-4 leading-snug text-center">{{ ctaButton }}</a>
                    {% if not isLoggedIn %}
                        <p class="text-xs text-base-content/50 mt-3">Free plan • No credit card • 2-minute setup</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>
{% else %}
    {# wide — slot-in card to live inside an existing layout / result card area #}
    <div class="mt-6 rounded-2xl border border-primary/20 bg-gradient-to-br from-primary/8 via-base-100 to-accent-500/5 p-6 md:p-8">
        <div class="flex flex-col md:flex-row md:items-start gap-5">
            <div class="flex-1 min-w-0">
                <h3 class="text-lg md:text-xl font-bold leading-snug">{{ ctaHeadline }}</h3>
                {% if isLoggedIn %}
                    <p class="text-sm text-base-content/70 mt-1.5">{{ ctaBody }}</p>
                {% else %}
                    {# TASK-117: 3-bullet "what you also get" list replaces the single-paragraph sell. Names the round-4 features a public DMARC-record lookup tool can't deliver — DMARC report parsing, sender inventory, pass-rate / DNS regression alerts. #}
                    <ul class="mt-2.5 space-y-1.5">
                        <li class="flex gap-2.5 items-start">
                            <svg class="w-4 h-4 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                            <span class="text-sm text-base-content/75">Parse every DMARC report automatically — see who's sending as you, with what pass rate</span>
                        </li>
                        <li class="flex gap-2.5 items-start">
                            <svg class="w-4 h-4 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                            <span class="text-sm text-base-content/75">Get alerted the moment a sender starts failing or your pass rate drops</span>
                        </li>
                        <li class="flex gap-2.5 items-start">
                            <svg class="w-4 h-4 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                            <span class="text-sm text-base-content/75">Plain-English setup guidance — no XML reading required</span>
                        </li>
                    </ul>
                    <p class="text-xs text-base-content/50 mt-3">Free plan • No credit card • 2-minute setup</p>
                {% endif %}
            </div>
            <div class="shrink-0 md:self-center">
                {# h-auto + py-3 + leading-snug: long domains wrap to 2 lines and daisyUI's fixed min-height leaves the text visually squished — let height grow with content and add real vertical padding. #}
                <a href="{{ ctaHref }}" class="btn btn-primary btn-block md:btn-wide h-auto py-3 leading-snug text-center">{{ ctaButton }}</a>
            </div>
        </div>
    </div>
{% endif %}
