{#
   Shared severity glyph — single source of truth for the leading row-glyph
   used across TASK-066 (DomainCard) family of list surfaces:
   TASK-068 mailboxes, TASK-069 reports, TASK-070 alerts, TASK-071 quarantine.

   `severity` accepts one of: 'success'|'warning'|'error'|'info'|'neutral'.
   `neutral` renders as the daisyUI base-300 ghost dot used for "inactive"
   / undifferentiated rows where success/warning/error would all over-claim.

   `size` accepts 'sm' (24px → w-6 h-6), 'md' (32px → w-8 h-8),
   'lg' (40px → w-10 h-10). The icon glyph inside scales to about half.

   SVG paths are lifted from the canonical glyphs already shipping in the
   codebase (overview.html.twig:20 check-circle, alerts.html.twig:101
   exclamation-triangle, the universal exclamation-circle / info-circle).
#}
{% macro glyph(severity, size = 'sm') %}
    {%- set wrapperClass = {
        'sm': 'w-6 h-6',
        'md': 'w-8 h-8',
        'lg': 'w-10 h-10',
    }[size] ?? 'w-6 h-6' -%}
    {%- set iconClass = {
        'sm': 'w-3.5 h-3.5',
        'md': 'w-4 h-4',
        'lg': 'w-5 h-5',
    }[size] ?? 'w-3.5 h-3.5' -%}
    {%- set tone = severity == 'neutral' ? 'base-content/40' : severity -%}
    {%- set bgTone = severity == 'neutral' ? 'base-300' : severity -%}
    <span class="{{ wrapperClass }} rounded-full bg-{{ bgTone }}/10 flex items-center justify-center shrink-0" aria-hidden="true">
        <svg class="{{ iconClass }} text-{{ tone }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            {%- if severity == 'success' -%}
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            {%- elseif severity == 'warning' -%}
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
            {%- elseif severity == 'error' -%}
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            {%- elseif severity == 'info' -%}
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            {%- else -%}
                {# neutral: 8px-ish hollow dot — visually quiet for inactive rows. #}
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 12m-3 0a3 3 0 106 0a3 3 0 10-6 0"/>
            {%- endif -%}
        </svg>
    </span>
{% endmacro %}

{#
   Convenience: passRate → severity. Mirrors the pass-rate text-color
   thresholds already used inline across templates (≥90 success, 70–89.99
   warning, <70 error). Null pass-rate is treated as warning — "data missing"
   should be a "look at me" cue, not a green-tinted lie.
#}
{% macro pass_rate_tone(passRate) %}
    {%- if passRate is null -%}warning
    {%- elseif passRate >= 90 -%}success
    {%- elseif passRate >= 70 -%}warning
    {%- else -%}error
    {%- endif -%}
{% endmacro %}
