{# Unified section header: small uppercase eyebrow + larger H2 + optional lede.
   Replaces the seven+ identical `<h2 class="text-2xl md:text-3xl font-bold">`
   blocks on the homepage so each section can carry a distinct visual weight.
   See TASK-026 in docs/cx-improvement-backlog.md. #}
{% props eyebrow = null, title, lede = null, centered = true %}

<div class="{{ centered ? 'text-center' : '' }} mb-10">
    {% if eyebrow %}<div class="text-xs font-semibold uppercase tracking-[0.18em] text-primary mb-3">{{ eyebrow }}</div>{% endif %}
    <h2 class="text-3xl md:text-4xl font-bold tracking-tight">{{ title }}</h2>
    {% if lede %}<p class="mt-4 text-base-content/65 text-lg{{ centered ? ' max-w-2xl mx-auto' : '' }}">{{ lede }}</p>{% endif %}
</div>
