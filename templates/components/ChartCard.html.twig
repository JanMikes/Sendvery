{# Chart card — wraps an ApexCharts instance #}
{% props title, description = null, config = '{}', height = '300px' %}

<div class="card bg-base-100 border border-base-200 shadow-sm">
    <div class="card-body p-4">
        <h3 class="text-sm font-semibold">{{ title }}</h3>
        {% if description %}
            <p class="text-xs text-base-content/50 mt-0.5">{{ description }}</p>
        {% endif %}
        <div class="mt-3" style="min-height: {{ height }}"
             {{ stimulus_controller('chart', { config: config }) }}>
        </div>
    </div>
</div>
