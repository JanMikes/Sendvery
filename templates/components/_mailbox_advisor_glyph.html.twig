{# Inline SVG glyphs for the mailbox-health advisor primary CTA (TASK-108).
   Mapping `MailboxHealthAdvisorAction.glyph` keys to icon shapes lives here
   so the advisor service stays glyph-symbol-agnostic — adding a new glyph is
   a template-only change. All glyphs sit on the same 16x16 viewport, sized
   `w-4 h-4` to match the daisyUI `btn btn-sm` text x-height.

   Glyphs are heroicons-style stroke paths (matching existing usage in the
   alerts page) so we don't need an extra dependency. #}
{% set glyph = glyph|default('search') %}
{% if glyph == 'unlink' %}
    {# TASK-108 — "Disconnect this mailbox" CTA. Broken-chain glyph. #}
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 015.656 0l1.414 1.414a4 4 0 010 5.656l-1.414 1.414a4 4 0 01-5.656 0M10.172 13.828a4 4 0 01-5.656 0L3.1 12.414a4 4 0 010-5.656l1.414-1.414a4 4 0 015.656 0M3 3l3 3m12 12l3 3"></path>
    </svg>
{% elseif glyph == 'pencil' %}
    {# TASK-108 — "Publish a DMARC record" CTA. #}
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
    </svg>
{% elseif glyph == 'retest' %}
    {# Re-test connection — circular arrow / refresh glyph. #}
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
    </svg>
{% elseif glyph == 'quarantine' %}
    {# Open quarantine for this mailbox — shield glyph. #}
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
    </svg>
{% else %}
    {# Default — `search` glyph for the "Check DNS" CTA. #}
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z"></path>
    </svg>
{% endif %}
