<section id="testimonials" class="py-20 lg:py-24">
    <div class="container mx-auto">
        <div class="max-w-3xl mx-auto">
            <twig:SectionHeader
                eyebrow="What practitioners say"
                title="Trusted by the people who actually read DMARC reports"
            />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
            {% for entry in testimonials|slice(0, 3) %}
                <div class="card bg-base-100 border border-base-300">
                    <div class="card-body flex flex-col gap-4">
                        <p class="text-base-content/80 text-sm leading-relaxed flex-1">&ldquo;{{ entry.quote }}&rdquo;</p>
                        <div class="flex items-center gap-3">
                            <div class="avatar avatar-placeholder">
                                <div class="bg-primary/10 text-primary w-10 rounded-full">
                                    <span class="text-sm font-semibold">{{ entry.initials }}</span>
                                </div>
                            </div>
                            <div class="min-w-0">
                                <div class="font-semibold text-sm truncate">{{ entry.name }}</div>
                                <div class="text-xs text-base-content/50 truncate">
                                    {{ entry.role }} &middot;
                                    <span class="font-medium text-base-content/60">{{ entry.company }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</section>
