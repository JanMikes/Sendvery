{
    "$schema": "https://raw.githubusercontent.com/infection/infection/0.29.0/resources/schema.json",
    "source": {
        "directories": ["src"]
    },
    "logs": {
        "text": "var/infection/infection-log.txt",
        "summary": "var/infection/summary-log.txt"
    },
    "mutators": {
        "@default": true
    },
    "phpUnit": {
        "configDir": "."
    },
    "minMsi": 80,
    "minCoveredMsi": 90
}
