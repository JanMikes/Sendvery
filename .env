# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change-me-in-production
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://app:secret@database:5432/sendvery?serverVersion=17"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?queue_name=messages
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=smtp://mailpit:1025
###< symfony/mailer ###

###> sendvery/reports-ingestion ###
# Email address customers point their DMARC `rua=` at. Used in onboarding
# instructions and dashboard hints. Self-hosters set this to their own inbox.
SENDVERY_REPORT_ADDRESS=reports@sendvery.com

# Where notifications about domain-ownership inquiries land. The "Notify
# admin" button on the "domain already monitored" page sends here.
SENDVERY_ADMIN_EMAIL=jan.mikes@sendvery.com

# Central reports inbox (Seznam Email Profi by default). Leave USERNAME
# blank to disable the central inbox — only BYO mailbox connections will
# be polled. Self-hosters that don't want a central inbox can ignore the
# rest of these settings.
SENDVERY_REPORTS_INBOX_HOST=
SENDVERY_REPORTS_INBOX_PORT=993
SENDVERY_REPORTS_INBOX_USERNAME=
SENDVERY_REPORTS_INBOX_PASSWORD=
SENDVERY_REPORTS_INBOX_ENCRYPTION=ssl
SENDVERY_REPORTS_INBOX_PENDING_FOLDER=Sendvery/Pending
SENDVERY_REPORTS_INBOX_PROCESSED_FOLDER=Sendvery/Processed
SENDVERY_REPORTS_INBOX_FAILED_FOLDER=Sendvery/Failed
SENDVERY_REPORTS_INBOX_JUNK_FOLDER=Sendvery/Junk
SENDVERY_REPORTS_INBOX_BATCH_SIZE=200
SENDVERY_REPORTS_INBOX_MAX_MESSAGE_BYTES=26214400

# Quarantined reports for unverified/unrecognized domains are kept this long.
SENDVERY_QUARANTINE_TTL_DAYS=60
# Parsed envelopes are purged from DB and from the Processed IMAP folder after this many days.
SENDVERY_ENVELOPE_PURGE_AFTER_DAYS=30
###< sendvery/reports-ingestion ###

###> sentry/sentry-symfony ###
SENTRY_DSN=
# Release version reported to Sentry. Wire to your build/commit SHA in CI.
SENTRY_RELEASE=
# Fraction of requests/messages to trace (0.0 – 1.0). Keep low in production.
SENTRY_TRACES_SAMPLE_RATE=0
# Shared secret to enable on-demand profiling via ?_profile=<secret>.
# Leave empty to disable the toggle. Generate with: php -r "echo bin2hex(random_bytes(16));"
SENTRY_PROFILING_SECRET=
###< sentry/sentry-symfony ###

###> sendvery/credential-encryption ###
# 32-byte key, base64-encoded. Generate with: php -r "echo base64_encode(random_bytes(32));"
ENCRYPTION_KEY="YWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWE="
###< sendvery/credential-encryption ###

###> stripe ###
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Price IDs (3 paid tiers × 2 AI variants × 2 cadences = 12). Created in Stripe
# dashboard during the cutover (see docs/12-fake-door-stripe.md).
STRIPE_PRICE_PERSONAL_MONTHLY=
STRIPE_PRICE_PERSONAL_ANNUAL=
STRIPE_PRICE_PERSONAL_AI_MONTHLY=
STRIPE_PRICE_PERSONAL_AI_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_PRO_AI_MONTHLY=
STRIPE_PRICE_PRO_AI_ANNUAL=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_ANNUAL=
STRIPE_PRICE_BUSINESS_AI_MONTHLY=
STRIPE_PRICE_BUSINESS_AI_ANNUAL=

###< stripe ###

###> anthropic ###
# Presence of ANTHROPIC_API_KEY is the AI-purchasable gate (DEC-057):
# when set, real AI is wired and AI plan variants are purchasable +
# the pricing-page AI toggle is visible. When unset, AI variants are
# hidden and StripePriceResolver throws AiNotYetPurchasable.
ANTHROPIC_API_KEY=
###< anthropic ###

###> sendvery/open-source ###
# Gates the public "View on GitHub" CTA on /about/open-source. The repo
# is private until launch (docs/03-features-roadmap.md Phase 2); flip to
# "1" when the repo flips public so visitors stop seeing the disabled
# "Coming soon" button.
SENDVERY_REPO_PUBLIC=0
###< sendvery/open-source ###

###> symfony/routing ###
DEFAULT_URI=http://localhost:8080
###< symfony/routing ###
