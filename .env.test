# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='test-secret'
DATABASE_URL="postgresql://app:secret@database:5432/sendvery_test?serverVersion=17"
MESSENGER_TRANSPORT_DSN=in-memory://
ENCRYPTION_KEY="YWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWE="
MAILER_DSN=null://null
STRIPE_SECRET_KEY=sk_test_fake
STRIPE_WEBHOOK_SECRET=whsec_test_fake
STRIPE_PUBLISHABLE_KEY=pk_test_fake
# Prices resolve by Stripe lookup key at runtime (no price-ID env vars). The
# resolver's lookup-key mapping is unit-tested; the Prices-API resolution and
# checkout calls hit Stripe and are exercised only in the live smoke-test.
ANTHROPIC_API_KEY=sk-ant-test-fake
# Unreachable host + MockHttpClient = tests never touch the network (belt and braces).
ANTHROPIC_API_BASE_URL=https://api.anthropic.test
ANTHROPIC_MODEL_EXPLAIN_REPORT=claude-sonnet-4-6
ANTHROPIC_MODEL_EXPLAIN_ANOMALY=claude-sonnet-4-6
ANTHROPIC_MODEL_WEEKLY_DIGEST=claude-sonnet-4-6
ANTHROPIC_MODEL_REMEDIATION=claude-haiku-4-5
ANTHROPIC_MODEL_SENDER_LABEL=claude-haiku-4-5
SENDVERY_REPORT_ADDRESS=reports@sendvery.test
SENDVERY_ADMIN_EMAIL=admin@sendvery.test
SENDVERY_REPORTS_INBOX_HOST=imap.fake.test
SENDVERY_REPORTS_INBOX_PORT=993
SENDVERY_REPORTS_INBOX_USERNAME=reports@sendvery.test
SENDVERY_REPORTS_INBOX_PASSWORD=ignored-in-tests
SENDVERY_REPORTS_INBOX_ENCRYPTION=ssl
SENDVERY_REPORTS_INBOX_PENDING_FOLDER=Sendvery/Pending
SENDVERY_REPORTS_INBOX_PROCESSED_FOLDER=Sendvery/Processed
